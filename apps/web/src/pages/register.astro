---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../lib/api";
const title = `Daftar — ${APP_NAME}`;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: #0b1220;
        color: #f1f5f9;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        line-height: 1.55;
      }
      a { color: #38bdf8; text-decoration: none; }
      .wrap { max-width: 480px; margin: 0 auto; padding: 32px 20px 80px; }
      .back { font-size: 14px; color: #94a3b8; }
      .card {
        background: #0f172a;
        border: 1px solid #1e293b;
        border-radius: 14px;
        padding: 28px;
        margin-top: 24px;
      }
      .eyebrow { color: #fbbf24; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; }
      h1 { margin: 8px 0 12px; font-size: 28px; line-height: 1.15; }
      h2 { margin: 8px 0 12px; font-size: 22px; line-height: 1.2; }
      p { color: #94a3b8; margin: 0 0 20px; }
      label { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
      .lbl { font-size: 13px; font-weight: 600; }
      input {
        background: #0b1220;
        border: 1px solid #1e293b;
        color: #f1f5f9;
        padding: 14px 14px;
        border-radius: 10px;
        font-size: 16px;
        font-family: inherit;
        width: 100%;
      }
      input:focus { outline: none; border-color: #fbbf24; box-shadow: 0 0 0 3px rgba(251, 191, 36, .15); }
      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        padding: 14px 20px; border-radius: 10px; font-weight: 600;
        border: 1px solid transparent; cursor: pointer; font-size: 16px;
        width: 100%;
      }
      .btn-primary { background: #fbbf24; color: #0b1220; }
      .btn-primary:hover { background: #f59e0b; }
      .btn-ghost { background: transparent; color: #f1f5f9; border-color: #1e293b; }
      .btn:disabled { opacity: .5; cursor: not-allowed; }
      .err {
        background: rgba(251, 113, 133, .12);
        color: #fb7185;
        border: 1px solid rgba(251, 113, 133, .3);
        padding: 10px 12px; border-radius: 10px;
        font-size: 14px; margin-bottom: 16px;
      }
      .info {
        background: rgba(56, 189, 248, .1);
        color: #38bdf8;
        border: 1px solid rgba(56, 189, 248, .3);
        padding: 10px 12px; border-radius: 10px;
        font-size: 14px; margin-bottom: 16px;
      }
      .dev-code {
        font-family: ui-monospace, monospace;
        font-size: 22px; letter-spacing: 4px;
        background: #0b1220; border: 1px dashed #fbbf24;
        padding: 12px 16px; border-radius: 10px;
        text-align: center; color: #fbbf24; margin: 8px 0 16px;
      }
      .step2 { display: none; margin-top: 28px; padding-top: 24px; border-top: 1px solid #1e293b; }
      .step2.show { display: block; }
      .small { font-size: 13px; color: #94a3b8; }
      .muted { color: #94a3b8; }
      .role-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
      .role-card {
        background: #0b1220;
        border: 1px solid #1e293b;
        border-radius: 12px;
        padding: 16px 14px;
        cursor: pointer;
        transition: all .15s ease;
        text-align: left;
        color: #f1f5f9;
        font-family: inherit;
      }
      .role-card:hover { border-color: #fbbf24; }
      .role-card.selected {
        border-color: #fbbf24;
        background: rgba(251, 191, 36, 0.08);
        box-shadow: 0 0 0 3px rgba(251, 191, 36, .15);
      }
      .role-card .emoji { font-size: 24px; display: block; margin-bottom: 6px; }
      .role-card .label { font-weight: 700; font-size: 15px; display: block; }
      .role-card .sub { color: #94a3b8; font-size: 12px; display: block; margin-top: 4px; }
    </style>
  </head>
  <body>
    <main class="wrap">
      <a class="back" href="/">← Kembali</a>
      <div class="card">
        <span class="eyebrow">Sign up</span>
        <h1>Daftar di {APP_NAME}</h1>
        <p>Gratis untuk brand &amp; cafe. Masukin nomor HP, pilih peran, jadi.</p>

        <div id="err" class="err" style="display:none"></div>
        <div id="info" class="info" style="display:none"></div>

        <form id="otp-form">
          <label>
            <span class="lbl">Nomor HP (format +62)</span>
            <input
              id="phone"
              name="phone"
              type="tel"
              inputmode="tel"
              autocomplete="tel"
              placeholder="+628****7890"
              required
              pattern="^\+[1-9]\d{7,14}$"
            />
          </label>
          <button class="btn btn-primary" type="submit" id="send-btn">Kirim OTP via WhatsApp</button>
          <p class="small" style="margin-top:16px">
            Sudah punya akun? <a href="/login">Masuk di sini</a>.
          </p>
        </form>

        <div id="step2" class="step2">
          <span class="eyebrow">Step 2 of 2</span>
          <h2>Verifikasi &amp; lengkapi profil</h2>
          <p class="small">OTP dikirim ke <span id="otp-phone" class="muted"></span>. Berlaku 5 menit.</p>
          <div id="dev-code" class="dev-code" style="display:none"></div>

          <form id="verify-form">
            <label>
              <span class="lbl">6-digit kode OTP</span>
              <input id="code" name="code" type="text" inputmode="numeric" autocomplete="one-time-code"
                     pattern="\d{6}" maxlength="6" placeholder="123456" required />
            </label>

            <label>
              <span class="lbl">Nama kamu</span>
              <input id="name" name="name" type="text" minlength="2" maxlength="80"
                     placeholder="Contoh: Hanniel Salim" required />
            </label>

            <div class="lbl" style="margin-bottom:8px">Daftar sebagai:</div>
            <div class="role-grid">
              <button type="button" class="role-card" data-role="BRAND">
                <span class="emoji">🏷️</span>
                <span class="label">Brand owner</span>
                <span class="sub">Punya produk, mau titip di banyak cafe.</span>
              </button>
              <button type="button" class="role-card" data-role="TENANT">
                <span class="emoji">☕</span>
                <span class="label">Cafe / tenant PIC</span>
                <span class="sub">Punya cafe, mau jual produk brand.</span>
              </button>
            </div>
            <input type="hidden" id="role" name="role" value="" />

            <button class="btn btn-primary" type="submit" id="verify-btn" disabled>Verifikasi &amp; daftar</button>
            <button class="btn btn-ghost" type="button" id="resend" style="margin-top:8px">Kirim ulang OTP</button>
          </form>
        </div>
      </div>
    </main>

    <script define:vars={{ API_BASE_URL }}>
      const API = API_BASE_URL.replace(/\/$/, "");
      const $ = (s) => document.querySelector(s);
      const err = $("#err"), info = $("#info");
      const showErr = (m) => { err.textContent = m; err.style.display = "block"; info.style.display = "none"; };
      const showInfo = (m) => { info.textContent = m; info.style.display = "block"; err.style.display = "none"; };
      const hideMsg = () => { err.style.display = "none"; info.style.display = "none"; };

      let lastPhone = "";
      let chosenRole = "";

      // Role card selection
      document.querySelectorAll(".role-card").forEach((card) => {
        card.addEventListener("click", () => {
          document.querySelectorAll(".role-card").forEach((c) => c.classList.remove("selected"));
          card.classList.add("selected");
          chosenRole = card.getAttribute("data-role");
          $("#role").value = chosenRole;
          // Re-evaluate verify button
          const code = $("#code").value.trim();
          const name = $("#name").value.trim();
          $("#verify-btn").disabled = !(chosenRole && /^\d{6}$/.test(code) && name.length >= 2);
        });
      });

      // Verify button enable/disable
      function recheckVerify() {
        const code = $("#code").value.trim();
        const name = $("#name").value.trim();
        const ok = chosenRole && /^\d{6}$/.test(code) && name.length >= 2;
        $("#verify-btn").disabled = !ok;
      }
      ["#code", "#name"].forEach((sel) => {
        const el = $(sel);
        el && el.addEventListener("input", recheckVerify);
      });

      $("#otp-form").addEventListener("submit", async (e) => {
        e.preventDefault();
        hideMsg();
        const phone = $("#phone").value.trim();
        if (!/^\+[1-9]\d{7,14}$/.test(phone)) { showErr("Nomor harus format +62xxx (E.164)."); return; }
        const btn = $("#send-btn"); btn.disabled = true; btn.textContent = "Mengirim…";
        try {
          const res = await fetch(`${API}/v1/auth/otp/request`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ phone, purpose: "LOGIN" }),
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok || !json.ok) {
            const code = json?.error?.code;
            if (code === "OTP_RATE_LIMITED") showErr("Kebanyakan percobaan. Coba lagi ~1 jam.");
            else showErr("Gagal kirim OTP. Coba lagi.");
            return;
          }
          lastPhone = phone;
          try { localStorage.setItem("kongsian_register_phone", phone); } catch {}
          $("#otp-phone").textContent = phone;
          $("#step2").classList.add("show");
          $("#otp-form").style.display = "none";
          if (json.data?.devCode) {
            $("#dev-code").textContent = json.data.devCode;
            $("#dev-code").style.display = "block";
            $("#code").value = json.data.devCode;
            showInfo("Dev mode: kode OTP sudah diisi otomatis. Pilih peran lalu klik daftar.");
          } else {
            showInfo("OTP dikirim. Cek WhatsApp kamu.");
          }
          recheckVerify();
        } catch (e) {
          showErr("Tidak bisa konek ke server. Coba lagi.");
        } finally {
          btn.disabled = false; btn.textContent = "Kirim OTP via WhatsApp";
        }
      });

      $("#verify-form").addEventListener("submit", async (e) => {
        e.preventDefault();
        hideMsg();
        const code = $("#code").value.trim();
        const name = $("#name").value.trim();
        if (!/^\d{6}$/.test(code)) { showErr("Kode harus 6 digit angka."); return; }
        if (name.length < 2) { showErr("Nama minimal 2 karakter."); return; }
        if (!chosenRole) { showErr("Pilih peran: Brand atau Cafe."); return; }
        const btn = $("#verify-btn"); btn.disabled = true; btn.textContent = "Memverifikasi…";
        try {
          const res = await fetch(`${API}/v1/auth/otp/verify`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ phone: lastPhone, code, purpose: "LOGIN", name, role: chosenRole }),
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok || !json.ok) {
            const c = json?.error?.code;
            if (c === "OTP_INVALID") showErr("Kode salah. Coba lagi.");
            else if (c === "OTP_EXPIRED") showErr("Kode sudah kadaluarsa. Kirim ulang.");
            else if (c === "OTP_TOO_MANY_ATTEMPTS") showErr("Terlalu banyak percobaan. Kirim OTP baru.");
            else if (c === "REGISTRATION_REQUIRED") showErr("Nama + peran wajib untuk pendaftaran pertama.");
            else showErr("Verifikasi gagal. Coba lagi.");
            return;
          }
          const token = json.data?.sessionToken;
          const user = json.data?.user;
          if (token) {
            try { localStorage.setItem("kongsian_session", token); } catch {}
            // Route by role
            const vs = user?.verificationStatus;
            const role = chosenRole; // BRAND | TENANT — chosen at registration
            if (vs === "PENDING_VERIFICATION" || vs === "PENDING_VERIFIED") {
              showInfo("Berhasil! Akun kamu menunggu verifikasi admin (~1x24 jam)…");
              setTimeout(() => { window.location.href = "/login?registered=1"; }, 1200);
            } else {
              showInfo("Berhasil! Mengarahkan ke dashboard…");
              setTimeout(() => {
                window.location.href = role === "BRAND" ? "/dashboard/brand" : "/dashboard/tenant";
              }, 400);
            }
          } else {
            showErr("Tidak ada session token. Coba lagi.");
          }
        } catch (e) {
          showErr("Tidak bisa konek ke server. Coba lagi.");
        } finally {
          recheckVerify();
          btn.textContent = "Verifikasi & daftar";
        }
      });

      $("#resend").addEventListener("click", () => {
        $("#otp-form").style.display = "block";
        $("#step2").classList.remove("show");
        $("#verify-form").reset();
        chosenRole = "";
        document.querySelectorAll(".role-card").forEach((c) => c.classList.remove("selected"));
        $("#role").value = "";
        $("#verify-btn").disabled = true;
      });
    </script>
  </body>
</html>
