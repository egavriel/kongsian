---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../../../lib/api";
const title = `SKU — ${APP_NAME}`;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style is:global>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: radial-gradient(circle at top, #0b1220 0%, #030712 100%);
        background-attachment: fixed;
        color: #f1f5f9;
        font-family: 'Plus Jakarta Sans', ui-sans-serif, system-ui, -apple-system, sans-serif;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }
      a { color: #38bdf8; text-decoration: none; transition: color 0.15s ease; }
      a:hover { color: #7dd3fc; }
      
      .shell { max-width: 480px; margin: 0 auto; padding: 0 0 100px; }
      
      header.top {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; border-bottom: 2px solid #1e293b;
        position: sticky; top: 0; background: rgba(3, 7, 18, 0.85);
        backdrop-filter: blur(20px); z-index: 50;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
      }
      .brand-name { font-weight: 900; font-size: 16px; color: #f8fafc; letter-spacing: -0.02em; }
      .role-tag { font-size: 10px; padding: 3px 8px; border-radius: 999px; background: rgba(168, 85, 247, 0.1); color: #a855f7; border: 1.5px solid rgba(168, 85, 247, 0.2); font-weight: 800; letter-spacing: 0.06em; }
      .back { color: #94a3b8; font-size: 14px; font-weight: 700; display: inline-flex; align-items: center; gap: 4px; }
      .back:hover { color: #fbbf24; }
      
      main { padding: 20px; }
      
      /* Quest Header Panel */
      .quest-header-panel {
        background: linear-gradient(135deg, rgba(30, 41, 59, 0.7) 0%, rgba(15, 23, 42, 0.85) 100%);
        border: 2.5px solid #1e293b;
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 24px;
        box-shadow: 4px 4px 0px 0px #020617;
      }
      .quest-header-layout {
        display: flex;
        gap: 12px;
        align-items: center;
      }
      .quest-tracker-icon {
        font-size: 28px;
        background: rgba(168, 85, 247, 0.1);
        border: 2px solid rgba(168, 85, 247, 0.2);
        width: 54px;
        height: 54px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .quest-tracker-info {
        flex: 1;
      }
      .quest-tracker-title {
        font-size: 10px;
        font-weight: 800;
        color: #a855f7;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .quest-tracker-subtitle {
        font-size: 16px;
        font-weight: 800;
        color: #ffffff;
      }
      
      /* Neobrutalist RPG Card */
      .rpg-card {
        background: #0f172a;
        border: 2.5px solid #1e293b;
        border-radius: 16px;
        box-shadow: 4px 4px 0px 0px #020617;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
      }
      .rpg-card:hover {
        transform: translate(-1px, -1px);
        box-shadow: 5px 5px 0px 0px #020617;
        border-color: #334155;
      }
      
      .add-card {
        padding: 20px;
        margin-bottom: 28px;
      }
      .add-card h2 {
        margin: 0 0 16px;
        font-size: 16px;
        color: #fbbf24;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      
      label { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; font-size: 11px; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; }
      
      input, select {
        background: #090d16;
        border: 2px solid #1e293b;
        color: #f1f5f9;
        padding: 12px;
        border-radius: 12px;
        font-size: 15px;
        font-family: inherit;
        font-weight: 600;
        width: 100%;
        min-height: 48px;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
      }
      input:focus, select:focus {
        outline: none;
        border-color: #fbbf24;
        box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.15);
      }
      
      .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
      
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 20px;
        border-radius: 12px;
        font-weight: 800;
        border: 2.5px solid transparent;
        cursor: pointer;
        font-size: 15px;
        min-height: 48px;
        transition: all 0.15s ease;
        text-transform: uppercase;
        letter-spacing: 0.02em;
      }
      .btn-primary {
        background: #fbbf24;
        color: #0b1220;
        border-color: #d97706;
        box-shadow: 3px 3px 0px 0px #78350f;
        width: 100%;
      }
      .btn-primary:hover:not(:disabled) {
        background: #f59e0b;
        transform: translate(-1px, -1px);
        box-shadow: 4px 4px 0px 0px #78350f;
      }
      .btn-primary:active:not(:disabled) {
        transform: translate(1px, 1px);
        box-shadow: 2px 2px 0px 0px #78350f;
      }
      .btn-ghost {
        background: transparent;
        color: #f1f5f9;
        border-color: #334155;
        box-shadow: 2px 2px 0px 0px #020617;
      }
      .btn-ghost:hover {
        background: rgba(255,255,255,0.05);
        border-color: #475569;
      }
      .btn-danger {
        background: rgba(244, 63, 94, 0.1);
        color: #f43f5e;
        border-color: rgba(244, 63, 94, 0.3);
        box-shadow: 2px 2px 0px 0px #4c0519;
      }
      .btn-danger:hover {
        background: rgba(244, 63, 94, 0.18);
        border-color: #f43f5e;
      }
      .btn-sm {
        padding: 8px 12px;
        font-size: 11px;
        min-height: 32px;
        border-radius: 8px;
      }
      
      /* Section Title */
      .section-title {
        font-size: 11px;
        font-weight: 900;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin: 28px 0 12px;
      }
      
      /* Inventory List */
      /* Responsive columns on mobile */
      @media (max-width: 480px) {
        .row2 {
          grid-template-columns: 1fr !important;
          gap: 12px;
        }
      }

      /* Live Forging Preview Box */
      .live-preview-container {
        margin: 16px 0;
        padding: 12px;
        background: rgba(9, 13, 22, 0.6);
        border: 2px dashed #fbbf24;
        border-radius: 12px;
        position: relative;
      }
      .preview-tag {
        position: absolute;
        top: -9px;
        left: 12px;
        background: #fbbf24;
        color: #0b1220;
        font-size: 8px;
        font-weight: 900;
        padding: 1px 6px;
        border-radius: 4px;
        letter-spacing: 0.08em;
      }
      @keyframes forgeGlow {
        0% { box-shadow: 0 0 5px rgba(251, 191, 36, 0.15); }
        50% { box-shadow: 0 0 15px rgba(251, 191, 36, 0.4); }
        100% { box-shadow: 0 0 5px rgba(251, 191, 36, 0.15); }
      }
      .preview-card-glow {
        animation: forgeGlow 2s infinite ease-in-out;
        border-color: rgba(251, 191, 36, 0.4) !important;
      }

      /* Inventory List */
      .sku-list { display: flex; flex-direction: column; gap: 12px; }
      .sku-row {
        background: #0f172a;
        border: 2.5px solid #1e293b;
        border-radius: 16px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        box-shadow: 3px 3px 0px 0px #020617;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .sku-row:hover {
        transform: translate(-1px, -1px);
        box-shadow: 4px 4px 0px 0px #020617;
        border-color: #334155;
      }
      .sku-row.inactive { opacity: 0.4; }
      
      .sku-main-info {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
      }
      
      .sku-code {
        font-weight: 900;
        color: #fbbf24;
        font-size: 18px;
        width: 44px;
        height: 44px;
        background: rgba(251, 191, 36, 0.08);
        border: 2px solid rgba(251, 191, 36, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .sku-info { flex: 1; }
      .sku-name { font-weight: 800; font-size: 15px; color: #f8fafc; margin-bottom: 2px; }
      .sku-meta { font-size: 11px; color: #94a3b8; font-weight: 700; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
      .sku-actions {
        display: flex;
        gap: 8px;
        width: 100%;
        border-top: 1.5px solid #1e293b;
        padding-top: 12px;
        margin-top: 4px;
      }
      .sku-actions .btn {
        flex: 1;
        justify-content: center;
        min-height: 38px;
      }
      
      .rarity-badge {
        font-size: 9px;
        font-weight: 900;
        padding: 2px 6px;
        border-radius: 4px;
        letter-spacing: 0.04em;
        display: inline-block;
        border: 1px solid transparent;
      }
      
      .dot-separator { color: #475569; }
      
      .empty {
        background: rgba(15, 23, 42, 0.45);
        border: 2.5px dashed #1e293b;
        border-radius: 16px;
        padding: 32px 20px;
        text-align: center;
        color: #94a3b8;
        font-weight: 700;
      }
      
      .err { background: rgba(244, 63, 94, 0.1); color: #f43f5e; border: 2px solid rgba(244, 63, 94, 0.2); padding: 12px; border-radius: 12px; font-size: 13px; font-weight: 700; margin-bottom: 16px; }
      .ok { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 2px solid rgba(16, 185, 129, 0.2); padding: 12px; border-radius: 12px; font-size: 13px; font-weight: 700; margin-bottom: 16px; }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="top">
        <a class="back" href="/dashboard/brand">← Brand Dashboard</a>
        <h1 class="brand-name">Kelola SKU</h1>
        <span class="role-tag">ARSENAL</span>
      </header>
      <main>
        <div class="quest-header-panel">
          <div class="quest-header-layout">
            <div class="quest-tracker-icon">🛠️</div>
            <div class="quest-tracker-info">
              <div class="quest-tracker-title">Item Smithy</div>
              <div class="quest-tracker-subtitle">Forge & Upgrade SKU</div>
            </div>
          </div>
        </div>

        <div class="rpg-card add-card">
          <h2>🛠️ Forge New Artifact</h2>
          <div id="err" class="err" style="display:none"></div>
          <div id="ok" class="ok" style="display:none"></div>
          <form id="add-form">
            <div class="row2">
              <label>
                <span class="lbl">Item Code</span>
                <input id="code" name="code" maxlength="8" placeholder="A" required />
              </label>
              <label>
                <span class="lbl">Cost (Rp)</span>
                <input id="price" name="price" type="number" min="100" step="100" placeholder="42000" required />
              </label>
            </div>
            <label>
              <span class="lbl">Artifact Name</span>
              <input id="name" name="name" maxlength="60" placeholder="Double Choco" required />
            </label>
            <label>
              <span class="lbl">Shelf Life (Days)</span>
              <input id="shelf" name="shelf" type="number" min="1" max="365" value="7" required />
            </label>

            <!-- Live Preview Widget -->
            <div class="live-preview-container" id="live-preview-box">
              <span class="preview-tag">LIVE FORGE PREVIEW</span>
              <div class="sku-row preview-card-glow" style="margin: 0;">
                <div class="sku-main-info">
                  <div class="sku-code" id="preview-code">A</div>
                  <div class="sku-info">
                    <div class="sku-name" id="preview-name">Double Choco</div>
                    <div class="sku-meta">
                      <span class="rarity-badge" id="preview-rarity" style="color:#94a3b8; background:rgba(148,163,184,0.1); border-color:rgba(148,163,184,0.3)">COMMON</span>
                      <span class="dot-separator">·</span>
                      <span id="preview-price">🪙 Rp 0</span>
                      <span class="dot-separator">·</span>
                      <span id="preview-shelf">⏳ 7 hari</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <button class="btn btn-primary" type="submit">Forge SKU</button>
          </form>
        </div>

        <div class="section-title">📦 Inventory Arsenal</div>
        <div class="sku-list" id="list">
          <div class="empty">Memuat…</div>
        </div>
      </main>
    </div>
    <script define:vars={{ API_BASE_URL }}>
      const API = API_BASE_URL.replace(/\/$/, "");
      const tok = localStorage.getItem("kongsian_session");
      if (!tok) { window.location.href = "/login"; }
      const authH = { Authorization: `Bearer ${tok}`, "Content-Type": "application/json" };
      async function jget(p) { return (await fetch(API+p, { headers: authH })).json().catch(()=>({})); }
      async function jpost(p,b) { return (await fetch(API+p, { method:"POST", headers:authH, body:JSON.stringify(b) })).json().catch(()=>({})); }
      async function jpatch(p,b) { return (await fetch(API+p, { method:"PATCH", headers:authH, body:JSON.stringify(b) })).json().catch(()=>({})); }
      async function jdel(p) { return (await fetch(API+p, { method:"DELETE", headers:authH })).json().catch(()=>({})); }

      const errEl = document.getElementById("err");
      const okEl = document.getElementById("ok");
      const showErr = m => { errEl.textContent = m; errEl.style.display="block"; okEl.style.display="none"; };
      const showOk = m => { okEl.textContent = m; okEl.style.display="block"; errEl.style.display="none"; };

      function fmtRp(n) { return new Intl.NumberFormat("id-ID", { style:"currency", currency:"IDR", maximumFractionDigits:0 }).format(n); }

      function getRarity(price) {
        if (price >= 40000) return { name: "LEGENDARY", color: "#fbbf24", bg: "rgba(251,191,36,0.1)", border: "rgba(251,191,36,0.3)" };
        if (price >= 25000) return { name: "EPIC", color: "#c084fc", bg: "rgba(192,132,252,0.1)", border: "rgba(192,132,252,0.3)" };
        if (price >= 15000) return { name: "RARE", color: "#60a5fa", bg: "rgba(96,165,250,0.1)", border: "rgba(96,165,250,0.3)" };
        return { name: "COMMON", color: "#94a3b8", bg: "rgba(148,163,184,0.1)", border: "rgba(148,163,184,0.3)" };
      }

      async function load() {
        const me = await jget("/v1/brands/me");
        if (!me.ok || !me.data.brandId) { window.location.href = "/dashboard/brand"; return; }
        const brandId = me.data.brandId;
        const r = await jget(`/v1/skus?brandId=${brandId}`);
        const list = document.getElementById("list");
        if (!r.ok || !r.data) {
          list.innerHTML = `<div class="empty">Gagal memuat SKU.</div>`;
          return;
        }
        if (r.data.length === 0) {
          list.innerHTML = `<div class="empty">Belum ada SKU. Tambah di atas.</div>`;
          return;
        }
        list.innerHTML = r.data.map(s => {
          const rarity = getRarity(s.priceIdr);
          return `
            <div class="sku-row ${s.active ? "" : "inactive"}">
              <div class="sku-main-info">
                <div class="sku-code">${s.code}</div>
                <div class="sku-info">
                  <div class="sku-name">${s.name}</div>
                  <div class="sku-meta">
                    <span class="rarity-badge" style="color:${rarity.color}; background:${rarity.bg}; border-color:${rarity.border}">${rarity.name}</span>
                    <span class="dot-separator">·</span>
                    <span>🪙 ${fmtRp(s.priceIdr)}</span>
                    <span class="dot-separator">·</span>
                    <span>⏳ ${s.masaSimpanHari} hari</span>
                    ${s.active ? "" : `<span class="dot-separator">·</span><span style="color:#f43f5e">nonaktif</span>`}
                  </div>
                </div>
              </div>
              <div class="sku-actions">
                <button class="btn btn-ghost btn-sm" data-act="price" data-id="${s.id}" data-price="${s.priceIdr}">Upgrade</button>
                <button class="btn btn-danger btn-sm" data-act="del" data-id="${s.id}" data-name="${s.name}">Scrap</button>
              </div>
            </div>
          `;
        }).join("");
        // Bind actions
        list.querySelectorAll("button[data-act]").forEach(btn => {
          btn.addEventListener("click", async () => {
            const id = btn.dataset.id;
            if (btn.dataset.act === "del") {
              if (!confirm(`Hapus SKU "${btn.dataset.name}"?`)) return;
              const r = await jdel(`/v1/skus/${id}`);
              if (!r.ok) showErr("Gagal hapus: " + (r.error?.code || "?"));
              else { showOk("SKU dinonaktifkan."); load(); }
            } else if (btn.dataset.act === "price") {
              const v = prompt(`Harga baru untuk SKU (Rp):`, btn.dataset.price);
              if (!v) return;
              const n = parseInt(v, 10);
              if (!n || n < 100) { showErr("Harga tidak valid."); return; }
              const r = await jpatch(`/v1/skus/${id}`, { priceIdr: n });
              if (!r.ok) showErr("Gagal update: " + (r.error?.code || "?"));
              else { showOk("Harga diupdate."); load(); }
            }
          });
        });
      }

      document.getElementById("add-form").addEventListener("submit", async (e) => {
        e.preventDefault();
        errEl.style.display = "none"; okEl.style.display = "none";
        const code = document.getElementById("code").value.trim();
        const name = document.getElementById("name").value.trim();
        const price = parseInt(document.getElementById("price").value, 10);
        const shelf = parseInt(document.getElementById("shelf").value, 10);
        if (!code || !name || !price) { showErr("Kode, nama, harga wajib."); return; }
        const me = await jget("/v1/brands/me");
        const r = await jpost("/v1/skus", { brandId: me.data.brandId, code, name, priceIdr: price, masaSimpanHari: shelf });
        if (!r.ok) { showErr("Gagal: " + (r.error?.code || "?")); return; }
        showOk(r.data?.alreadyExists ? "SKU sudah ada." : "SKU ditambah.");
        document.getElementById("add-form").reset();
        document.getElementById("shelf").value = "7";
        load();
      });

      // ---- Live Forge Preview Synchronization ----
      const codeIn = document.getElementById("code");
      const nameIn = document.getElementById("name");
      const priceIn = document.getElementById("price");
      const shelfIn = document.getElementById("shelf");

      const prevCode = document.getElementById("preview-code");
      const prevName = document.getElementById("preview-name");
      const prevPrice = document.getElementById("preview-price");
      const prevShelf = document.getElementById("preview-shelf");
      const prevRarity = document.getElementById("preview-rarity");

      function updatePreview() {
        const code = codeIn.value.trim().toUpperCase() || "A";
        const name = nameIn.value.trim() || "Double Choco";
        const price = parseInt(priceIn.value, 10) || 0;
        const shelf = parseInt(shelfIn.value, 10) || 7;

        prevCode.textContent = code.slice(0, 8);
        prevName.textContent = name;
        prevPrice.textContent = `🪙 ${fmtRp(price)}`;
        prevShelf.textContent = `⏳ ${shelf} hari`;

        const rarity = getRarity(price);
        prevRarity.textContent = rarity.name;
        prevRarity.style.color = rarity.color;
        prevRarity.style.background = rarity.bg;
        prevRarity.style.borderColor = rarity.border;
      }

      codeIn.addEventListener("input", updatePreview);
      nameIn.addEventListener("input", updatePreview);
      priceIn.addEventListener("input", updatePreview);
      shelfIn.addEventListener("input", updatePreview);

      // Trigger initial preview setup
      updatePreview();

      load();
      
      // Reset preview on form reset
      const originalReset = document.getElementById("add-form").reset;
      document.getElementById("add-form").addEventListener("reset", () => {
        setTimeout(updatePreview, 50);
      });
    </script>
  </body>
</html>
