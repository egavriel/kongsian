---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../../../lib/api";
const title = `SKU — ${APP_NAME}`;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body { margin:0; background:#0b1220; color:#f1f5f9; font-family:ui-sans-serif,system-ui,-apple-system,sans-serif; line-height:1.5; }
      a { color:#38bdf8; text-decoration:none; }
      .shell { max-width:480px; margin:0 auto; padding:0 0 80px; }
      header.top { display:flex; align-items:center; justify-content:space-between; padding:16px 20px; border-bottom:1px solid #1e293b; position:sticky; top:0; background:rgba(11,18,32,.92); backdrop-filter:blur(6px); z-index:5; }
      .back { color:#94a3b8; font-size:14px; }
      h1 { font-size:20px; margin:0; }
      main { padding:20px; }
      .add-card { background:#0f172a; border:1px solid #1e293b; border-radius:12px; padding:16px; margin-bottom:20px; }
      .add-card h2 { margin:0 0 12px; font-size:15px; color:#fbbf24; }
      label { display:flex; flex-direction:column; gap:6px; margin-bottom:12px; font-size:13px; }
      .lbl { font-weight:600; }
      input, select {
        background:#0b1220; border:1px solid #1e293b; color:#f1f5f9;
        padding:12px; border-radius:10px; font-size:15px; font-family:inherit; width:100%;
      }
      input:focus, select:focus { outline:none; border-color:#fbbf24; }
      .row2 { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
      .btn { display:inline-flex; align-items:center; justify-content:center; gap:8px; padding:12px 16px; border-radius:10px; font-weight:600; border:1px solid transparent; cursor:pointer; font-size:14px; }
      .btn-primary { background:#fbbf24; color:#0b1220; }
      .btn-primary:hover { background:#f59e0b; }
      .btn-ghost { background:transparent; color:#f1f5f9; border-color:#1e293b; }
      .btn-danger { background:rgba(251,113,133,.15); color:#fb7185; border-color:rgba(251,113,133,.3); }
      .btn-sm { padding:6px 10px; font-size:12px; }
      .sku-list { display:flex; flex-direction:column; gap:8px; }
      .sku-row { background:#0f172a; border:1px solid #1e293b; border-radius:12px; padding:14px; display:flex; justify-content:space-between; align-items:center; gap:10px; }
      .sku-row.inactive { opacity:.5; }
      .sku-code { font-weight:700; color:#fbbf24; font-size:18px; min-width:36px; }
      .sku-info { flex:1; }
      .sku-name { font-weight:600; }
      .sku-meta { font-size:12px; color:#94a3b8; }
      .sku-actions { display:flex; gap:6px; }
      .empty { background:#0f172a; border:1px dashed #1e293b; border-radius:12px; padding:24px; text-align:center; color:#94a3b8; }
      .err { background:rgba(251,113,133,.12); color:#fb7185; border:1px solid rgba(251,113,133,.3); padding:10px 12px; border-radius:10px; font-size:13px; margin-bottom:12px; }
      .ok { background:rgba(52,211,153,.12); color:#34d399; border:1px solid rgba(52,211,153,.3); padding:10px 12px; border-radius:10px; font-size:13px; margin-bottom:12px; }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="top">
        <a class="back" href="/dashboard/brand">← Brand</a>
        <h1>SKU</h1>
        <span></span>
      </header>
      <main>
        <div class="add-card">
          <h2>Tambah SKU</h2>
          <div id="err" class="err" style="display:none"></div>
          <div id="ok" class="ok" style="display:none"></div>
          <form id="add-form">
            <div class="row2">
              <label>
                <span class="lbl">Kode</span>
                <input id="code" name="code" maxlength="8" placeholder="A" required />
              </label>
              <label>
                <span class="lbl">Harga (Rp)</span>
                <input id="price" name="price" type="number" min="100" step="100" placeholder="42000" required />
              </label>
            </div>
            <label>
              <span class="lbl">Nama</span>
              <input id="name" name="name" maxlength="60" placeholder="Double Choco" required />
            </label>
            <label>
              <span class="lbl">Masa simpan (hari)</span>
              <input id="shelf" name="shelf" type="number" min="1" max="365" value="7" required />
            </label>
            <button class="btn btn-primary" type="submit" style="width:100%">+ Tambah SKU</button>
          </form>
        </div>

        <div class="sku-list" id="list">
          <div class="empty">Memuat…</div>
        </div>
      </main>
    </div>
    <script define:vars={{ API_BASE_URL }}>
      const API = API_BASE_URL.replace(/\/$/, "");
      const tok = localStorage.getItem("kongsian_session");
      if (!tok) { window.location.href = "/login"; }
      const authH = { Authorization: `Bearer ${tok}`, "Content-Type": "application/json" };
      async function jget(p) { return (await fetch(API+p, { headers: authH })).json().catch(()=>({})); }
      async function jpost(p,b) { return (await fetch(API+p, { method:"POST", headers:authH, body:JSON.stringify(b) })).json().catch(()=>({})); }
      async function jpatch(p,b) { return (await fetch(API+p, { method:"PATCH", headers:authH, body:JSON.stringify(b) })).json().catch(()=>({})); }
      async function jdel(p) { return (await fetch(API+p, { method:"DELETE", headers:authH })).json().catch(()=>({})); }

      const errEl = document.getElementById("err");
      const okEl = document.getElementById("ok");
      const showErr = m => { errEl.textContent = m; errEl.style.display="block"; okEl.style.display="none"; };
      const showOk = m => { okEl.textContent = m; okEl.style.display="block"; errEl.style.display="none"; };

      function fmtRp(n) { return new Intl.NumberFormat("id-ID", { style:"currency", currency:"IDR", maximumFractionDigits:0 }).format(n); }

      async function load() {
        const me = await jget("/v1/brands/me");
        if (!me.ok || !me.data.brandId) { window.location.href = "/dashboard/brand"; return; }
        const brandId = me.data.brandId;
        const r = await jget(`/v1/skus?brandId=${brandId}`);
        const list = document.getElementById("list");
        if (!r.ok || !r.data) {
          list.innerHTML = `<div class="empty">Gagal memuat SKU.</div>`;
          return;
        }
        if (r.data.length === 0) {
          list.innerHTML = `<div class="empty">Belum ada SKU. Tambah di atas.</div>`;
          return;
        }
        list.innerHTML = r.data.map(s => `
          <div class="sku-row ${s.active ? "" : "inactive"}">
            <div class="sku-code">${s.code}</div>
            <div class="sku-info">
              <div class="sku-name">${s.name}</div>
              <div class="sku-meta">${fmtRp(s.priceIdr)} · ${s.masaSimpanHari} hari${s.active ? "" : " · nonaktif"}</div>
            </div>
            <div class="sku-actions">
              <button class="btn btn-ghost btn-sm" data-act="price" data-id="${s.id}" data-price="${s.priceIdr}">Harga</button>
              <button class="btn btn-danger btn-sm" data-act="del" data-id="${s.id}" data-name="${s.name}">Hapus</button>
            </div>
          </div>
        `).join("");
        // Bind actions
        list.querySelectorAll("button[data-act]").forEach(btn => {
          btn.addEventListener("click", async () => {
            const id = btn.dataset.id;
            if (btn.dataset.act === "del") {
              if (!confirm(`Hapus SKU "${btn.dataset.name}"?`)) return;
              const r = await jdel(`/v1/skus/${id}`);
              if (!r.ok) showErr("Gagal hapus: " + (r.error?.code || "?"));
              else { showOk("SKU dinonaktifkan."); load(); }
            } else if (btn.dataset.act === "price") {
              const v = prompt(`Harga baru untuk SKU (Rp):`, btn.dataset.price);
              if (!v) return;
              const n = parseInt(v, 10);
              if (!n || n < 100) { showErr("Harga tidak valid."); return; }
              const r = await jpatch(`/v1/skus/${id}`, { priceIdr: n });
              if (!r.ok) showErr("Gagal update: " + (r.error?.code || "?"));
              else { showOk("Harga diupdate."); load(); }
            }
          });
        });
      }

      document.getElementById("add-form").addEventListener("submit", async (e) => {
        e.preventDefault();
        errEl.style.display = "none"; okEl.style.display = "none";
        const code = document.getElementById("code").value.trim();
        const name = document.getElementById("name").value.trim();
        const price = parseInt(document.getElementById("price").value, 10);
        const shelf = parseInt(document.getElementById("shelf").value, 10);
        if (!code || !name || !price) { showErr("Kode, nama, harga wajib."); return; }
        const me = await jget("/v1/brands/me");
        const r = await jpost("/v1/skus", { brandId: me.data.brandId, code, name, priceIdr: price, masaSimpanHari: shelf });
        if (!r.ok) { showErr("Gagal: " + (r.error?.code || "?")); return; }
        showOk(r.data?.alreadyExists ? "SKU sudah ada." : "SKU ditambah.");
        document.getElementById("add-form").reset();
        document.getElementById("shelf").value = "7";
        load();
      });

      load();
    </script>
  </body>
</html>
