---
/**
 * Brand Analytics — Week 4, F3.
 *
 * URL state: ?range=7d|30d&tenantId=<id?>
 *   - Tab is implicit (= range). Persists in URL so a deep-link is
 *     shareable.
 *   - Tenant dropdown narrows the query.
 *
 * Renders:
 *   - 4 summary cards: Total Revenue, Total Units, Closings, Disputes
 *   - Top 5 SKU table
 *   - Per-tenant breakdown cards (qty + revenue + closing/settle count)
 *   - ASCII bar chart of daily revenue (0-filled, TZ-safe)
 *   - "Download CSV" button → /v1/analytics/overview?range=...&format=csv
 *
 * Empty state: if totalUnits === 0, hide chart + table, show a
 * "Belum ada closing di rentang ini" card.
 */
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../../../lib/api";
import NotificationBell from "../../../components/NotificationBell.astro";
import "../../../styles/global.css";
const title = `Analytics — ${APP_NAME}`;
---
<!doctype html>
<html lang="id" data-role="brand">
  <head>
    <script src="/i18n-helper.js" is:inline></script>
    <script src="/theme-helper.js" is:inline></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style is:global>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: radial-gradient(circle at top, #0b1220 0%, #030712 100%);
        background-attachment: fixed;
        color: #f1f5f9;
        font-family: 'Plus Jakarta Sans', ui-sans-serif, system-ui, -apple-system, sans-serif;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }
      a { color: #38bdf8; text-decoration: none; transition: color 0.15s ease; }
      a:hover { color: #7dd3fc; }
      
      .shell { max-width: 720px; margin: 0 auto; padding: 0 0 100px; }
      
      header.top {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; border-bottom: 2px solid #1e293b;
        position: sticky; top: 0; background: rgba(3, 7, 18, 0.85);
        backdrop-filter: blur(20px); z-index: 50;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
      }
      .brand-name { font-weight: 900; font-size: 16px; color: #f8fafc; letter-spacing: -0.02em; }
      .role-tag { font-size: 10px; padding: 3px 8px; border-radius: 999px; background: rgba(168, 85, 247, 0.1); color: #a855f7; border: 1.5px solid rgba(168, 85, 247, 0.2); font-weight: 800; letter-spacing: 0.06em; }
      
      main { padding: 20px; }
      
      .greet { font-size: 11px; font-weight: 800; color: #fbbf24; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 4px; }
      h1 { font-size: 26px; margin: 0 0 6px; font-weight: 900; letter-spacing: -0.02em; }
      .sub-h1 { font-size: 13px; color: #94a3b8; margin: 0 0 24px; font-weight: 600; }
      
      /* Neobrutalist RPG Card */
      .rpg-card {
        background: #0f172a;
        border: 2.5px solid #1e293b;
        border-radius: 16px;
        box-shadow: 4px 4px 0px 0px #020617;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
      }
      .rpg-card:hover {
        transform: translate(-1px, -1px);
        box-shadow: 5px 5px 0px 0px #020617;
        border-color: #334155;
      }

      /* Tabs */
      .tabs {
        display: flex;
        gap: 8px;
        background: rgba(15, 23, 42, 0.45);
        border: 2.5px solid #1e293b;
        border-radius: 14px;
        padding: 4px;
        margin-bottom: 20px;
      }
      .tab {
        flex: 1;
        padding: 10px 12px;
        text-align: center;
        font-size: 13px;
        font-weight: 800;
        border-radius: 10px;
        color: #94a3b8;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
      }
      .tab:hover {
        color: #f1f5f9;
        background: rgba(255, 255, 255, 0.03);
        text-decoration: none;
      }
      .tab.active {
        background: #fbbf24;
        color: #0b1220;
        box-shadow: 2px 2px 0px 0px #020617;
      }

      /* Filter row */
      .filter-row {
        display: flex;
        gap: 12px;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
      }
      .filter-row select {
        background: #090d16;
        color: #f1f5f9;
        border: 2.5px solid #1e293b;
        border-radius: 12px;
        padding: 10px 14px;
        font-size: 14px;
        font-weight: 700;
        font-family: inherit;
        flex: 1;
        min-width: 150px;
        transition: all 0.2s ease;
      }
      .filter-row select:focus {
        outline: none;
        border-color: #fbbf24;
        box-shadow: 3px 3px 0px 0px #020617;
      }
      
      .csv-btn {
        background: #fbbf24;
        color: #0b1220;
        border: 2.5px solid #d97706;
        border-radius: 12px;
        padding: 10px 16px;
        font-size: 14px;
        font-weight: 800;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 2px 2px 0px 0px #78350f;
        transition: all 0.15s ease;
        text-transform: uppercase;
        letter-spacing: 0.02em;
      }
      .csv-btn:hover:not(:disabled) {
        background: #f59e0b;
        transform: translate(-1px, -1px);
        box-shadow: 3px 3px 0px 0px #78350f;
      }
      .csv-btn:active:not(:disabled) {
        transform: translate(1px, 1px);
        box-shadow: 1px 1px 0px 0px #78350f;
      }
      .csv-btn:disabled { opacity: 0.5; cursor: not-allowed; }

      /* Summary cards */
      .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px; }
      .stat {
        background: #0f172a;
        border: 2.5px solid #1e293b;
        border-radius: 16px;
        padding: 16px;
        box-shadow: 3px 3px 0px 0px #020617;
        transition: all 0.25s ease;
      }
      .stat:hover {
        transform: translate(-1px, -1px);
        box-shadow: 4px 4px 0px 0px #020617;
        border-color: #334155;
      }
      .stat .lbl {
        font-size: 10px;
        color: #94a3b8;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .stat .val { font-size: 20px; font-weight: 900; color: #ffffff; word-break: break-all; }
      .stat .sub { font-size: 10px; color: #64748b; margin-top: 4px; font-weight: 700; }

      h2 {
        font-size: 11px;
        margin: 28px 0 12px;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 900;
      }

      /* Top SKU table */
      .sku-table {
        background: #0f172a;
        border: 2.5px solid #1e293b;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 3px 3px 0px 0px #020617;
      }
      .sku-row { display: grid; grid-template-columns: 48px 1fr 80px 120px; padding: 12px 16px; align-items: center; font-size: 13px; border-bottom: 2px solid #1e293b; }
      .sku-row:last-child { border-bottom: none; }
      .sku-row.head { background: #1e293b; color: #94a3b8; font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 800; }
      .sku-row .rank { font-weight: 900; color: #fbbf24; }
      .sku-row .qty { text-align: right; color: #94a3b8; }
      .sku-row .rev { text-align: right; font-weight: 800; }

      /* Tenant cards */
      .tenant-list { display: grid; grid-template-columns: 1fr; gap: 12px; }
      @media (min-width: 480px) {
        .tenant-list { grid-template-columns: 1fr 1fr; }
      }
      
      .tenant-card {
        background: #0f172a;
        border: 2.5px solid #1e293b;
        border-radius: 16px;
        padding: 16px;
        box-shadow: 3px 3px 0px 0px #020617;
      }
      .tenant-card .name { font-weight: 900; font-size: 15px; margin-bottom: 12px; }
      .tenant-card .row { display: flex; justify-content: space-between; font-size: 12px; color: #94a3b8; padding: 4px 0; border-bottom: 1px dashed rgba(30,41,59,0.4); }
      .tenant-card .row:last-child { border-bottom: none; }
      .tenant-card .row .v { color: #f1f5f9; font-weight: 700; }

      /* ASCII chart */
      .chart {
        background: #020617;
        border: 2.5px solid #1e293b;
        border-radius: 16px;
        padding: 20px;
        overflow-x: auto;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.8), 3px 3px 0px 0px #020617;
      }
      .chart-row { display: flex; align-items: center; font-size: 13px; padding: 6px 0; border-bottom: 1px solid rgba(30, 41, 59, 0.5); }
      .chart-row:last-child { border-bottom: none; }
      .chart-row .date { width: 60px; color: #94a3b8; font-weight: 800; flex-shrink: 0; }
      .chart-row .bar { color: #fbbf24; text-shadow: 0 0 4px rgba(251, 191, 36, 0.4); letter-spacing: 0.1em; font-weight: 900; }
      .chart-row .val { margin-left: 12px; color: #38bdf8; font-weight: 700; }

      .err { background: rgba(244, 63, 94, 0.1); color: #f43f5e; border: 2px solid rgba(244, 63, 94, 0.2); padding: 12px; border-radius: 12px; font-size: 14px; font-weight: 700; margin-bottom: 16px; }
      .loading { color: #94a3b8; text-align: center; padding: 40px 24px; font-weight: 700; }
      .empty {
        background: rgba(15, 23, 42, 0.45);
        border: 2.5px dashed #1e293b;
        border-radius: 16px;
        padding: 32px 20px;
        text-align: center;
        color: #94a3b8;
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="top">
        <a href="/dashboard/brand" class="back">← <span data-i18n="brand dashboard">Dashboard Brand</span></a>
        <div style="display:flex; gap:10px; align-items:center;">
          <button id="theme-toggle" class="theme-toggle-btn">☕</button>
          <span class="role-tag">ARCHIVES</span>
          <NotificationBell />
        </div>
      </header>
      <main>
        <p class="greet">Kingdom Archives</p>
        <h1>Tren Penjualan</h1>
        <p class="sub-h1" id="range-label">Memuat…</p>
 
        <!-- Tabs (URL state, shareable) -->
        <div class="tabs" id="tabs">
          <a class="tab" data-range="7d" href="?range=7d">7 Hari</a>
          <a class="tab" data-range="30d" href="?range=30d">30 Hari</a>
        </div>

        <!-- Tenant filter + CSV button -->
        <div class="filter-row">
          <select id="tenant-filter">
            <option value="">Semua tenant</option>
          </select>
          <button class="csv-btn" id="csv-btn" type="button"><span>📥</span> Export Scroll</button>
        </div>

        <div id="status" aria-live="polite"></div>
        <div id="content"></div>
      </main>
      <footer class="tagline-footer">
        Built with <a href="https://oatlet.com" target="_blank">Oatlet App</a> — Trusted and proudly used by <a href="https://www.instagram.com/littlehanniel" target="_blank">@littlehanniel</a>
      </footer>
    </div>

    <script src="/kongsian-auth-bus.js" defer is:inline></script>
    <script define:vars={{ API_BASE_URL }}>
      window.__KONGSIAN_API__ = API_BASE_URL;

      // Theme Toggle logic
      const toggleBtn = document.getElementById("theme-toggle");
      if (toggleBtn) {
        const updateThemeBtnText = (theme) => {
          toggleBtn.innerHTML = theme === "playful" ? "🌾" : "☕";
        };
        updateThemeBtnText(window.OatletTheme.getTheme());
        window.addEventListener("oatlet:themechange", (e) => {
          updateThemeBtnText(e.detail.theme);
        });
        toggleBtn.addEventListener("click", () => {
          window.OatletTheme.toggleTheme();
        });
      }

      // -----------------------------------------------------------------------
      // State from URL
      // -----------------------------------------------------------------------
      const params = new URLSearchParams(window.location.search);
      const range = params.get("range") === "30d" ? "30d" : "7d";
      const tenantId = params.get("tenantId") || "";

      // Active tab
      document.querySelectorAll("#tabs .tab").forEach(el => {
        el.classList.toggle("active", el.getAttribute("data-range") === range);
      });

      const tok = localStorage.getItem("kongsian_session");
      const API = API_BASE_URL.replace(/\/$/, "");

      // -----------------------------------------------------------------------
      // Format helpers
      // -----------------------------------------------------------------------
      const fmtIdr = n => "Rp " + (n || 0).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
      const fmtInt = n => (n || 0).toLocaleString("id-ID");

      function formatDateLocalYMD(dateObj) {
        const y = dateObj.getFullYear();
        const m = String(dateObj.getMonth() + 1).padStart(2, "0");
        const d = String(dateObj.getDate()).padStart(2, "0");
        return `${y}-${m}-${d}`;
      }

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, c => ({
          "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#39;"
        }[c]));
      }

      // -----------------------------------------------------------------------
      // API helper (uses global auth bus if loaded)
      // -----------------------------------------------------------------------
      function apiJson(path) {
        if (window.kongsianApi && window.kongsianApi.apiJson) {
          return window.kongsianApi.apiJson(path, { headers: { Authorization: "Bearer " + tok } });
        }
        return fetch(API + path, { headers: { Authorization: "Bearer " + tok } }).then(r => {
          if (r.status === 401) {
            window.dispatchEvent(new CustomEvent("kongsian:unauthorized", { detail: { reason: "api_401" } }));
            const e = new Error("Unauthenticated"); e.code = "UNAUTHENTICATED"; throw e;
          }
          if (!r.ok) {
            return r.json().then(j => { throw new Error(j?.error?.message || "API " + r.status); });
          }
          return r.json();
        });
      }

      // -----------------------------------------------------------------------
      // Render
      // -----------------------------------------------------------------------
      // Render
      // -----------------------------------------------------------------------
      function renderChart(daily) {
        if (!daily || daily.length === 0) return `<div class="empty">${window.t("Belum ada data")}</div>`;
        const maxRev = Math.max(...daily.map(d => d.revenueIdr), 0);
        const BARS = "▁▂▃▄▅▆▇█";
        const ROWS = 40; // max bar width in chars
        return '<div class="chart">' + daily.map(d => {
          // Bar width: proportional to max, 1 char min, 0 if max is 0.
          let bar;
          if (maxRev === 0 || d.revenueIdr === 0) {
            bar = "▁";
          } else {
            const ratio = d.revenueIdr / maxRev;
            const width = Math.max(1, Math.round(ratio * ROWS));
            // Build a "ramp"-style bar: each char represents a level.
            const fullBlocks = Math.min(8, Math.ceil((ratio) * 8));
            bar = BARS[fullBlocks - 1].repeat(Math.max(1, Math.round(width / 5)));
            // Pad to ROWS chars for alignment
            bar = bar.padEnd(ROWS, " ");
          }
          return `<div class="chart-row">
            <span class="date">${d.date.slice(5)}</span>
            <span class="bar">${escapeHtml(bar)}</span>
            <span class="val">${fmtIdr(d.revenueIdr)}</span>
          </div>`;
        }).join("") + '</div>';
      }

      function renderTopProducts(top) {
        if (!top || top.length === 0) return `<div class="empty">${window.t("Belum ada produk terjual")}</div>`;
        const rankEmojis = ["🥇", "🥈", "🥉", "4️⃣", "5️⃣"];
        return '<div class="sku-table rpg-card">' +
          `<div class="sku-row head"><div>${window.t("Rank")}</div><div>${window.t("SKU Name")}</div><div class="qty">${window.t("Units")}</div><div class="rev">${window.t("Revenue")}</div></div>` +
          top.map((p, i) => `<div class="sku-row">
            <div class="rank" style="font-size:16px;">${rankEmojis[i] || (i + 1)}</div>
            <div style="font-weight: 800; color: #f8fafc;">${escapeHtml(p.skuName)} <span style="color:#fbbf24; font-size:10px; font-weight:900; background:rgba(251,191,36,0.08); border:1px solid rgba(251,191,36,0.15); padding:1px 4px; border-radius:4px; margin-left:4px;">${escapeHtml(p.skuCode)}</span></div>
            <div class="qty" style="font-weight: 700; color: #e2e8f0;">${fmtInt(p.qtySold)}</div>
            <div class="rev" style="color: #10b981; font-weight: 800;">${fmtIdr(p.revenueIdr)}</div>
          </div>`).join("") +
          '</div>';
      }

      function renderTenantBreakdown(list) {
        if (!list || list.length === 0) return `<div class="empty">${window.t("Belum ada tenant")}</div>`;
        return '<div class="tenant-list">' + list.map(t => `<div class="tenant-card rpg-card">
          <div class="name" style="font-weight: 900; font-size: 15px; color: #fbbf24; display:flex; align-items:center; gap:8px;">🏰 ${escapeHtml(t.tenantName)}</div>
          <div class="row"><span>📦 <span>${window.t("qty terjual")}</span></span><span class="v" style="color:#f1f5f9;">${fmtInt(t.qtySold)}</span></div>
          <div class="row"><span>🪙 <span>${window.t("revenue share")}</span></span><span class="v" style="color:#10b981;">${fmtIdr(t.revenueIdr)}</span></div>
          <div class="row"><span>📜 <span>${window.t("closing count")}</span></span><span class="v" style="color:#38bdf8;">${fmtInt(t.closingCount)}</span></div>
          <div class="row"><span>🛡️ <span>${window.t("settlements")}</span></span><span class="v" style="color:#a855f7;">${fmtInt(t.settleCount)}</span></div>
        </div>`).join("") + '</div>';
      }

      function render(data) {
        const status = document.getElementById("status");
        const content = document.getElementById("content");
        const rangeLbl = document.getElementById("range-label");

        const { range: r, summary, topProducts, tenantBreakdown, dailySeries } = data;
        rangeLbl.textContent = `${r.start} → ${r.end} (${r.end === formatDateLocalYMD(new Date()) ? window.t("sampai hari ini") : window.t("akhir rentang")})`;

        if (summary.totalUnits === 0) {
          content.innerHTML = `<div class="empty rpg-card">
            <p style="margin:0 0 8px; font-weight: 800; font-size: 16px;">${window.t("Belum ada closing di rentang ini.")}</p>
            <p style="margin:0;font-size:12px; color: #94a3b8;">${window.t("Coba rentang yang lebih panjang, atau tunggu tenant submit closing pertama.")}</p>
          </div>`;
          return;
        }

        // Summary cards
        let html = `<div class="stats">
          <div class="stat rpg-card">
            <div class="lbl"><span>🪙</span> Total Revenue</div>
            <div class="val" style="color:#10b981;">${fmtIdr(summary.totalRevenueIdr)}</div>
            <div class="sub">${window.t("rata-rata")} ${fmtIdr(summary.avgDailyRevenueIdr)} / ${window.t("hari") === "days" ? "day" : "hari"}</div>
          </div>
          <div class="stat rpg-card">
            <div class="lbl"><span>📦</span> Units Sold</div>
            <div class="val" style="color:#38bdf8;">${fmtInt(summary.totalUnits)}</div>
            <div class="sub">${window.t("total items dispatched")}</div>
          </div>
          <div class="stat rpg-card">
            <div class="lbl"><span>📜</span> Closings</div>
            <div class="val" style="color:#fbbf24;">${fmtInt(summary.closingCount)}</div>
            <div class="sub">${window.t("scrolls recorded")}</div>
          </div>
          <div class="stat rpg-card">
            <div class="lbl"><span>⚔️</span> Disputes</div>
            <div class="val" style="color:#f43f5e;">${fmtInt(summary.disputeCount)}</div>
            <div class="sub">${window.t("skirmishes occurred")}</div>
          </div>
        </div>`;

        html += `<h2><span>📊</span> ${window.t("Tren Harian")}</h2>${renderChart(dailySeries)}`;
        html += `<h2><span>🏆</span> ${window.t("Top 5 Produk")}</h2>${renderTopProducts(topProducts)}`;
        html += `<h2><span>🏰</span> ${window.t("Per Tenant")}</h2>${renderTenantBreakdown(tenantBreakdown)}`;

        content.innerHTML = html;
      }

      // -----------------------------------------------------------------------
      // Tenant filter
      // -----------------------------------------------------------------------
      function loadTenants() {
        // Light: fetch the partnerships and extract unique tenants.
        return apiJson("/v1/partnerships?status=ACTIVE&limit=200").then(j => {
          const list = (j?.data?.partnerships || []).map(p => ({
            id: p.tenant?.id || p.tenantId,
            name: p.tenant?.name || "(tanpa nama)",
          }));
          // Dedupe by id
          const seen = new Set();
          const unique = list.filter(t => { if (seen.has(t.id)) return false; seen.add(t.id); return true; });
          const sel = document.getElementById("tenant-filter");
          sel.innerHTML = `<option value="">${window.t("Semua tenant")}</option>` +
            unique.map(t => `<option value="${escapeHtml(t.id)}" ${tenantId === t.id ? "selected" : ""}>${escapeHtml(t.name)}</option>`).join("");
        }).catch(() => { /* non-fatal; filter stays empty */ });
      }

      // -----------------------------------------------------------------------
      // Load + reload
      // -----------------------------------------------------------------------
      async function load() {
        const status = document.getElementById("status");
        const content = document.getElementById("content");
        if (!tok) {
          window.location.href = "/login";
          return;
        }
        status.innerHTML = `<div class="loading">${window.t("Memuat analytics…")}</div>`;
        content.innerHTML = "";
        try {
          const qs = new URLSearchParams({ range });
          if (tenantId) qs.set("tenantId", tenantId);
          const j = await apiJson("/v1/analytics/overview?" + qs.toString());
          if (!j.ok) throw new Error(j?.error?.message || "Gagal");
          status.innerHTML = "";
          render(j.data);
        } catch (e) {
          if (e && e.code === "UNAUTHENTICATED") return;
          status.innerHTML = '<div class="err">' + escapeHtml(e?.message || window.t("Gagal memuat")) + '</div>';
        }
      }

      // Filter change reloads with new ?tenantId=
      document.getElementById("tenant-filter").addEventListener("change", (e) => {
        const newTenantId = e.target.value;
        const q = new URLSearchParams(window.location.search);
        if (newTenantId) q.set("tenantId", newTenantId); else q.delete("tenantId");
        window.location.search = q.toString();
      });

      // CSV button
      document.getElementById("csv-btn").addEventListener("click", async (e) => {
        const btn = e.currentTarget;
        if (btn.disabled) return;
        const orig = btn.textContent;
        btn.disabled = true;
        btn.textContent = window.t("Menyiapkan…");
        try {
          const qs = new URLSearchParams({ range, format: "csv" });
          if (tenantId) qs.set("tenantId", tenantId);
          // Stream the CSV via blob to trigger download with the right filename.
          const url = API + "/v1/analytics/overview?" + qs.toString();
          const res = await fetch(url, { headers: { Authorization: "Bearer " + tok } });
          if (!res.ok) {
            const j = await res.json().catch(() => ({}));
            throw new Error(j?.error?.message || "Gagal (" + res.status + ")");
          }
          const blob = await res.blob();
          // Extract filename from Content-Disposition if present.
          const cd = res.headers.get("content-disposition") || "";
          const m = cd.match(/filename="?([^"]+)"?/);
          const filename = m ? m[1] : "kongsian-analytics.csv";
          const a = document.createElement("a");
          a.href = URL.createObjectURL(blob);
          a.download = filename;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          setTimeout(() => URL.revokeObjectURL(a.href), 5000);
        } catch (err) {
          if (err && err.code === "UNAUTHENTICATED") return;
          alert(window.t("Gagal") + ": " + (err?.message || window.t("Unknown")));
        } finally {
          btn.disabled = false;
          btn.textContent = orig;
        }
      });

      // Tab clicks already have href= so they navigate naturally. Init load:
      loadTenants().then(load);
    </script>
  </body>
</html>
