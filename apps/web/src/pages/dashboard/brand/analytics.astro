---
/**
 * Brand Analytics — Week 4, F3.
 *
 * URL state: ?range=7d|30d&tenantId=<id?>
 *   - Tab is implicit (= range). Persists in URL so a deep-link is
 *     shareable.
 *   - Tenant dropdown narrows the query.
 *
 * Renders:
 *   - 4 summary cards: Total Revenue, Total Units, Closings, Disputes
 *   - Top 5 SKU table
 *   - Per-tenant breakdown cards (qty + revenue + closing/settle count)
 *   - ASCII bar chart of daily revenue (0-filled, TZ-safe)
 *   - "Download CSV" button → /v1/analytics/overview?range=...&format=csv
 *
 * Empty state: if totalUnits === 0, hide chart + table, show a
 * "Belum ada closing di rentang ini" card.
 */
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../../../lib/api";
import NotificationBell from "../../../components/NotificationBell.astro";
const title = `Analytics — ${APP_NAME}`;
---
<!doctype html>
<html lang="id" data-role="brand">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: #0b1220; color: #f1f5f9;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }
      a { color: #38bdf8; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .shell { max-width: 720px; margin: 0 auto; padding: 0 0 80px; }
      header.top {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; border-bottom: 1px solid #1e293b;
        position: sticky; top: 0; background: rgba(11, 18, 32, .92);
        backdrop-filter: blur(6px); z-index: 5;
      }
      .brand-name { font-weight: 700; font-size: 15px; }
      .role-tag { font-size: 11px; padding: 2px 8px; border-radius: 999px; background: #fbbf24; color: #0b1220; font-weight: 700; letter-spacing: 0.04em; }
      .logout { font-size: 13px; color: #94a3b8; background: none; border: none; cursor: pointer; }
      main { padding: 20px; }
      .greet { font-size: 14px; color: #94a3b8; margin: 0 0 4px; }
      h1 { font-size: 24px; margin: 0 0 8px; letter-spacing: -0.01em; }
      .sub-h1 { font-size: 13px; color: #94a3b8; margin: 0 0 16px; }

      /* Tabs */
      .tabs { display: flex; gap: 4px; background: #0f172a; border: 1px solid #1e293b; border-radius: 10px; padding: 4px; margin-bottom: 16px; }
      .tab { flex: 1; padding: 8px 12px; text-align: center; font-size: 13px; font-weight: 600; border-radius: 7px; color: #94a3b8; cursor: pointer; text-decoration: none; }
      .tab:hover { color: #f1f5f9; text-decoration: none; }
      .tab.active { background: #1e293b; color: #f1f5f9; }

      /* Filter row */
      .filter-row { display: flex; gap: 8px; align-items: center; margin-bottom: 20px; flex-wrap: wrap; }
      .filter-row select {
        background: #0f172a; color: #f1f5f9; border: 1px solid #1e293b;
        border-radius: 8px; padding: 8px 10px; font-size: 13px; flex: 1; min-width: 0;
      }
      .csv-btn {
        background: #fbbf24; color: #0b1220; border: none; border-radius: 8px;
        padding: 8px 14px; font-size: 13px; font-weight: 700; cursor: pointer;
        display: inline-flex; align-items: center; gap: 6px;
      }
      .csv-btn:hover { background: #fde68a; }
      .csv-btn:disabled { opacity: 0.5; cursor: not-allowed; }

      /* Summary cards */
      .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px; }
      .stat { background: #0f172a; border: 1px solid #1e293b; border-radius: 12px; padding: 14px; }
      .stat .lbl { font-size: 11px; color: #94a3b8; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.06em; }
      .stat .val { font-size: 20px; font-weight: 700; word-break: break-all; }
      .stat .sub { font-size: 11px; color: #94a3b8; margin-top: 2px; }

      h2 { font-size: 13px; margin: 24px 0 12px; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; }

      /* Top SKU table */
      .sku-table { background: #0f172a; border: 1px solid #1e293b; border-radius: 12px; overflow: hidden; }
      .sku-row { display: grid; grid-template-columns: 36px 1fr 80px 120px; padding: 10px 14px; align-items: center; font-size: 13px; border-bottom: 1px solid #1e293b; }
      .sku-row:last-child { border-bottom: none; }
      .sku-row.head { background: #1e293b; color: #94a3b8; font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; }
      .sku-row .rank { font-weight: 700; color: #fbbf24; }
      .sku-row .qty { text-align: right; color: #94a3b8; }
      .sku-row .rev { text-align: right; font-weight: 600; }

      /* Tenant cards */
      .tenant-list { display: flex; flex-direction: column; gap: 10px; }
      .tenant-card { background: #0f172a; border: 1px solid #1e293b; border-radius: 12px; padding: 14px; }
      .tenant-card .name { font-weight: 600; font-size: 14px; margin-bottom: 6px; }
      .tenant-card .row { display: flex; justify-content: space-between; font-size: 12px; color: #94a3b8; padding: 2px 0; }
      .tenant-card .row .v { color: #f1f5f9; font-weight: 600; }

      /* ASCII chart */
      .chart { background: #0f172a; border: 1px solid #1e293b; border-radius: 12px; padding: 16px; overflow-x: auto; }
      .chart-row { display: flex; align-items: center; font-size: 11px; font-family: ui-monospace, SFMono-Regular, monospace; padding: 1px 0; }
      .chart-row .date { width: 70px; color: #94a3b8; flex-shrink: 0; }
      .chart-row .bar { color: #fbbf24; letter-spacing: 0; }
      .chart-row .val { margin-left: 8px; color: #94a3b8; }

      .err { background: rgba(251, 113, 133, .12); color: #fb7185; border: 1px solid rgba(251, 113, 133, .3); padding: 12px; border-radius: 10px; font-size: 14px; margin-bottom: 16px; }
      .loading { color: #94a3b8; text-align: center; padding: 40px 24px; }
      .empty { background: #0f172a; border: 1px dashed #1e293b; border-radius: 12px; padding: 32px 20px; text-align: center; color: #94a3b8; }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="top">
        <a href="/dashboard/brand" class="brand-name">← {APP_NAME}</a>
        <div style="display:flex; gap:10px; align-items:center;">
          <span class="role-tag">BRAND</span>
          <NotificationBell />
        </div>
      </header>
      <main>
        <p class="greet">Analytics</p>
        <h1>Tren Penjualan</h1>
        <p class="sub-h1" id="range-label">Memuat…</p>

        <!-- Tabs (URL state, shareable) -->
        <div class="tabs" id="tabs">
          <a class="tab" data-range="7d" href="?range=7d">7 Hari</a>
          <a class="tab" data-range="30d" href="?range=30d">30 Hari</a>
        </div>

        <!-- Tenant filter + CSV button -->
        <div class="filter-row">
          <select id="tenant-filter">
            <option value="">Semua tenant</option>
          </select>
          <button class="csv-btn" id="csv-btn" type="button">📥 Download CSV</button>
        </div>

        <div id="status" aria-live="polite"></div>
        <div id="content"></div>
      </main>
    </div>

    <script src="/kongsian-auth-bus.js" defer is:inline></script>
    <script define:vars={{ API_BASE_URL }}>
      // -----------------------------------------------------------------------
      // State from URL
      // -----------------------------------------------------------------------
      const params = new URLSearchParams(window.location.search);
      const range = params.get("range") === "30d" ? "30d" : "7d";
      const tenantId = params.get("tenantId") || "";

      // Active tab
      document.querySelectorAll("#tabs .tab").forEach(el => {
        el.classList.toggle("active", el.getAttribute("data-range") === range);
      });

      const tok = localStorage.getItem("kongsian_session");
      const API = API_BASE_URL.replace(/\/$/, "");

      // -----------------------------------------------------------------------
      // Format helpers
      // -----------------------------------------------------------------------
      const fmtIdr = n => "Rp " + (n || 0).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
      const fmtInt = n => (n || 0).toLocaleString("id-ID");

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, c => ({
          "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#39;"
        }[c]));
      }

      // -----------------------------------------------------------------------
      // API helper (uses global auth bus if loaded)
      // -----------------------------------------------------------------------
      function apiJson(path) {
        if (window.kongsianApi && window.kongsianApi.apiJson) {
          return window.kongsianApi.apiJson(path, { headers: { Authorization: "Bearer " + tok } });
        }
        return fetch(API + path, { headers: { Authorization: "Bearer " + tok } }).then(r => {
          if (r.status === 401) {
            window.dispatchEvent(new CustomEvent("kongsian:unauthorized", { detail: { reason: "api_401" } }));
            const e = new Error("Unauthenticated"); e.code = "UNAUTHENTICATED"; throw e;
          }
          if (!r.ok) {
            return r.json().then(j => { throw new Error(j?.error?.message || "API " + r.status); });
          }
          return r.json();
        });
      }

      // -----------------------------------------------------------------------
      // Render
      // -----------------------------------------------------------------------
      function renderChart(daily) {
        if (!daily || daily.length === 0) return '<div class="empty">Belum ada data</div>';
        const maxRev = Math.max(...daily.map(d => d.revenueIdr), 0);
        const BARS = "▁▂▃▄▅▆▇█";
        const ROWS = 40; // max bar width in chars
        return '<div class="chart">' + daily.map(d => {
          // Bar width: proportional to max, 1 char min, 0 if max is 0.
          let bar;
          if (maxRev === 0 || d.revenueIdr === 0) {
            bar = "▁";
          } else {
            const ratio = d.revenueIdr / maxRev;
            const width = Math.max(1, Math.round(ratio * ROWS));
            // Build a "ramp"-style bar: each char represents a level.
            const fullBlocks = Math.min(8, Math.ceil((ratio) * 8));
            bar = BARS[fullBlocks - 1].repeat(Math.max(1, Math.round(width / 5)));
            // Pad to ROWS chars for alignment
            bar = bar.padEnd(ROWS, " ");
          }
          return `<div class="chart-row">
            <span class="date">${d.date.slice(5)}</span>
            <span class="bar">${escapeHtml(bar)}</span>
            <span class="val">${fmtIdr(d.revenueIdr)}</span>
          </div>`;
        }).join("") + '</div>';
      }

      function renderTopProducts(top) {
        if (!top || top.length === 0) return '<div class="empty">Belum ada produk terjual</div>';
        return '<div class="sku-table">' +
          '<div class="sku-row head"><div>#</div><div>SKU</div><div class="qty">Qty</div><div class="rev">Revenue</div></div>' +
          top.map((p, i) => `<div class="sku-row">
            <div class="rank">${i + 1}</div>
            <div>${escapeHtml(p.skuName)} <span style="color:#64748b;font-size:11px;">${escapeHtml(p.skuCode)}</span></div>
            <div class="qty">${fmtInt(p.qtySold)}</div>
            <div class="rev">${fmtIdr(p.revenueIdr)}</div>
          </div>`).join("") +
          '</div>';
      }

      function renderTenantBreakdown(list) {
        if (!list || list.length === 0) return '<div class="empty">Belum ada tenant</div>';
        return '<div class="tenant-list">' + list.map(t => `<div class="tenant-card">
          <div class="name">${escapeHtml(t.tenantName)}</div>
          <div class="row"><span>Qty terjual</span><span class="v">${fmtInt(t.qtySold)}</span></div>
          <div class="row"><span>Revenue</span><span class="v">${fmtIdr(t.revenueIdr)}</span></div>
          <div class="row"><span>Closings</span><span class="v">${fmtInt(t.closingCount)}</span></div>
          <div class="row"><span>Settlements</span><span class="v">${fmtInt(t.settleCount)}</span></div>
        </div>`).join("") + '</div>';
      }

      function render(data) {
        const status = document.getElementById("status");
        const content = document.getElementById("content");
        const rangeLbl = document.getElementById("range-label");

        const { range: r, summary, topProducts, tenantBreakdown, dailySeries } = data;
        rangeLbl.textContent = `${r.start} → ${r.end} (${r.end === new Date().toISOString().slice(0,10) ? "sampai hari ini" : "akhir rentang"})`;

        if (summary.totalUnits === 0) {
          content.innerHTML = `<div class="empty">
            <p style="margin:0 0 8px;">Belum ada closing di rentang ini.</p>
            <p style="margin:0;font-size:12px;">Coba rentang yang lebih panjang, atau tunggu tenant submit closing pertama.</p>
          </div>`;
          return;
        }

        // Summary cards
        let html = `<div class="stats">
          <div class="stat"><div class="lbl">Total Revenue</div><div class="val">${fmtIdr(summary.totalRevenueIdr)}</div><div class="sub">avg ${fmtIdr(summary.avgDailyRevenueIdr)}/hari</div></div>
          <div class="stat"><div class="lbl">Units Sold</div><div class="val">${fmtInt(summary.totalUnits)}</div></div>
          <div class="stat"><div class="lbl">Closings</div><div class="val">${fmtInt(summary.closingCount)}</div></div>
          <div class="stat"><div class="lbl">Disputes</div><div class="val">${fmtInt(summary.disputeCount)}</div></div>
        </div>`;

        html += `<h2>Tren Harian</h2>${renderChart(dailySeries)}`;
        html += `<h2>Top 5 Produk</h2>${renderTopProducts(topProducts)}`;
        html += `<h2>Per Tenant</h2>${renderTenantBreakdown(tenantBreakdown)}`;

        content.innerHTML = html;
      }

      // -----------------------------------------------------------------------
      // Tenant filter
      // -----------------------------------------------------------------------
      function loadTenants() {
        // Light: fetch the partnerships and extract unique tenants.
        return apiJson("/v1/partnerships?status=ACTIVE&limit=200").then(j => {
          const list = (j?.data?.partnerships || []).map(p => ({
            id: p.tenant?.id || p.tenantId,
            name: p.tenant?.name || "(tanpa nama)",
          }));
          // Dedupe by id
          const seen = new Set();
          const unique = list.filter(t => { if (seen.has(t.id)) return false; seen.add(t.id); return true; });
          const sel = document.getElementById("tenant-filter");
          sel.innerHTML = '<option value="">Semua tenant</option>' +
            unique.map(t => `<option value="${escapeHtml(t.id)}" ${tenantId === t.id ? "selected" : ""}>${escapeHtml(t.name)}</option>`).join("");
        }).catch(() => { /* non-fatal; filter stays empty */ });
      }

      // -----------------------------------------------------------------------
      // Load + reload
      // -----------------------------------------------------------------------
      async function load() {
        const status = document.getElementById("status");
        const content = document.getElementById("content");
        if (!tok) {
          window.location.href = "/login";
          return;
        }
        status.innerHTML = '<div class="loading">Memuat analytics…</div>';
        content.innerHTML = "";
        try {
          const qs = new URLSearchParams({ range });
          if (tenantId) qs.set("tenantId", tenantId);
          const j = await apiJson("/v1/analytics/overview?" + qs.toString());
          if (!j.ok) throw new Error(j?.error?.message || "Gagal");
          status.innerHTML = "";
          render(j.data);
        } catch (e) {
          if (e && e.code === "UNAUTHENTICATED") return;
          status.innerHTML = '<div class="err">' + escapeHtml(e?.message || "Gagal memuat") + '</div>';
        }
      }

      // Filter change reloads with new ?tenantId=
      document.getElementById("tenant-filter").addEventListener("change", (e) => {
        const newTenantId = e.target.value;
        const q = new URLSearchParams(window.location.search);
        if (newTenantId) q.set("tenantId", newTenantId); else q.delete("tenantId");
        window.location.search = q.toString();
      });

      // CSV button
      document.getElementById("csv-btn").addEventListener("click", async (e) => {
        const btn = e.currentTarget;
        if (btn.disabled) return;
        const orig = btn.textContent;
        btn.disabled = true;
        btn.textContent = "Menyiapkan…";
        try {
          const qs = new URLSearchParams({ range, format: "csv" });
          if (tenantId) qs.set("tenantId", tenantId);
          // Stream the CSV via blob to trigger download with the right filename.
          const url = API + "/v1/analytics/overview?" + qs.toString();
          const res = await fetch(url, { headers: { Authorization: "Bearer " + tok } });
          if (!res.ok) {
            const j = await res.json().catch(() => ({}));
            throw new Error(j?.error?.message || "Gagal (" + res.status + ")");
          }
          const blob = await res.blob();
          // Extract filename from Content-Disposition if present.
          const cd = res.headers.get("content-disposition") || "";
          const m = cd.match(/filename="?([^"]+)"?/);
          const filename = m ? m[1] : "kongsian-analytics.csv";
          const a = document.createElement("a");
          a.href = URL.createObjectURL(blob);
          a.download = filename;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          setTimeout(() => URL.revokeObjectURL(a.href), 5000);
        } catch (err) {
          if (err && err.code === "UNAUTHENTICATED") return;
          alert("Gagal: " + (err?.message || "Unknown"));
        } finally {
          btn.disabled = false;
          btn.textContent = orig;
        }
      });

      // Tab clicks already have href= so they navigate naturally. Init load:
      loadTenants().then(load);
    </script>
  </body>
</html>
