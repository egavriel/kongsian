---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../../../../lib/api";
const title = `Catat Hari Ini — ${APP_NAME}`;
export const prerender = false;
export const ssr = false;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body { margin:0; background:#0b1220; color:#f1f5f9; font-family:ui-sans-serif,system-ui,-apple-system,sans-serif; line-height:1.5; -webkit-font-smoothing:antialiased; }
      a { color:#38bdf8; text-decoration:none; }
      .shell { max-width:480px; margin:0 auto; padding:0 0 80px; }
      header.top { display:flex; align-items:center; justify-content:space-between; padding:16px 20px; border-bottom:1px solid #1e293b; position:sticky; top:0; background:rgba(11,18,32,.92); backdrop-filter:blur(6px); z-index:5; }
      .back { color:#94a3b8; font-size:14px; }
      h1 { font-size:20px; margin:0; }
      main { padding:20px; }
      label { display:flex; flex-direction:column; gap:6px; margin-bottom:14px; font-size:13px; }
      .lbl { font-weight:600; }
      select, input { background:#0b1220; border:1px solid #1e293b; color:#f1f5f9; padding:12px; border-radius:10px; font-size:16px; font-family:inherit; width:100%; min-height:48px; }
      select:focus, input:focus { outline:none; border-color:#fbbf24; }
      .btn { display:inline-flex; align-items:center; justify-content:center; gap:8px; padding:14px 20px; border-radius:10px; font-weight:600; border:1px solid transparent; cursor:pointer; font-size:16px; min-height:48px; }
      .btn-primary { background:#fbbf24; color:#0b1220; width:100%; }
      .btn-primary:disabled { opacity:.5; cursor:not-allowed; }
      .section { background:#0f172a; border:1px solid #1e293b; border-radius:12px; padding:14px; margin-bottom:16px; }
      .section h2 { margin:0 0 4px; font-size:16px; display:flex; align-items:center; gap:8px; }
      .section h2 .ic { font-size:18px; }
      .section .hint { font-size:12px; color:#94a3b8; margin:0 0 10px; }
      .sk-row, :global(.sk-row) { display:grid; grid-template-columns:1fr 150px; gap:10px; align-items:center; padding:8px 0; border-bottom:1px solid #1e293b; }
      :global(.sk-row:last-child) { border-bottom:none; }
      :global(.sk-label .code) { color:#fbbf24; font-weight:700; margin-right:6px; }
      :global(.sk-label .name) { color:#f1f5f9; }
      :global(.sk-label .meta) { color:#94a3b8; font-size:12px; }
      :global(.sk-row input) { padding:10px; text-align:center; font-size:16px; min-height:48px; }
      :global(.stepper) { display:grid; grid-template-columns:44px 1fr 44px; gap:6px; align-items:stretch; }
      :global(.stepper .step-btn) { background:#0b1220; border:1px solid #1e293b; color:#f1f5f9; border-radius:10px; font-size:20px; font-weight:700; min-height:48px; cursor:pointer; padding:0; line-height:1; }
      :global(.stepper .step-btn:active) { background:#1e293b; }
      :global(.stepper .step-btn:disabled) { opacity:.4; cursor:not-allowed; }
      :global(.stepper input) { width:100%; }
      .empty { padding:16px; text-align:center; color:#94a3b8; font-size:13px; }
      .err { background:rgba(251,113,133,.12); color:#fb7185; border:1px solid rgba(251,113,133,.3); padding:10px 12px; border-radius:10px; font-size:13px; margin-bottom:12px; }
      .ok { background:rgba(52,211,153,.12); color:#34d399; border:1px solid rgba(52,211,153,.3); padding:10px 12px; border-radius:10px; font-size:13px; margin-bottom:12px; }
      .status { padding:10px 12px; border-radius:10px; font-size:13px; margin-bottom:12px; }
      .diag { display:block; }
      .summary-card { background:#0f172a; border:1px solid #1e293b; border-radius:12px; padding:14px; margin-bottom:14px; }
      .summary-card .partner { font-weight:700; margin-bottom:10px; font-size:13px; color:#94a3b8; }
      .summary-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
      .summary-card .label { font-size: 11px; color:#94a3b8; text-transform: uppercase; letter-spacing:.08em; font-weight:700; }
      .summary-card .value { font-size: 26px; font-weight: 800; color:#f1f5f9; }
      .summary-card .sub { font-size: 12px; color:#94a3b8; margin-top:6px; }
      .section.stok-awal { border-color:#a78bfa; background:rgba(167,139,250,.04); }
      .section.stok-awal h2 .ic { color:#a78bfa; }
      .section.stok-awal .badge { display:inline-block; background:rgba(167,139,250,.15); color:#a78bfa; border:1px solid rgba(167,139,250,.3); border-radius:999px; font-size:10px; padding:2px 8px; font-weight:700; letter-spacing:.05em; margin-left:6px; vertical-align:middle; }
      :global(.sk-row .set-once-hint) { color:#a78bfa; font-size:11px; }
      .summary-card .stok-awal-row { grid-column:1 / -1; padding:10px 0; border-bottom:1px solid #1e293b; margin-bottom:6px; }
      .summary-card .stok-awal-row .label { color:#a78bfa; }
      .summary-card .stok-awal-row .value { color:#a78bfa; }
      .section-head { display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:4px; }
      .section-head h2 { margin:0; }
      .btn-ghost { background:transparent; border:1px solid #1e293b; color:#a78bfa; padding:6px 12px; border-radius:8px; font-size:12px; font-weight:600; cursor:pointer; min-height:32px; }
      .btn-ghost:hover { background:rgba(167,139,250,.08); border-color:#a78bfa; }
      .btn-ghost:active { background:rgba(167,139,250,.16); }
      .btn-ghost:disabled { opacity:.4; cursor:not-allowed; }
      /* Skeleton loaders — shown while partnership-scoped data is fetching */
      :global(.skeleton) { background: linear-gradient(90deg, #1e293b 0%, #334155 50%, #1e293b 100%); background-size: 200% 100%; animation: sk-shimmer 1.2s linear infinite; border-radius:6px; }
      @keyframes sk-shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
      :global(.skeleton-row) { display:grid; grid-template-columns:1fr 150px; gap:10px; align-items:center; padding:10px 0; border-bottom:1px solid #1e293b; }
      :global(.skeleton-row:last-child) { border-bottom:none; }
      :global(.skeleton-block) { height:14px; }
      :global(.skeleton-stepper) { height:36px; }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="top">
        <a class="back" href="/dashboard/brand">← Brand</a>
        <h1>Catat Hari Ini</h1>
        <span></span>
      </header>
      <main>
        <div id="err" class="err" style="display:none"></div>
        <div id="ok" class="ok" style="display:none"></div>
        <label>
          <span class="lbl">Tanggal</span>
          <input id="date" type="date" required />
        </label>
        <label>
          <span class="lbl">Partner</span>
          <select id="partnership" disabled>
            <option value="">— Memuat… —</option>
          </select>
        </label>
        <div id="ops-summary" class="summary-card" style="display:none">
          <div class="partner" id="ops-summary-partner">—</div>
          <div class="summary-grid">
            <div class="stok-awal-row"><div class="label">Stok Awal</div><div class="value" id="ops-summary-stok-awal">0</div></div>
            <div><div class="label">Titip</div><div class="value" id="ops-summary-titip">0</div></div>
            <div><div class="label">Tarik</div><div class="value" id="ops-summary-tarik">0</div></div>
            <div><div class="label">Terjual</div><div class="value" id="ops-summary-terjual">0</div></div>
            <div><div class="label">Sisa sistem</div><div class="value" id="ops-summary-sisa">0</div></div>
          </div>
        </div>

        <div class="section stok-awal">
          <div class="section-head">
            <h2><span class="ic">🌱</span> Stok Awal<span class="badge">SEKALI</span></h2>
            <button type="button" id="stok-awal-reset" class="btn-ghost" style="display:none" aria-label="Reset Stok Awal">↺ Reset</button>
          </div>
          <p class="hint">Stok yang SUDAH ada di partner <b>sebelum</b> mulai pakai Kongsian. Cukup diisi sekali di hari pertama partnership — sistem akan menambahkannya ke sisa. Untuk tambah stok baru pakai kolom Titip di bawah.</p>
          <div id="stok-awal-section"><div class="empty">Pilih partner dulu.</div></div>
        </div>

        <div class="section">
          <h2><span class="ic">📦</span> Titip (stok masuk)</h2>
          <p class="hint">Isi berapa banyak tiap SKU yang kamu titipkan ke partner hari ini.</p>
          <div id="titip-section"><div class="empty">Pilih partner dulu.</div></div>
        </div>

        <div class="section">
          <h2><span class="ic">↩️</span> Tarik (stok kembali)</h2>
          <p class="hint">Stok yang tidak terjual dan kamu bawa kembali. Max = sisa sistem.</p>
          <div id="tarik-section"><div class="empty">Pilih partner dulu.</div></div>
        </div>

        <div class="section">
          <h2><span class="ic">💵</span> Terjual (closing)</h2>
          <p class="hint">Berapa cup/pack terjual hari ini per SKU. Ini yang dihitung untuk settlement.</p>
          <div id="terjual-section"><div class="empty">Pilih partner dulu.</div></div>
        </div>

        <button id="submit-btn" class="btn btn-primary" type="button" disabled>Simpan Semua</button>
        <div id="ops-status" class="status" style="display:none"></div>
      </main>
    </div>
    <script define:vars={{ API_BASE_URL }}>
      const API = API_BASE_URL.replace(/\/$/, "");
      const tok = localStorage.getItem("kongsian_session");
      if (!tok) { window.location.href = "/login"; }
      const authH = { Authorization: `Bearer ${tok}`, "Content-Type": "application/json" };
      async function jget(p) { return (await fetch(API+p, { headers: authH })).json().catch(()=>({})); }

      const errEl = document.getElementById("err");
      const okEl = document.getElementById("ok");
      const showErr = m => { errEl.textContent = m; errEl.style.display="block"; okEl.style.display="none"; window.scrollTo({ top: 0, behavior: "smooth" }); };
      const showOk = m => { okEl.textContent = m; okEl.style.display="block"; errEl.style.display="none"; };
      function fmtRp(n) { return new Intl.NumberFormat("id-ID", { style:"currency", currency:"IDR", maximumFractionDigits:0 }).format(n); }

      const state = { brandId: null, partnershipId: null, tenantId: null, skus: [], sisaSistem: {}, partnerships: [], stokAwal: {} };
      const STOK_AWAL_REASON = "Stok awal partnership";
      document.getElementById("date").value = new Date().toISOString().slice(0, 10);

      // Race guard: bump this on every partnership/date change. A response whose
      // sequence number is < the current one is stale (user picked a different
      // option before the previous fetch finished) and must NOT touch state.
      let loadSeq = 0;

      function renderSkeletons() {
        const skel = `
          <div class="skeleton-row">
            <div><div class="skeleton skeleton-block" style="width:55%"></div><div class="skeleton skeleton-block" style="width:35%; margin-top:6px"></div></div>
            <div class="skeleton skeleton-stepper"></div>
          </div>
          <div class="skeleton-row">
            <div><div class="skeleton skeleton-block" style="width:50%"></div><div class="skeleton skeleton-block" style="width:30%; margin-top:6px"></div></div>
            <div class="skeleton skeleton-stepper"></div>
          </div>
          <div class="skeleton-row">
            <div><div class="skeleton skeleton-block" style="width:60%"></div><div class="skeleton skeleton-block" style="width:40%; margin-top:6px"></div></div>
            <div class="skeleton skeleton-stepper"></div>
          </div>
        `;
        for (const id of ["stok-awal-section","titip-section","tarik-section","terjual-section"]) {
          document.getElementById(id).innerHTML = skel;
        }
      }

      function attachQtyStrip(sel) {
        // Strip non-digits on the hidden number input + wire minus/plus buttons.
        document.querySelectorAll(sel + " .stepper").forEach(stepper => {
          const inp = stepper.querySelector("input[data-sku]");
          const minus = stepper.querySelector(".step-btn.minus");
          const plus = stepper.querySelector(".step-btn.plus");
          if (!inp) return;
          const clamp = () => {
            const max = inp.hasAttribute("max") ? parseInt(inp.getAttribute("max"), 10) : null;
            let v = parseInt((inp.value || "0").replace(/\D/g, ""), 10) || 0;
            if (v < 0) v = 0;
            if (max != null && v > max) v = max;
            if (String(v) !== inp.value) inp.value = String(v);
            if (minus) minus.disabled = v <= 0;
            if (plus) plus.disabled = (max != null && v >= max);
            try { updateSummary(); } catch (e) {}
          };
          inp.addEventListener("input", clamp);
          if (minus) minus.addEventListener("click", () => { if (inp.disabled) return; inp.value = String(Math.max(0, (parseInt((inp.value||"0").replace(/\D/g,""),10)||0) - 1)); clamp(); });
          if (plus)  plus.addEventListener("click", () => { if (inp.disabled) return; inp.value = String(((parseInt((inp.value||"0").replace(/\D/g,""),10)||0) + 1)); clamp(); });
          clamp();
        });
      }

      function skuRow(s, kind, opts = {}) {
        const max = opts.max != null ? `max="${opts.max}"` : "";
        const dis = opts.disabled ? "disabled" : "";
        const val = opts.value != null && opts.value !== 0 ? `value="${opts.value}"` : "";
        const hint = opts.hint ? `<div class="meta">${opts.hint}</div>` : `<div class="meta">${fmtRp(s.priceIdr)}</div>`;
        return `
          <div class="sk-row">
            <div class="sk-label">
              <div><span class="code">${s.code}</span><span class="name">${s.name}</span></div>
              ${hint}
            </div>
            <div class="stepper">
              <button type="button" class="step-btn minus" aria-label="Kurangi" ${dis}>−</button>
              <input type="number" min="0" ${max} ${val} step="1" data-sku="${s.id}" data-kind="${kind}" placeholder="0" inputmode="numeric" ${dis} />
              <button type="button" class="step-btn plus" aria-label="Tambah" ${dis}>+</button>
            </div>
          </div>
        `;
      }

      function renderSections() {
        const disabled = !state.partnershipId || state.skus.length === 0;
        document.getElementById("submit-btn").disabled = disabled;
        if (!state.partnershipId) {
          for (const id of ["stok-awal-section","titip-section","tarik-section","terjual-section"]) {
            document.getElementById(id).innerHTML = `<div class="empty">Pilih partner dulu.</div>`;
          }
          return;
        }
        if (state.skus.length === 0) {
          for (const id of ["stok-awal-section","titip-section","tarik-section","terjual-section"]) {
            document.getElementById(id).innerHTML = `<div class="empty">Belum ada SKU.</div>`;
          }
          return;
        }
        document.getElementById("stok-awal-section").innerHTML = state.skus.map(s => {
          const existing = state.stokAwal[s.id] ?? 0;
          const hint = existing > 0
            ? `<div class="meta set-once-hint">✓ Sudah diisi: ${existing} (edit jika perlu)</div>`
            : `<div class="meta">${fmtRp(s.priceIdr)}</div>`;
          return skuRow(s, "stok-awal", { hint, value: existing > 0 ? existing : undefined });
        }).join("");
        document.getElementById("titip-section").innerHTML = state.skus.map(s => skuRow(s, "titip")).join("");
        document.getElementById("tarik-section").innerHTML = state.skus.map(s => {
          const sisa = state.sisaSistem[s.id] ?? 0;
          return skuRow(s, "tarik", { max: sisa, disabled: sisa <= 0, hint: `Sisa: ${sisa}` });
        }).join("");
        document.getElementById("terjual-section").innerHTML = state.skus.map(s => skuRow(s, "terjual")).join("");
        attachQtyStrip("#stok-awal-section"); attachQtyStrip("#titip-section"); attachQtyStrip("#tarik-section"); attachQtyStrip("#terjual-section");
      }

      function updateStokAwalResetButton() {
        const btn = document.getElementById("stok-awal-reset");
        if (!btn) return;
        const hasSaved = Object.values(state.stokAwal || {}).some((v) => (v || 0) > 0);
        btn.style.display = (state.partnershipId && hasSaved) ? "inline-block" : "none";
      }

      async function resetStokAwal() {
        if (!state.partnershipId) return;
        const date = document.getElementById("date").value;
        const savedCount = Object.values(state.stokAwal || {}).filter((v) => (v || 0) > 0).length;
        if (savedCount === 0) return;
        const ok = window.confirm(
          `Hapus ${savedCount} entri Stok Awal yang tersimpan untuk tanggal ${date}?\n\n` +
          `Tindakan ini akan mempengaruhi Sisa Sistem. Tidak bisa di-undo (kecuali kamu input ulang).`
        );
        if (!ok) return;
        const btn = document.getElementById("stok-awal-reset");
        btn.disabled = true; btn.textContent = "Menghapus…";
        try {
          const r = await fetch(API + "/v1/movements", {
            method: "DELETE",
            headers: { ...authH },
            body: JSON.stringify({
              partnershipId: state.partnershipId,
              movementDate: date,
              reason: STOK_AWAL_REASON,
            }),
          });
          if (!r.ok) { const j = await r.json().catch(()=>({})); throw new Error(j?.error?.code || "HTTP " + r.status); }
          const j = await r.json().catch(() => ({}));
          const deletedCount = j?.data?.count ?? savedCount;
          showOk(`Stok Awal dihapus (${deletedCount} baris). Menyegarkan…`);
          // Hard reload to guarantee a fresh state from the server. In-place state
          // updates were leaving stale `Sisa sistem` values visible when the
          // user expected the persisted stock to drop to 0 immediately.
          setTimeout(() => { window.location.reload(); }, 700);
        } catch (e) {
          showErr("Reset gagal: " + (e.message || e));
          btn.disabled = false; btn.textContent = "↺ Reset";
        }
      }

      function updateSummary() {
        const box = document.getElementById("ops-summary");
        const partnerName = document.getElementById("partnership")?.selectedOptions?.[0]?.text?.trim() || "(partner)";
        const stokAwal = [...document.querySelectorAll("#stok-awal-section input[data-sku]")].reduce((a, i) => a + (parseInt(i.value || "0", 10) || 0), 0);
        const titip = [...document.querySelectorAll("#titip-section input[data-sku]")].reduce((a, i) => a + (parseInt(i.value || "0", 10) || 0), 0);
        const tarik = [...document.querySelectorAll("#tarik-section input[data-sku]")].reduce((a, i) => a + (parseInt(i.value || "0", 10) || 0), 0);
        const terjual = [...document.querySelectorAll("#terjual-section input[data-sku]")].reduce((a, i) => a + (parseInt(i.value || "0", 10) || 0), 0);
        const sisa = Object.values(state.sisaSistem || {}).reduce((a, v) => a + (v || 0), 0);
        document.getElementById("ops-summary-partner").textContent = partnerName;
        document.getElementById("ops-summary-stok-awal").textContent = stokAwal.toLocaleString("id-ID");
        document.getElementById("ops-summary-titip").textContent = titip.toLocaleString("id-ID");
        document.getElementById("ops-summary-tarik").textContent = tarik.toLocaleString("id-ID");
        document.getElementById("ops-summary-terjual").textContent = terjual.toLocaleString("id-ID");
        document.getElementById("ops-summary-sisa").textContent = sisa.toLocaleString("id-ID");
        box.style.display = "block";
      }

      async function loadPartnershipScopedData() {
        if (!state.partnershipId) return;
        const seq = ++loadSeq;        // invalidate any in-flight previous load
        renderSkeletons();             // show shimmer immediately so the user sees the page is working
        const date = document.getElementById("date").value;
        const r = await jget(`/v1/ops/partnership-data?partnershipId=${state.partnershipId}&date=${date}`);
        if (seq !== loadSeq) return; // stale

        state.sisaSistem = {};
        state.stokAwal = {};
        if (r.ok) {
          const { sisaSistem, stokAwal } = r.data || {};
          for (const row of sisaSistem || []) {
            state.sisaSistem[row.skuId] = row.sisa ?? 0;
          }
          for (const row of stokAwal || []) {
            state.stokAwal[row.skuId] = row.qty ?? 0;
          }
        }
        updateStokAwalResetButton();
        renderSections();
        updateSummary();
      }

      async function init() {
        const initData = await jget("/v1/ops/init");
        if (!initData.ok) {
          if (initData.error?.code === "VERIFICATION_PENDING") {
            window.location.href = "/login?registered=1";
            return;
          }
          window.location.href = "/dashboard/brand";
          return;
        }

        const { brandId, skus, partnerships } = initData.data;
        state.brandId = brandId;
        state.skus = skus || [];
        state.partnerships = partnerships || [];

        const sel = document.getElementById("partnership");
        if (state.partnerships.length === 0) {
          sel.innerHTML = `<option value="">— Belum ada partner aktif —</option>`;
        } else {
          sel.innerHTML = `<option value="">— Pilih partner —</option>` +
            state.partnerships.map(p => `<option value="${p.id}" data-tenant="${p.tenant?.id || ""}">${p.tenant?.name || "(tenant?)"}</option>`).join("");
        }
        sel.disabled = false;

        sel.addEventListener("change", async (e) => {
          const opt = e.target.selectedOptions[0];
          state.partnershipId = e.target.value || null;
          state.tenantId = opt ? opt.dataset.tenant : null;
          renderSections();
          updateSummary();
          if (!state.partnershipId) return;
          await loadPartnershipScopedData();
        });
        document.getElementById("date").addEventListener("change", async () => {
          if (state.partnershipId) { await loadPartnershipScopedData(); }
        });
      }

      function readSectionItems(sectionSel, kind) {
        // For movements/batch: each item is { skuId, kind, qty }
        const items = [];
        document.querySelectorAll(sectionSel + " input[data-sku]").forEach(inp => {
          if (inp.disabled) return;
          const v = parseInt((inp.value || "0").replace(/\D/g, ""), 10) || 0;
          if (v > 0) items.push({ skuId: inp.dataset.sku, kind, qty: v });
        });
        return items;
      }
      function readStokAwalItems(sectionSel) {
        // Stok Awal is an ADJUSTMENT with a fixed reason, stored as positive qty.
        const items = [];
        document.querySelectorAll(sectionSel + " input[data-sku]").forEach(inp => {
          if (inp.disabled) return;
          const v = parseInt((inp.value || "0").replace(/\D/g, ""), 10) || 0;
          if (v > 0) items.push({ skuId: inp.dataset.sku, kind: "ADJUSTMENT", qty: v, reason: STOK_AWAL_REASON });
        });
        return items;
      }
      function readTerjualLines(sectionSel) {
        // For closings/:date/terjual: each line is { skuId, terjual } (not qty!)
        const lines = [];
        document.querySelectorAll(sectionSel + " input[data-sku]").forEach(inp => {
          if (inp.disabled) return;
          const v = parseInt((inp.value || "0").replace(/\D/g, ""), 10) || 0;
          if (v > 0) lines.push({ skuId: inp.dataset.sku, terjual: v });
        });
        return lines;
      }

      document.getElementById("stok-awal-reset").addEventListener("click", resetStokAwal);
      document.getElementById("submit-btn").addEventListener("click", async () => {
        errEl.style.display = "none"; okEl.style.display = "none";
        if (!state.partnershipId) { showErr("Pilih partner dulu."); return; }
        if (!state.tenantId) { showErr("Tenant ID tidak ditemukan di partnership ini."); return; }
        const date = document.getElementById("date").value;
        if (!date) { showErr("Tanggal wajib."); return; }
        // Sections: items per (kind) for movements, lines per (terjual) for closing.
        const stokAwalItems = readStokAwalItems("#stok-awal-section");
        const titipItems = readSectionItems("#titip-section", "TITIP");
        const tarikItems = readSectionItems("#tarik-section", "TARIK");
        const terjualLines = readTerjualLines("#terjual-section");
        // Validate tarik vs sisa
        for (const it of tarikItems) {
          const sisa = state.sisaSistem[it.skuId] ?? 0;
          if (it.qty > sisa) { showErr(`Tarik SKU melebihi sisa sistem (${sisa}).`); return; }
        }
        if (stokAwalItems.length + titipItems.length + tarikItems.length + terjualLines.length === 0) {
          showErr("Minimal isi satu kolom (Stok Awal, Titip, Tarik, atau Terjual)."); return;
        }

        const btn = document.getElementById("submit-btn");
        btn.disabled = true; btn.textContent = "Menyimpan…";
        try {
          const r = await fetch(API + "/v1/ops/combined-save", {
            method: "POST",
            headers: { ...authH },
            body: JSON.stringify({
              partnershipId: state.partnershipId,
              tenantId: state.tenantId,
              movementDate: date,
              stokAwalItems,
              titipItems,
              tarikItems,
              terjualLines,
            }),
          });

          if (!r.ok) {
            const j = await r.json().catch(() => ({}));
            throw new Error(j?.error?.message || "Penyimpanan gagal.");
          }

          showOk(`Berhasil disimpan. Mengarahkan…`);
          setTimeout(() => { window.location.href = "/dashboard/brand/movements"; }, 1000);
        } catch (e) {
          showErr(e.message || "Tidak bisa konek ke server.");
        } finally {
          btn.disabled = false; btn.textContent = "Simpan Semua";
        }
      });

      init();
    </script>
  </body>
</html>
