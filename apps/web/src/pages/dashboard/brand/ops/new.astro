---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../../../../lib/api";
const title = `Catat Hari Ini — ${APP_NAME}`;
export const prerender = false;
export const ssr = false;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: radial-gradient(circle at top, #0b1220 0%, #030712 100%);
        background-attachment: fixed;
        color: #f1f5f9;
        font-family: 'Plus Jakarta Sans', ui-sans-serif, system-ui, -apple-system, sans-serif;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }
      a { color: #38bdf8; text-decoration: none; transition: color 0.15s ease; }
      a:hover { color: #7dd3fc; }
      
      .shell { max-width: 480px; margin: 0 auto; padding: 0 0 100px; }
      
      header.top {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; border-bottom: 2px solid #1e293b;
        position: sticky; top: 0; background: rgba(3, 7, 18, 0.85);
        backdrop-filter: blur(20px); z-index: 50;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
      }
      .brand-name { font-weight: 900; font-size: 16px; color: #f8fafc; letter-spacing: -0.02em; }
      .role-tag { font-size: 10px; padding: 3px 8px; border-radius: 999px; background: rgba(168, 85, 247, 0.1); color: #a855f7; border: 1.5px solid rgba(168, 85, 247, 0.2); font-weight: 800; letter-spacing: 0.06em; }
      .back { color: #94a3b8; font-size: 14px; font-weight: 700; display: inline-flex; align-items: center; gap: 4px; }
      .back:hover { color: #fbbf24; }
      
      main { padding: 20px; }
      
      /* RPG Card theme */
      .rpg-card {
        background: #0f172a;
        border: 2.5px solid #1e293b;
        border-radius: 16px;
        box-shadow: 4px 4px 0px 0px #020617;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
      }
      .rpg-card:hover {
        transform: translate(-1px, -1px);
        box-shadow: 5px 5px 0px 0px #020617;
        border-color: #334155;
      }

      /* Quest Panel Header */
      .quest-header-panel {
        background: linear-gradient(135deg, rgba(30, 41, 59, 0.7) 0%, rgba(15, 23, 42, 0.85) 100%);
        border: 2.5px solid #1e293b;
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 24px;
        box-shadow: 4px 4px 0px 0px #020617;
      }
      .quest-header-layout {
        display: flex;
        gap: 12px;
        align-items: center;
      }
      .quest-tracker-icon {
        font-size: 28px;
        background: rgba(245, 158, 11, 0.1);
        border: 2px solid rgba(245, 158, 11, 0.2);
        width: 54px;
        height: 54px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .quest-tracker-info {
        flex: 1;
      }
      .quest-tracker-title {
        font-size: 10px;
        font-weight: 800;
        color: #fbbf24;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .quest-tracker-subtitle {
        font-size: 16px;
        font-weight: 800;
        color: #ffffff;
      }
      
      label { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; font-size: 11px; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; }
      select, input {
        background: #090d16;
        border: 2px solid #1e293b;
        color: #f1f5f9;
        padding: 12px;
        border-radius: 12px;
        font-size: 15px;
        font-family: inherit;
        font-weight: 600;
        width: 100%;
        min-height: 48px;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
      }
      select:focus, input:focus {
        outline: none;
        border-color: #fbbf24;
        box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.15);
      }
      
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 20px;
        border-radius: 12px;
        font-weight: 800;
        border: 2.5px solid transparent;
        cursor: pointer;
        font-size: 15px;
        min-height: 48px;
      }
      .btn-primary {
        background: #fbbf24;
        color: #0b1220;
        border-color: #d97706;
        box-shadow: 3px 3px 0px 0px #78350f;
        transition: all 0.15s ease;
        width: 100%;
      }
      .btn-primary:hover:not(:disabled) {
        background: #f59e0b;
        transform: translate(-1px, -1px);
        box-shadow: 4px 4px 0px 0px #78350f;
      }
      .btn-primary:active:not(:disabled) {
        transform: translate(2px, 2px);
        box-shadow: 0px 0px 0px 0px #78350f;
      }
      .btn-primary:disabled { opacity: .5; cursor: not-allowed; }
      
      /* Quest Section styling */
      .section {
        background: rgba(15, 23, 42, 0.45);
        border: 2px solid #1e293b;
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 20px;
        box-shadow: 3px 3px 0px 0px #020617;
        transition: all 0.2s ease;
      }
      .section:hover {
        border-color: #334155;
      }
      .section h2 { margin: 0 0 4px; font-size: 15px; font-weight: 800; display: flex; align-items: center; gap: 8px; color: #ffffff; text-transform: uppercase; letter-spacing: 0.02em; }
      .section h2 .ic { font-size: 20px; }
      .section .hint { font-size: 12px; color: #94a3b8; margin: 0 0 12px; font-weight: 500; }
      
      /* Color themes per Quest */
      .section.stok-awal { border-color: rgba(167, 139, 250, 0.35); background: rgba(167, 139, 250, 0.03); }
      .section.stok-awal:hover { border-color: #a78bfa; }
      .section.stok-awal h2 { color: #c4b5fd; }
      .section.stok-awal h2 .ic { color: #a78bfa; }
      .section.stok-awal .badge { display: inline-block; background: rgba(167, 139, 250, 0.15); color: #c4b5fd; border: 1px solid rgba(167, 139, 250, 0.3); border-radius: 6px; font-size: 9px; padding: 2px 6px; font-weight: 800; letter-spacing: .06em; margin-left: 6px; vertical-align: middle; }
      
      .section.quest-titip { border-color: rgba(16, 185, 129, 0.35); background: rgba(16, 185, 129, 0.03); }
      .section.quest-titip:hover { border-color: #10b981; }
      .section.quest-titip h2 { color: #a7f3d0; }
      .section.quest-titip h2 .ic { color: #10b981; }
      
      .section.quest-tarik { border-color: rgba(251, 113, 133, 0.35); background: rgba(251, 113, 133, 0.03); }
      .section.quest-tarik:hover { border-color: #fb7185; }
      .section.quest-tarik h2 { color: #fecdd3; }
      .section.quest-tarik h2 .ic { color: #fb7185; }
      
      .section.quest-terjual { border-color: rgba(245, 158, 11, 0.35); background: rgba(245, 158, 11, 0.03); }
      .section.quest-terjual:hover { border-color: #f59e0b; }
      .section.quest-terjual h2 { color: #fde68a; }
      .section.quest-terjual h2 .ic { color: #f59e0b; }
      
      .sk-row, :global(.sk-row) { display: grid; grid-template-columns: 1fr 140px; gap: 10px; align-items: center; padding: 10px 0; border-bottom: 1.5px solid #1e293b; }
      :global(.sk-row:last-child) { border-bottom: none; }
      :global(.sk-label .code) { color: #fbbf24; font-weight: 900; margin-right: 6px; font-size: 15px; }
      :global(.sk-label .name) { color: #f1f5f9; font-weight: 700; font-size: 14px; }
      :global(.sk-label .meta) { color: #94a3b8; font-size: 11px; font-weight: 600; margin-top: 2px; }
      :global(.sk-row input) { background: #090d16; border: 1.5px solid #1e293b; border-radius: 8px; padding: 8px; text-align: center; font-size: 15px; min-height: 40px; font-weight: 700; }
      :global(.sk-row input:focus) { border-color: #fbbf24; }
      
      :global(.stepper) { display: grid; grid-template-columns: 38px 1fr 38px; gap: 4px; align-items: stretch; }
      :global(.stepper .step-btn) { background: #090d16; border: 1.5px solid #1e293b; color: #f1f5f9; border-radius: 8px; font-size: 18px; font-weight: 800; min-height: 40px; cursor: pointer; padding: 0; line-height: 1; transition: all 0.1s ease; }
      :global(.stepper .step-btn:hover:not(:disabled)) { background: #1e293b; border-color: #fbbf24; color: #fbbf24; }
      :global(.stepper .step-btn:active:not(:disabled)) { transform: scale(0.92); }
      :global(.stepper .step-btn:disabled) { opacity: .3; cursor: not-allowed; }
      :global(.stepper input) { width: 100%; }
      :global(.sk-row .set-once-hint) { color: #a78bfa; font-size: 11px; font-weight: 600; }
      
      .empty { padding: 20px; text-align: center; color: #64748b; font-size: 13px; font-weight: 600; background: rgba(15, 23, 42, 0.2); border-radius: 12px; border: 1.5px dashed #1e293b; }
      .err { background: rgba(251, 113, 133, 0.12); color: #fb7185; border: 2px solid rgba(251, 113, 133, 0.3); padding: 12px; border-radius: 12px; font-size: 13px; margin-bottom: 16px; font-weight: 700; }
      .ok { background: rgba(52, 211, 153, 0.12); color: #34d399; border: 2px solid rgba(52, 211, 153, 0.3); padding: 12px; border-radius: 12px; font-size: 13px; margin-bottom: 16px; font-weight: 700; }
      .status { padding: 12px; border-radius: 12px; font-size: 13px; margin-bottom: 16px; border: 1.5px solid #1e293b; font-weight: 700; }
      .diag { display: block; }
      
      /* Summary Card */
      .summary-card { background: linear-gradient(135deg, #0f172a 0%, #090d16 100%); border: 2.5px dashed #334155; border-radius: 16px; padding: 16px; margin-bottom: 20px; }
      .summary-card .partner { font-weight: 800; margin-bottom: 12px; font-size: 13px; color: #fbbf24; text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; gap: 6px; }
      .summary-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
      .summary-card .label { font-size: 9px; color: #64748b; text-transform: uppercase; letter-spacing: .08em; font-weight: 800; }
      .summary-card .value { font-size: 24px; font-weight: 900; color: #f1f5f9; line-height: 1.2; }
      .summary-card .sub { font-size: 11px; color: #94a3b8; margin-top: 4px; font-weight: 600; }
      .summary-card .stok-awal-row { grid-column: 1 / -1; padding: 10px 0; border-bottom: 1.5px solid #1e293b; margin-bottom: 6px; display: flex; justify-content: space-between; align-items: center; }
      .summary-card .stok-awal-row .label { color: #a78bfa; }
      .summary-card .stok-awal-row .value { color: #a78bfa; font-size: 22px; }
      
      .section-head { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 4px; }
      .section-head h2 { margin: 0; }
      .btn-ghost { background: transparent; border: 1.5px solid #3b4252; color: #a78bfa; padding: 6px 12px; border-radius: 8px; font-size: 11px; font-weight: 700; cursor: pointer; min-height: 30px; transition: all 0.15s ease; text-transform: uppercase; letter-spacing: 0.04em; }
      .btn-ghost:hover { background: rgba(167, 139, 250, 0.1); border-color: #a78bfa; color: #c4b5fd; }
      .btn-ghost:active { transform: scale(0.95); }
      .btn-ghost:disabled { opacity: .4; cursor: not-allowed; }
      
      /* Skeletons */
      :global(.skeleton) { background: linear-gradient(90deg, #1e293b 0%, #2d3748 50%, #1e293b 100%); background-size: 200% 100%; animation: sk-shimmer 1.2s linear infinite; border-radius: 6px; }
      @keyframes sk-shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
      :global(.skeleton-row) { display: grid; grid-template-columns: 1fr 140px; gap: 10px; align-items: center; padding: 10px 0; border-bottom: 1.5px solid #1e293b; }
      :global(.skeleton-row:last-child) { border-bottom: none; }
      :global(.skeleton-block) { height: 14px; }
      :global(.skeleton-stepper) { height: 36px; }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="top">
        <a class="back" href="/dashboard/brand">← Kembali</a>
        <h1 class="brand-name">Catat Hari Ini</h1>
        <span class="role-tag">OPS QUEST</span>
      </header>
      <main>
        <div id="err" class="err" style="display:none"></div>
        <div id="ok" class="ok" style="display:none"></div>

        <!-- Quest Tracker Header Panel -->
        <div class="quest-header-panel">
          <div class="quest-header-layout">
            <div class="quest-tracker-icon">⚡</div>
            <div class="quest-tracker-info">
              <span class="quest-tracker-title">Guild Mission Tracker</span>
              <div class="quest-tracker-subtitle">Lengkapi Laporan Harian</div>
            </div>
          </div>
        </div>

        <label>
          <span class="lbl">Tanggal Quest (Hari)</span>
          <input id="date" type="date" required />
        </label>
        <label>
          <span class="lbl">Aliansi Partner (Cafe)</span>
          <select id="partnership" disabled>
            <option value="">— Memuat partner… —</option>
          </select>
        </label>
        <div id="ops-summary" class="summary-card" style="display:none">
          <div class="partner" id="ops-summary-partner">—</div>
          <div class="summary-grid">
            <div class="stok-awal-row"><div class="label">Stok Awal Aliansi</div><div class="value" id="ops-summary-stok-awal">0</div></div>
            <div><div class="label">Titip (Logistik)</div><div class="value" id="ops-summary-titip">0</div></div>
            <div><div class="label">Tarik (Retur)</div><div class="value" id="ops-summary-tarik">0</div></div>
            <div><div class="label">Terjual (Sales)</div><div class="value" id="ops-summary-terjual">0</div></div>
            <div><div class="label">Sisa Rak Sistem</div><div class="value" id="ops-summary-sisa">0</div></div>
          </div>
        </div>

        <!-- Quest 1: Stok Awal -->
        <div class="section stok-awal">
          <div class="section-head">
            <h2><span class="ic">🌱</span> Quest: Inisiasi Labirin (Stok Awal)<span class="badge">SEKALI</span></h2>
            <button type="button" id="stok-awal-reset" class="btn-ghost" style="display:none" aria-label="Reset Stok Awal">↺ Reset</button>
          </div>
          <p class="hint">Persediaan logistik pertama yang sudah ada di partner sebelum mulai menggunakan sistem. Cukup diisi sekali di awal aliansi.</p>
          <div id="stok-awal-section"><div class="empty">Pilih partner aliansi dulu.</div></div>
        </div>

        <!-- Quest 2: Titip -->
        <div class="section quest-titip">
          <h2><span class="ic">📦</span> Quest: Pasok Logistik (Titip)</h2>
          <p class="hint">Jumlah persediaan SKU baru yang Anda kirimkan ke partner aliansi hari ini.</p>
          <div id="titip-section"><div class="empty">Pilih partner aliansi dulu.</div></div>
        </div>

        <!-- Quest 3: Tarik -->
        <div class="section quest-tarik">
          <h2><span class="ic">↩️</span> Quest: Tarik Kembali (Tarik)</h2>
          <p class="hint">Tarik sisa stok yang tidak terjual kembali ke inventori Anda.</p>
          <div id="tarik-section"><div class="empty">Pilih partner aliansi dulu.</div></div>
        </div>

        <!-- Quest 4: Terjual -->
        <div class="section quest-terjual">
          <h2><span class="ic">🪙</span> Quest: Catatan Kemenangan (Terjual)</h2>
          <p class="hint">Berapa cup/pack produk yang terjual hari ini. Digunakan untuk perhitungan koin mingguan.</p>
          <div id="terjual-section"><div class="empty">Pilih partner aliansi dulu.</div></div>
        </div>

        <button id="submit-btn" class="btn btn-primary" type="button" disabled>Selesaikan Misi (Simpan Semua)</button>
        <div id="ops-status" class="status" style="display:none"></div>
      </main>
    </div>
    <script define:vars={{ API_BASE_URL }}>
      const API = API_BASE_URL.replace(/\/$/, "");
      const tok = localStorage.getItem("kongsian_session");
      if (!tok) { window.location.href = "/login"; }
      const authH = { Authorization: `Bearer ${tok}`, "Content-Type": "application/json" };
      async function jget(p) { return (await fetch(API+p, { headers: authH })).json().catch(()=>({})); }

      const errEl = document.getElementById("err");
      const okEl = document.getElementById("ok");
      const showErr = m => { errEl.textContent = m; errEl.style.display="block"; okEl.style.display="none"; window.scrollTo({ top: 0, behavior: "smooth" }); };
      const showOk = m => { okEl.textContent = m; okEl.style.display="block"; errEl.style.display="none"; };
      function fmtRp(n) { return new Intl.NumberFormat("id-ID", { style:"currency", currency:"IDR", maximumFractionDigits:0 }).format(n); }

      const state = { brandId: null, partnershipId: null, tenantId: null, skus: [], sisaSistem: {}, partnerships: [], stokAwal: {} };
      const STOK_AWAL_REASON = "Stok awal partnership";
      document.getElementById("date").value = new Date().toISOString().slice(0, 10);

      // Race guard: bump this on every partnership/date change. A response whose
      // sequence number is < the current one is stale (user picked a different
      // option before the previous fetch finished) and must NOT touch state.
      let loadSeq = 0;

      function renderSkeletons() {
        const skel = `
          <div class="skeleton-row">
            <div><div class="skeleton skeleton-block" style="width:55%"></div><div class="skeleton skeleton-block" style="width:35%; margin-top:6px"></div></div>
            <div class="skeleton skeleton-stepper"></div>
          </div>
          <div class="skeleton-row">
            <div><div class="skeleton skeleton-block" style="width:50%"></div><div class="skeleton skeleton-block" style="width:30%; margin-top:6px"></div></div>
            <div class="skeleton skeleton-stepper"></div>
          </div>
          <div class="skeleton-row">
            <div><div class="skeleton skeleton-block" style="width:60%"></div><div class="skeleton skeleton-block" style="width:40%; margin-top:6px"></div></div>
            <div class="skeleton skeleton-stepper"></div>
          </div>
        `;
        for (const id of ["stok-awal-section","titip-section","tarik-section","terjual-section"]) {
          document.getElementById(id).innerHTML = skel;
        }
      }

      function attachQtyStrip(sel) {
        // Strip non-digits on the hidden number input + wire minus/plus buttons.
        document.querySelectorAll(sel + " .stepper").forEach(stepper => {
          const inp = stepper.querySelector("input[data-sku]");
          const minus = stepper.querySelector(".step-btn.minus");
          const plus = stepper.querySelector(".step-btn.plus");
          if (!inp) return;
          const clamp = () => {
            const max = inp.hasAttribute("max") ? parseInt(inp.getAttribute("max"), 10) : null;
            let v = parseInt((inp.value || "0").replace(/\D/g, ""), 10) || 0;
            if (v < 0) v = 0;
            if (max != null && v > max) v = max;
            if (String(v) !== inp.value) inp.value = String(v);
            if (minus) minus.disabled = v <= 0;
            if (plus) plus.disabled = (max != null && v >= max);
            try { updateSummary(); } catch (e) {}
          };
          inp.addEventListener("input", clamp);
          if (minus) minus.addEventListener("click", () => { if (inp.disabled) return; inp.value = String(Math.max(0, (parseInt((inp.value||"0").replace(/\D/g,""),10)||0) - 1)); clamp(); });
          if (plus)  plus.addEventListener("click", () => { if (inp.disabled) return; inp.value = String(((parseInt((inp.value||"0").replace(/\D/g,""),10)||0) + 1)); clamp(); });
          clamp();
        });
      }

      function skuRow(s, kind, opts = {}) {
        const max = opts.max != null ? `max="${opts.max}"` : "";
        const dis = opts.disabled ? "disabled" : "";
        const val = opts.value != null && opts.value !== 0 ? `value="${opts.value}"` : "";
        const hint = opts.hint ? `<div class="meta">${opts.hint}</div>` : `<div class="meta">${fmtRp(s.priceIdr)}</div>`;
        return `
          <div class="sk-row">
            <div class="sk-label">
              <div><span class="code">${s.code}</span><span class="name">${s.name}</span></div>
              ${hint}
            </div>
            <div class="stepper">
              <button type="button" class="step-btn minus" aria-label="Kurangi" ${dis}>−</button>
              <input type="number" min="0" ${max} ${val} step="1" data-sku="${s.id}" data-kind="${kind}" placeholder="0" inputmode="numeric" ${dis} />
              <button type="button" class="step-btn plus" aria-label="Tambah" ${dis}>+</button>
            </div>
          </div>
        `;
      }

      function renderSections() {
        const disabled = !state.partnershipId || state.skus.length === 0;
        document.getElementById("submit-btn").disabled = disabled;
        if (!state.partnershipId) {
          for (const id of ["stok-awal-section","titip-section","tarik-section","terjual-section"]) {
            document.getElementById(id).innerHTML = `<div class="empty">Pilih partner dulu.</div>`;
          }
          return;
        }
        if (state.skus.length === 0) {
          for (const id of ["stok-awal-section","titip-section","tarik-section","terjual-section"]) {
            document.getElementById(id).innerHTML = `<div class="empty">Belum ada SKU.</div>`;
          }
          return;
        }
        document.getElementById("stok-awal-section").innerHTML = state.skus.map(s => {
          const existing = state.stokAwal[s.id] ?? 0;
          const hint = existing > 0
            ? `<div class="meta set-once-hint">✓ Sudah diisi: ${existing} (edit jika perlu)</div>`
            : `<div class="meta">${fmtRp(s.priceIdr)}</div>`;
          return skuRow(s, "stok-awal", { hint, value: existing > 0 ? existing : undefined });
        }).join("");
        document.getElementById("titip-section").innerHTML = state.skus.map(s => skuRow(s, "titip")).join("");
        document.getElementById("tarik-section").innerHTML = state.skus.map(s => {
          const sisa = state.sisaSistem[s.id] ?? 0;
          return skuRow(s, "tarik", { max: sisa, disabled: sisa <= 0, hint: `Sisa: ${sisa}` });
        }).join("");
        document.getElementById("terjual-section").innerHTML = state.skus.map(s => skuRow(s, "terjual")).join("");
        attachQtyStrip("#stok-awal-section"); attachQtyStrip("#titip-section"); attachQtyStrip("#tarik-section"); attachQtyStrip("#terjual-section");
      }

      function updateStokAwalResetButton() {
        const btn = document.getElementById("stok-awal-reset");
        if (!btn) return;
        const hasSaved = Object.values(state.stokAwal || {}).some((v) => (v || 0) > 0);
        btn.style.display = (state.partnershipId && hasSaved) ? "inline-block" : "none";
      }

      async function resetStokAwal() {
        if (!state.partnershipId) return;
        const date = document.getElementById("date").value;
        const savedCount = Object.values(state.stokAwal || {}).filter((v) => (v || 0) > 0).length;
        if (savedCount === 0) return;
        const ok = window.confirm(
          `Hapus ${savedCount} entri Stok Awal yang tersimpan untuk tanggal ${date}?\n\n` +
          `Tindakan ini akan mempengaruhi Sisa Sistem. Tidak bisa di-undo (kecuali kamu input ulang).`
        );
        if (!ok) return;
        const btn = document.getElementById("stok-awal-reset");
        btn.disabled = true; btn.textContent = "Menghapus…";
        try {
          const r = await fetch(API + "/v1/movements", {
            method: "DELETE",
            headers: { ...authH },
            body: JSON.stringify({
              partnershipId: state.partnershipId,
              movementDate: date,
              reason: STOK_AWAL_REASON,
            }),
          });
          if (!r.ok) { const j = await r.json().catch(()=>({})); throw new Error(j?.error?.code || "HTTP " + r.status); }
          const j = await r.json().catch(() => ({}));
          const deletedCount = j?.data?.count ?? savedCount;
          showOk(`Stok Awal dihapus (${deletedCount} baris). Menyegarkan…`);
          // Hard reload to guarantee a fresh state from the server. In-place state
          // updates were leaving stale `Sisa sistem` values visible when the
          // user expected the persisted stock to drop to 0 immediately.
          setTimeout(() => { window.location.reload(); }, 700);
        } catch (e) {
          showErr("Reset gagal: " + (e.message || e));
          btn.disabled = false; btn.textContent = "↺ Reset";
        }
      }

      function updateSummary() {
        const box = document.getElementById("ops-summary");
        const partnerName = document.getElementById("partnership")?.selectedOptions?.[0]?.text?.trim() || "(partner)";
        const stokAwal = [...document.querySelectorAll("#stok-awal-section input[data-sku]")].reduce((a, i) => a + (parseInt(i.value || "0", 10) || 0), 0);
        const titip = [...document.querySelectorAll("#titip-section input[data-sku]")].reduce((a, i) => a + (parseInt(i.value || "0", 10) || 0), 0);
        const tarik = [...document.querySelectorAll("#tarik-section input[data-sku]")].reduce((a, i) => a + (parseInt(i.value || "0", 10) || 0), 0);
        const terjual = [...document.querySelectorAll("#terjual-section input[data-sku]")].reduce((a, i) => a + (parseInt(i.value || "0", 10) || 0), 0);
        const sisa = Object.values(state.sisaSistem || {}).reduce((a, v) => a + (v || 0), 0);
        document.getElementById("ops-summary-partner").textContent = partnerName;
        document.getElementById("ops-summary-stok-awal").textContent = stokAwal.toLocaleString("id-ID");
        document.getElementById("ops-summary-titip").textContent = titip.toLocaleString("id-ID");
        document.getElementById("ops-summary-tarik").textContent = tarik.toLocaleString("id-ID");
        document.getElementById("ops-summary-terjual").textContent = terjual.toLocaleString("id-ID");
        document.getElementById("ops-summary-sisa").textContent = sisa.toLocaleString("id-ID");
        box.style.display = "block";
      }

      async function loadPartnershipScopedData() {
        if (!state.partnershipId) return;
        const seq = ++loadSeq;        // invalidate any in-flight previous load
        renderSkeletons();             // show shimmer immediately so the user sees the page is working
        const date = document.getElementById("date").value;
        const r = await jget(`/v1/ops/partnership-data?partnershipId=${state.partnershipId}&date=${date}`);
        if (seq !== loadSeq) return; // stale

        state.sisaSistem = {};
        state.stokAwal = {};
        if (r.ok) {
          const { sisaSistem, stokAwal } = r.data || {};
          for (const row of sisaSistem || []) {
            state.sisaSistem[row.skuId] = row.sisa ?? 0;
          }
          for (const row of stokAwal || []) {
            state.stokAwal[row.skuId] = row.qty ?? 0;
          }
        }
        updateStokAwalResetButton();
        renderSections();
        updateSummary();
      }

      async function init() {
        const initData = await jget("/v1/ops/init");
        if (!initData.ok) {
          if (initData.error?.code === "VERIFICATION_PENDING") {
            window.location.href = "/login?registered=1";
            return;
          }
          window.location.href = "/dashboard/brand";
          return;
        }

        const { brandId, skus, partnerships } = initData.data;
        state.brandId = brandId;
        state.skus = skus || [];
        state.partnerships = partnerships || [];

        const sel = document.getElementById("partnership");
        if (state.partnerships.length === 0) {
          sel.innerHTML = `<option value="">— Belum ada partner aktif —</option>`;
        } else {
          sel.innerHTML = `<option value="">— Pilih partner —</option>` +
            state.partnerships.map(p => `<option value="${p.id}" data-tenant="${p.tenant?.id || ""}">${p.tenant?.name || "(tenant?)"}</option>`).join("");
        }
        sel.disabled = false;

        sel.addEventListener("change", async (e) => {
          const opt = e.target.selectedOptions[0];
          state.partnershipId = e.target.value || null;
          state.tenantId = opt ? opt.dataset.tenant : null;
          renderSections();
          updateSummary();
          if (!state.partnershipId) return;
          await loadPartnershipScopedData();
        });
        document.getElementById("date").addEventListener("change", async () => {
          if (state.partnershipId) { await loadPartnershipScopedData(); }
        });
      }

      function readSectionItems(sectionSel, kind) {
        // For movements/batch: each item is { skuId, kind, qty }
        const items = [];
        document.querySelectorAll(sectionSel + " input[data-sku]").forEach(inp => {
          if (inp.disabled) return;
          const v = parseInt((inp.value || "0").replace(/\D/g, ""), 10) || 0;
          if (v > 0) items.push({ skuId: inp.dataset.sku, kind, qty: v });
        });
        return items;
      }
      function readStokAwalItems(sectionSel) {
        // Stok Awal is an ADJUSTMENT with a fixed reason, stored as positive qty.
        const items = [];
        document.querySelectorAll(sectionSel + " input[data-sku]").forEach(inp => {
          if (inp.disabled) return;
          const v = parseInt((inp.value || "0").replace(/\D/g, ""), 10) || 0;
          if (v > 0) items.push({ skuId: inp.dataset.sku, kind: "ADJUSTMENT", qty: v, reason: STOK_AWAL_REASON });
        });
        return items;
      }
      function readTerjualLines(sectionSel) {
        // For closings/:date/terjual: each line is { skuId, terjual } (not qty!)
        const lines = [];
        document.querySelectorAll(sectionSel + " input[data-sku]").forEach(inp => {
          if (inp.disabled) return;
          const v = parseInt((inp.value || "0").replace(/\D/g, ""), 10) || 0;
          if (v > 0) lines.push({ skuId: inp.dataset.sku, terjual: v });
        });
        return lines;
      }

      document.getElementById("stok-awal-reset").addEventListener("click", resetStokAwal);
      document.getElementById("submit-btn").addEventListener("click", async () => {
        errEl.style.display = "none"; okEl.style.display = "none";
        if (!state.partnershipId) { showErr("Pilih partner dulu."); return; }
        if (!state.tenantId) { showErr("Tenant ID tidak ditemukan di partnership ini."); return; }
        const date = document.getElementById("date").value;
        if (!date) { showErr("Tanggal wajib."); return; }
        // Sections: items per (kind) for movements, lines per (terjual) for closing.
        const stokAwalItems = readStokAwalItems("#stok-awal-section");
        const titipItems = readSectionItems("#titip-section", "TITIP");
        const tarikItems = readSectionItems("#tarik-section", "TARIK");
        const terjualLines = readTerjualLines("#terjual-section");
        // Validate tarik vs sisa
        for (const it of tarikItems) {
          const sisa = state.sisaSistem[it.skuId] ?? 0;
          if (it.qty > sisa) { showErr(`Tarik SKU melebihi sisa sistem (${sisa}).`); return; }
        }
        if (stokAwalItems.length + titipItems.length + tarikItems.length + terjualLines.length === 0) {
          showErr("Minimal isi satu kolom (Stok Awal, Titip, Tarik, atau Terjual)."); return;
        }

        const btn = document.getElementById("submit-btn");
        btn.disabled = true; btn.textContent = "Menyimpan…";
        try {
          const r = await fetch(API + "/v1/ops/combined-save", {
            method: "POST",
            headers: { ...authH },
            body: JSON.stringify({
              partnershipId: state.partnershipId,
              tenantId: state.tenantId,
              movementDate: date,
              stokAwalItems,
              titipItems,
              tarikItems,
              terjualLines,
            }),
          });

          if (!r.ok) {
            const j = await r.json().catch(() => ({}));
            throw new Error(j?.error?.message || "Penyimpanan gagal.");
          }

          showOk(`Berhasil disimpan. Mengarahkan…`);
          setTimeout(() => { window.location.href = "/dashboard/brand/movements"; }, 1000);
        } catch (e) {
          showErr(e.message || "Tidak bisa konek ke server.");
        } finally {
          btn.disabled = false; btn.textContent = "Simpan Semua";
        }
      });

      init();
    </script>
  </body>
</html>
