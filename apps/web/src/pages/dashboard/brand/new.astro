---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../../../lib/api";
import "../../../styles/global.css";
const title = `Brand Baru — ${APP_NAME}`;
---
<!doctype html>
<html lang="id">
  <head>
    <script src="/i18n-helper.js" is:inline></script>
    <script src="/theme-helper.js" is:inline></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: #0b1220; color: #f1f5f9;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        line-height: 1.5; -webkit-font-smoothing: antialiased;
      }
      a { color: #38bdf8; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .shell { max-width: 480px; margin: 0 auto; padding: 0 0 80px; }
      header.top {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; border-bottom: 1px solid #1e293b;
        position: sticky; top: 0; background: rgba(11, 18, 32, .92);
        backdrop-filter: blur(6px); z-index: 5;
      }
      .brand-name { font-weight: 700; font-size: 15px; }
      .back { font-size: 13px; color: #94a3b8; }
      main { padding: 20px; }
      h1 { font-size: 24px; margin: 0 0 6px; letter-spacing: -0.01em; }
      p.lead { color: #94a3b8; font-size: 14px; margin: 0 0 24px; }
      label { display: block; margin-bottom: 16px; }
      .lbl { display: block; font-size: 13px; color: #94a3b8; margin-bottom: 6px; }
      input[type=text] {
        width: 100%; padding: 12px 14px; font-size: 16px;
        background: #0f172a; border: 1px solid #1e293b; border-radius: 10px;
        color: #f1f5f9; font-family: inherit;
      }
      input[type=text]:focus { outline: none; border-color: #fbbf24; }
      .slug-hint {
        font-size: 12px; color: #64748b; margin-top: 6px;
        font-family: ui-monospace, SFMono-Regular, monospace;
      }
      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        padding: 14px 20px; border-radius: 10px; font-weight: 600; font-size: 16px;
        border: 1px solid transparent; cursor: pointer; text-decoration: none;
      }
      .btn-primary { background: #fbbf24; color: #0b1220; }
      .btn-primary:hover { background: #f59e0b; }
      .btn-primary:disabled { background: #1e293b; color: #64748b; cursor: not-allowed; }
      .btn-ghost { background: transparent; color: #f1f5f9; border-color: #1e293b; }
      .msg { padding: 12px; border-radius: 10px; font-size: 14px; margin-top: 12px; display: none; }
      .msg.err { display: block; background: rgba(251, 113, 133, .12); color: #fb7185; border: 1px solid rgba(251, 113, 133, .3); }
      .msg.info { display: block; background: rgba(56, 189, 248, .12); color: #38bdf8; border: 1px solid rgba(56, 189, 248, .3); }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="top">
        <div class="brand-name">{APP_NAME}</div>
        <div style="display:flex;align-items:center;gap:10px">
          <button id="theme-toggle" class="theme-toggle-btn">☕</button>
          <a href="/dashboard/brand" class="back">← Kembali</a>
        </div>
      </header>
      <main>
        <h1>Brand baru</h1>
        <p class="lead">Bikin brand pertamamu. Kamu bisa ganti nama dan deskripsi nanti.</p>

        <form id="brand-form">
          <label>
            <span class="lbl">Nama brand</span>
            <input id="name" name="name" type="text" maxlength="80"
                   placeholder="Contoh: Hanniel Oat" required autofocus />
            <div id="slug-hint" class="slug-hint"></div>
          </label>

          <button class="btn btn-primary" type="submit" id="submit-btn" style="width:100%">
            Buat brand
          </button>
          <div id="msg" class="msg"></div>
        </form>
      </main>
    </div>

    <script define:vars={{ API_BASE_URL }}>
      const API = API_BASE_URL.replace(/\/$/, "");
      const tok = localStorage.getItem("kongsian_session");
      if (!tok) { window.location.href = "/login"; }

      // Theme Toggle logic
      const toggleBtn = document.getElementById("theme-toggle");
      if (toggleBtn) {
        const updateThemeBtnText = (theme) => {
          toggleBtn.innerHTML = theme === "playful" ? "🌾" : "☕";
        };
        updateThemeBtnText(window.OatletTheme.getTheme());
        window.addEventListener("oatlet:themechange", (e) => {
          updateThemeBtnText(e.detail.theme);
        });
        toggleBtn.addEventListener("click", () => {
          window.OatletTheme.toggleTheme();
        });
      }

      // Slug auto-derive: lowercase, non-allowed chars → '-', collapse runs.
      // Visible so the user can see what the URL will be.
      function slugify(s) {
        return s
          .toLowerCase()
          .normalize("NFKD").replace(/[\u0300-\u036f]/g, "") // strip diacritics
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "")
          .slice(0, 40);
      }

      const $ = (s) => document.querySelector(s);
      const nameEl = $("#name");
      const slugHint = $("#slug-hint");
      const submitBtn = $("#submit-btn");
      const msgEl = $("#msg");

      nameEl.addEventListener("input", () => {
        const slug = slugify(nameEl.value);
        slugHint.textContent = slug ? `Slug: oatlet.com/${slug}` : "";
        submitBtn.disabled = !slug || slug.length < 2;
      });

      function showErr(text) { msgEl.className = "msg err"; msgEl.textContent = text; }
      function clearMsg() { msgEl.className = "msg"; msgEl.textContent = ""; }

      $("#brand-form").addEventListener("submit", async (e) => {
        e.preventDefault();
        clearMsg();
        const name = nameEl.value.trim();
        if (name.length < 2) { showErr("Nama brand minimal 2 karakter."); return; }
        const slug = slugify(name);
        if (slug.length < 2) { showErr("Nama brand harus punya minimal satu huruf/angka (jadi slug valid)."); return; }

        submitBtn.disabled = true;
        submitBtn.textContent = "Membuat…";
        try {
          const r = await fetch(`${API}/v1/brands`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Authorization: `Bearer ${tok}`,
            },
            body: JSON.stringify({ name, slug }),
          });
          const j = await r.json().catch(() => ({}));
          if (!r.ok || !j.ok) {
            const code = j?.error?.code;
            if (code === "INVALID_INPUT") {
              const fe = j?.error?.issues?.fieldErrors ?? {};
              const first = Object.values(fe).flat()[0] || "Input tidak valid.";
              showErr(first);
            } else if (code === "SLUG_TAKEN") {
              showErr("Slug itu sudah dipakai brand lain. Coba nama lain.");
            } else {
              showErr(`Gagal: ${code || r.status || "?"}`);
            }
            submitBtn.disabled = false;
            submitBtn.textContent = "Buat brand";
            return;
          }
          // Success — go to the dashboard.
          window.location.href = "/dashboard/brand";
        } catch (err) {
          showErr("Gagal konek ke server. Coba lagi.");
          submitBtn.disabled = false;
          submitBtn.textContent = "Buat brand";
        }
      });
    </script>
  </body>
</html>
