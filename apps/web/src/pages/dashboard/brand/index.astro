    <script define:vars={{ API_BASE_URL }}>
      window.__KONGSIAN_API__ = API_BASE_URL;
      const API = API_BASE_URL.replace(/\/$/, "");
      const tok = localStorage.getItem("kongsian_session");
      if (!tok) { window.location.href = "/login"; }
      const authH = { Authorization: `Bearer ${tok}`, "Content-Type": "application/json" };

      let globalData = null;

      async function jget(path) {
        const r = await fetch(API + path, { headers: authH });
        return r.json().catch(() => ({}));
      }

      document.getElementById("logout").addEventListener("click", async () => {
        try { await fetch(API + "/v1/auth/logout", { method: "POST", headers: { Authorization: `Bearer ${tok}` } }); } catch {}
        localStorage.removeItem("kongsian_session");
        window.location.href = "/login";
      });

      window.togglePartnerCard = function(partnerId) {
        const card = document.querySelector(`.sisa-card[data-partner-id="${partnerId}"]`);
        if (card) {
          card.classList.toggle("collapsed");
        }
      };

      window.toggleSection = function(sectionId) {
        const sec = document.getElementById(sectionId);
        if (sec) {
          sec.classList.toggle("collapsed");
        }
      };

      window.focusCafeCard = function(partnerId) {
        const card = document.querySelector(`.sisa-card[data-partner-id="${partnerId}"]`);
        if (card) {
          card.classList.remove("collapsed");
          card.scrollIntoView({ behavior: "smooth", block: "center" });
          
          card.classList.add("map-highlight");
          setTimeout(() => {
            card.classList.remove("map-highlight");
          }, 2000);
        }
      };

      // RPG Hero Classes
      const heroClasses = {
        "🧙‍♂️": { title: "Coffee Sorcerer", clsName: "class-sorcerer" },
        "🧑‍🍳": { title: "Pastry Knight", clsName: "class-knight" },
        "👩‍🌾": { title: "Juice Druid", clsName: "class-druid" },
        "🧋": { title: "Boba Cleric", clsName: "class-cleric" },
        "🧇": { title: "Waffle Rogue", clsName: "class-rogue" }
      };

      window.toggleAvatarSelect = function() {
        const grid = document.getElementById("avatar-select-grid");
        grid.style.display = grid.style.display === "none" ? "flex" : "none";
      };

      window.selectAvatar = function(emoji, title) {
        localStorage.setItem("kongsian_hero_emoji", emoji);
        localStorage.setItem("kongsian_hero_title", title);
        
        document.getElementById("avatar-sprite").textContent = emoji;
        document.getElementById("char-title").textContent = title;
        
        const card = document.getElementById("rpg-profile-card");
        if (card) {
          card.className = "rpg-profile rpg-card"; // reset
          const classData = heroClasses[emoji];
          if (classData) {
            card.classList.add(classData.clsName);
          }
        }
        
        document.getElementById("avatar-select-grid").style.display = "none";
      };

      function renderSisaList(searchQuery = "", filterType = "all") {
        const sisaEl = document.getElementById("sisa-list");
        if (!globalData) return;

        const { skus, partnerships, sisaSistem } = globalData;
        const active = (partnerships || []).filter(p => p.status === "ACTIVE");

        if (active.length === 0) {
          sisaEl.innerHTML = `<div class="empty">${window.t('Belum ada partner aktif.')}</div>`;
          return;
        }

        const cards = [];
        const query = searchQuery.toLowerCase().trim();

        for (const p of active) {
          const partnerName = (p.tenant?.name || "").toLowerCase();
          const psSisa = (sisaSistem || []).filter(row => row.partnershipId === p.id);

          // Map and filter rows (pouch items)
          const resolvedRows = psSisa.map(row => {
            const sku = skus.find(s => s.id === row.skuId);
            if (!sku) return null;
            const qty = row.sisa ?? 0;
            const cls = qty <= 0 ? "zero" : qty < 5 ? "low" : "ok";

            // Status filter logic
            if (filterType === "low" && qty >= 5) return null;
            if (filterType === "empty" && qty > 0) return null;

            // Search text match
            if (query) {
              const skuCode = (sku.code || "").toLowerCase();
              const skuName = (sku.name || "").toLowerCase();
              if (!partnerName.includes(query) && !skuCode.includes(query) && !skuName.includes(query)) {
                return null;
              }
            }

            return { row, sku, qty, cls };
          }).filter(Boolean);

          // Skip card entirely if:
          // 1. Search query is provided and neither partner name nor any of its rows match
          if (query && resolvedRows.length === 0 && !partnerName.includes(query)) {
            continue;
          }

          // 2. Status filter (low/empty) is active and we filtered out all rows
          if (filterType !== "all" && resolvedRows.length === 0) {
            continue;
          }

          if (psSisa.length === 0) {
            if (filterType === "all" && (!query || partnerName.includes(query))) {
              cards.push(`
                <div class="sisa-card rpg-card" data-partner-id="${p.id}">
                  <div class="sisa-header" onclick="togglePartnerCard('${p.id}')">
                    <div class="sisa-header-left">
                      <span class="partner-icon">🏪</span>
                      <span class="partner-name">${p.tenant?.name || "(tenant?)"}</span>
                    </div>
                    <span class="sisa-toggle-icon">▶</span>
                  </div>
                  <div class="loading" style="padding:12px 0; font-size:12px;">${window.t('Belum ada stok terdaftar.')}</div>
                </div>
              `);
            }
            continue;
          }

          if (resolvedRows.length === 0 && query && partnerName.includes(query)) {
            cards.push(`
              <div class="sisa-card rpg-card" data-partner-id="${p.id}">
                <div class="sisa-header" onclick="togglePartnerCard('${p.id}')">
                  <div class="sisa-header-left">
                    <span class="partner-icon">🏪</span>
                    <span class="partner-name">${p.tenant?.name || "(tenant?)"}</span>
                  </div>
                  <span class="sisa-toggle-icon">▶</span>
                </div>
                <div class="loading" style="padding:12px 0; font-size:12px;">${window.t('Tidak ada SKU yang cocok.')}</div>
              </div>
            `);
            continue;
          }

          const rowsHtml = resolvedRows.map(({ sku, qty, cls }) => {
            const maxVal = 15; // Benchmark quantity for progress bar fill
            const percentage = Math.min(100, Math.max(0, (qty / maxVal) * 100));
            const priceStr = sku.priceIdr ? new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", maximumFractionDigits: 0 }).format(sku.priceIdr) : "";

            return `
              <div class="pouch-item ${cls}">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:8px;">
                  <div style="min-width: 0;">
                    <span class="sku-code">${sku.code}</span>
                    <div class="sku-name" style="margin-top: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${sku.name}</div>
                  </div>
                  <div style="text-align:right; flex-shrink: 0;">
                    <span class="stock-badge ${cls}">
                      ${qty <= 0 ? `🔴 ${window.t('HABIS')}` : qty < 5 ? `🟡 ${qty} ${window.t('UNIT')}` : `🟢 ${qty} ${window.t('UNIT')}`}
                    </span>
                    <div class="sku-price" style="margin-top: 4px;">${priceStr}</div>
                  </div>
                </div>
                <div style="margin-top:4px;">
                  <div style="display:flex; justify-content:space-between; align-items:center; font-size:9px; font-weight:800; color:#64748b; text-transform:uppercase; margin-bottom:2px;">
                    <span>${window.t('Stock HP')}</span>
                    <span>${qty} / 15</span>
                  </div>
                  <div class="stock-progress-container">
                    <div class="stock-progress-bar ${cls}" style="width: ${percentage}%"></div>
                  </div>
                </div>
              </div>
            `;
          }).join("");

          // Keep collapse state if card was already rendered
          const existingCard = document.querySelector(`.sisa-card[data-partner-id="${p.id}"]`);
          const isCollapsed = existingCard ? existingCard.classList.contains("collapsed") : false;

          cards.push(`
            <div class="sisa-card rpg-card ${isCollapsed ? 'collapsed' : ''}" data-partner-id="${p.id}">
              <div class="sisa-header" onclick="togglePartnerCard('${p.id}')">
                <div class="sisa-header-left">
                  <span class="partner-icon">🏪</span>
                  <span class="partner-name">${p.tenant?.name || "(tenant?)"}</span>
                </div>
                <span class="sisa-toggle-icon">▶</span>
              </div>
              <div class="pouch-grid">
                ${rowsHtml || `<div class="loading" style="padding:12px 0; font-size:12px;">${window.t('Tidak ada item yang cocok dengan filter.')}</div>`}
              </div>
            </div>
          `);
        }

        if (cards.length === 0) {
          sisaEl.innerHTML = `<div class="empty">${window.t('Tidak ada partner atau SKU yang cocok.')}</div>`;
        } else {
          sisaEl.innerHTML = cards.join("");
        }
      }

      (async () => {
        const r = await jget("/v1/ops/brand-dashboard");
        if (!r.ok) {
          if (r.error?.code === "VERIFICATION_PENDING") {
            window.location.href = "/login?registered=1";
            return;
          }
          window.location.href = "/login"; return;
        }

        globalData = r.data;
        const { user, brand, skus, partnerships, weeklyRevenue } = globalData;
        const brandId = brand.id;

        // Fetch additional map notification statuses: closings and settlements
        let closings = [];
        let settlements = [];
        try {
          const [closingsRes, settlementsRes] = await Promise.all([
            jget(`/v1/brands/${brandId}/closings`),
            jget(`/v1/brands/${brandId}/settlements`)
          ]);
          if (closingsRes.ok) closings = closingsRes.data?.closings || [];
          if (settlementsRes.ok) settlements = settlementsRes.data?.settlements || [];
        } catch (e) {
          console.error("Failed to load map data:", e);
        }

        // Set name displays
        document.getElementById("greet").textContent = `${window.t('Halo')}, ${user.name || user.phoneE164}`;
        document.getElementById("brand-name-display").textContent = brand.name;

        const active = (partnerships || []).filter(p => p.status === "ACTIVE");
        document.getElementById("active-count").textContent = active.length;

        // Dynamic RPG Level & XP calculation
        const submittedClosings = closings.filter(c => c.status === "SUBMITTED");
        const pendingSettlements = settlements.filter(s => s.status === "DRAFT" || s.status === "PENDING_BRAND");
        
        const xp = (active.length * 100) + 
                   (skus.length * 20) + 
                   Math.floor(weeklyRevenue / 10000) + 
                   (submittedClosings.length * 50) + 
                   (pendingSettlements.length * 100);
                   
        const level = Math.floor(xp / 1000) + 1;
        const xpProgress = xp % 1000;
        const xpPercentage = (xpProgress / 1000) * 100;
        
        document.getElementById("level-badge").textContent = `Lv. ${level}`;
        document.getElementById("xp-bar-fill").style.width = `${xpPercentage}%`;
        document.getElementById("xp-text").textContent = `${xpProgress} / 1000 XP (Total: ${xp})`;

        // Calculate Defense (Stock safety % across active partners)
        let totalActiveSKUs = 0;
        let healthyActiveSKUs = 0;
        const { sisaSistem } = globalData;
        
        for (const p of active) {
          const psSisa = (sisaSistem || []).filter(row => row.partnershipId === p.id);
          for (const row of psSisa) {
            totalActiveSKUs++;
            if ((row.sisa ?? 0) >= 5) {
              healthyActiveSKUs++;
            }
          }
        }
        const defensePct = totalActiveSKUs > 0 ? Math.round((healthyActiveSKUs / totalActiveSKUs) * 100) : 100;
        document.getElementById("defense-val").textContent = `${defensePct}%`;

        // Energy level (total closing review count + pending settlements count)
        const energyPoints = submittedClosings.length + pendingSettlements.length;
        document.getElementById("energy-val").textContent = energyPoints;

        // Setup persistent Character Avatar choice
        const savedEmoji = localStorage.getItem("kongsian_hero_emoji");
        const savedTitle = localStorage.getItem("kongsian_hero_title");
        if (savedEmoji && savedTitle) {
          selectAvatar(savedEmoji, savedTitle);
        } else {
          // Guess character class based on brand name
          const bName = brand.name.toLowerCase();
          if (bName.includes("roti") || bName.includes("oat") || bName.includes("bread") || bName.includes("cake") || bName.includes("pastry")) {
            selectAvatar("🧑‍🍳", "Pastry Knight");
          } else if (bName.includes("jus") || bName.includes("juice") || bName.includes("sehat") || bName.includes("healthy") || bName.includes("jamu")) {
            selectAvatar("👩‍🌾", "Juice Druid");
          } else if (bName.includes("boba") || bName.includes("teh") || bName.includes("tea") || bName.includes("milk")) {
            selectAvatar("🧋", "Boba Cleric");
          } else if (bName.includes("waffle") || bName.includes("snack") || bName.includes("cemilan") || bName.includes("kentang")) {
            selectAvatar("🧇", "Waffle Rogue");
          } else {
            selectAvatar("🧙‍♂️", "Coffee Sorcerer");
          }
        }

        // Draw Interactive Virtual Town Map
        const townMapEl = document.getElementById("town-map");
        if (active.length === 0) {
          document.getElementById("town-viewport").innerHTML = `
            <div class="empty" style="padding: 30px; border-style: dashed;">
              <div style="font-size: 44px; margin-bottom: 8px;">🗺️</div>
              <div style="font-weight: 800; color: #f1f5f9; margin-bottom: 4px;">${window.t('Peta Kosong')}</div>
              <div style="color: #64748b; font-size: 13px;">${window.t('Belum ada partner aktif. Undang partner di bawah untuk mendirikan Cafe baru!')}</div>
            </div>
          `;
        } else {
          const mapCells = [];
          // Predefined coordinate offsets around center row 2 col 4
          const cafePositions = [
            { r: 1, c: 2 }, { r: 1, c: 6 },
            { r: 2, c: 2 }, { r: 2, c: 6 },
            { r: 3, c: 2 }, { r: 3, c: 6 },
            { r: 1, c: 4 }, { r: 3, c: 4 },
            { r: 1, c: 1 }, { r: 1, c: 7 },
            { r: 3, c: 1 }, { r: 3, c: 7 }
          ];

          for (let r = 1; r <= 3; r++) {
            for (let c = 1; c <= 7; c++) {
              if (r === 2 && c === 4) {
                mapCells.push(`
                  <div class="map-cell">
                    <div class="building-sprite hq" style="cursor: default;">🏢</div>
                    <div class="building-label">${window.t('HQ KAMI')}</div>
                  </div>
                `);
                continue;
              }

              const cafeIdx = cafePositions.findIndex(pos => pos.r === r && pos.c === c);
              if (cafeIdx !== -1 && cafeIdx < active.length) {
                const p = active[cafeIdx];
                
                // Alert check
                const psSisa = (sisaSistem || []).filter(row => row.partnershipId === p.id);
                const hasZeroStock = psSisa.some(row => (row.sisa ?? 0) <= 0);
                const hasLowStock = psSisa.some(row => (row.sisa ?? 0) > 0 && (row.sisa ?? 0) < 5);
                const hasPendingClosing = closings.some(cl => cl.partnershipId === p.id && cl.status === "SUBMITTED");
                const hasPendingSettlement = settlements.some(se => se.partnershipId === p.id && (se.status === "DRAFT" || se.status === "PENDING_BRAND"));
                
                let alertHtml = "";
                let bubbleCls = "";
                if (hasPendingSettlement) {
                  alertHtml = "🪙";
                  bubbleCls = "settlement";
                } else if (hasPendingClosing) {
                  alertHtml = "🕒";
                  bubbleCls = "closing";
                } else if (hasZeroStock) {
                  alertHtml = "🚨";
                  bubbleCls = "zero";
                } else if (hasLowStock) {
                  alertHtml = "⚠️";
                  bubbleCls = "low";
                }

                const bubbleEl = alertHtml ? `<div class="floating-bubble ${bubbleCls}">${alertHtml}</div>` : "";

                mapCells.push(`
                  <div class="map-cell cafe-cell active-cafe" onclick="focusCafeCard('${p.id}')" title="${window.t('Klik untuk fokus ke stok cafe ini')}">
                    ${bubbleEl}
                    <div class="building-sprite cafe">🏪</div>
                    <div class="building-label">${(p.tenant?.name || "Cafe").toUpperCase()}</div>
                  </div>
                `);
                continue;
              }

              // Draw roads
              if (r === 2 || c === 4 || c === 2 || c === 6) {
                mapCells.push(`<div class="map-cell road-cell">•</div>`);
              } else {
                mapCells.push(`<div class="map-cell grass-cell">🌱</div>`);
              }
            }
          }
          townMapEl.innerHTML = mapCells.join("");
        }

        // Render remaining stock list
        renderSisaList();

        // Bind interactive search & filter events
        const searchInput = document.getElementById("sisa-search");
        let activeFilter = "all";

        searchInput.addEventListener("input", (e) => {
          renderSisaList(e.target.value, activeFilter);
        });

        document.querySelectorAll(".filter-tab").forEach(tab => {
          tab.addEventListener("click", () => {
            document.querySelectorAll(".filter-tab").forEach(t => t.classList.remove("active"));
            tab.classList.add("active");
            activeFilter = tab.getAttribute("data-filter");
            renderSisaList(searchInput.value, activeFilter);
          });
        });

        // SKU List
        const skusEl = document.getElementById("skus");
        if (skus.length === 0) {
          skusEl.innerHTML = `<div class="empty">${window.t('Belum ada SKU.')} <a href="/dashboard/brand/skus">${window.t('Tambah SKU')}</a>.</div>`;
        } else {
          skusEl.innerHTML = skus.map(s => `<span class="sku-pill">${s.code} · ${s.name}</span>`).join("");
        }

        // Partnerships List
        const pEl = document.getElementById("partnerships");
        if (partnerships.length === 0) {
          pEl.innerHTML = `<div class="empty">${window.t('Belum ada partner.')} <a href="/dashboard/brand/partnerships">${window.t('Invite partner pertama')}</a>.</div>`;
        } else {
          pEl.innerHTML = partnerships.map(p => `
            <div class="partner">
              <div>
                <div class="name">${p.tenant?.name || "(tenant?)"}</div>
                <div class="meta">${p.tenant?.address || p.tenant?.picPhoneE164 || ""}</div>
              </div>
              <div>
                <span class="badge ${p.status.toLowerCase()}">${p.status}</span>
              </div>
            </div>
          `).join("");
        }

        // Weekly revenue
        document.getElementById("weekly-revenue").textContent = weeklyRevenue === 0
          ? "Rp 0"
          : new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", maximumFractionDigits: 0 }).format(weeklyRevenue);

        // Render Quest Combat History Log
        const combatLogEl = document.getElementById("rpg-combat-log");
        const combatRows = [];

        // Add Active partnerships
        for (const p of partnerships) {
          const dateStr = new Date(p.createdAt * 1000).toLocaleDateString("id-ID", { day: "2-digit", month: "short" });
          if (p.status === "ACTIVE") {
            combatRows.push({
              time: p.createdAt * 1000,
              html: `<div class="combat-row"><span class="log-time">[${dateStr}]</span> <span class="log-icon">🤝</span> ${window.t('Aliansi didirikan dengan')} <span class="log-entity">${p.tenant?.name}</span>! <span class="log-xp">(+100 XP)</span></div>`
            });
          }
        }

        // Add submitted/approved closings logs
        for (const cl of closings) {
          const dateVal = new Date(cl.closingDate + "T00:00:00").getTime();
          const dateStr = new Date(cl.closingDate + "T00:00:00").toLocaleDateString("id-ID", { day: "2-digit", month: "short" });
          const partner = partnerships.find(p => p.id === cl.partnershipId);
          const tenantName = partner?.tenant?.name || "Tenant";

          if (cl.status === "LOCKED") {
            combatRows.push({
              time: dateVal + 1,
              html: `<div class="combat-row"><span class="log-time">[${dateStr}]</span> <span class="log-icon">📋</span> ${window.t('Laporan closing')} <span class="log-entity">${tenantName}</span> ${window.t('disetujui!')} <span class="log-xp">(+20 XP)</span></div>`
            });
          } else if (cl.status === "SUBMITTED") {
            combatRows.push({
              time: dateVal,
              html: `<div class="combat-row text-alert"><span class="log-time">[${dateStr}]</span> <span class="log-icon">🕒</span> ${window.t('Laporan closing baru dari')} <span class="log-entity">${tenantName}</span> ${window.t('siap direview!')}</div>`
            });
          }
        }

        // Add settlements logs
        for (const se of settlements) {
          const dateVal = new Date(se.weekStartDate + "T00:00:00").getTime();
          const dateStr = new Date(se.weekStartDate + "T00:00:00").toLocaleDateString("id-ID", { day: "2-digit", month: "short" });
          const partner = partnerships.find(p => p.id === se.partnershipId);
          const tenantName = partner?.tenant?.name || "Tenant";
          const revStr = new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", maximumFractionDigits: 0 }).format(se.totalRevenue || 0);

          if (se.status === "PAID") {
            combatRows.push({
              time: dateVal + 2,
              html: `<div class="combat-row text-success"><span class="log-time">[${dateStr}]</span> <span class="log-icon">💰</span> ${window.t('Quest Selesai: Settlement')} <span class="log-entity">${tenantName}</span> ${window.t('lunas')} ${revStr}! <span class="log-xp">(+50 XP)</span></div>`
            });
          } else if (se.status === "BRAND_APPROVED") {
            combatRows.push({
              time: dateVal + 1,
              html: `<div class="combat-row text-success"><span class="log-time">[${dateStr}]</span> <span class="log-icon">🪙</span> ${window.t('Settlement')} <span class="log-entity">${tenantName}</span> ${window.t('disetujui Brand!')}</div>`
            });
          } else if (se.status === "DRAFT" || se.status === "PENDING_BRAND") {
            combatRows.push({
              time: dateVal,
              html: `<div class="combat-row text-alert"><span class="log-time">[${dateStr}]</span> <span class="log-icon">⚠️</span> ${window.t('Settlement')} <span class="log-entity">${tenantName}</span> ${window.t('siap direview!')}</div>`
            });
          }
        }

        combatRows.sort((a, b) => b.time - a.time);

        if (combatRows.length === 0) {
          combatLogEl.innerHTML = `<div class="empty-log">${window.t('Belum ada riwayat aktivitas pertempuran.')}</div>`;
        } else {
          combatLogEl.innerHTML = combatRows.map(row => row.html).join("");
        }

      })();
    </script>
  </body>
</html>
