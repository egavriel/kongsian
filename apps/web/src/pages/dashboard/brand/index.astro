---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../../../lib/api";
import NotificationBell from "../../../components/NotificationBell.astro";
const title = `Brand Dashboard — ${APP_NAME}`;
---
<!doctype html>
<html lang="id">
  <head>
    <script src="/i18n-helper.js" is:inline></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style is:global>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: radial-gradient(circle at top, #0b1220 0%, #030712 100%);
        background-attachment: fixed;
        color: #f1f5f9;
        font-family: 'Plus Jakarta Sans', ui-sans-serif, system-ui, -apple-system, sans-serif;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }
      a { color: #38bdf8; text-decoration: none; transition: color 0.15s ease; }
      a:hover { color: #7dd3fc; text-decoration: none; }
      
      .shell { max-width: 480px; margin: 0 auto; padding: 0 0 100px; }
      
      header.top {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; border-bottom: 2px solid #1e293b;
        position: sticky; top: 0; background: rgba(3, 7, 18, 0.85);
        backdrop-filter: blur(20px); z-index: 50;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
      }
      .brand-name { font-weight: 900; font-size: 16px; color: #f8fafc; letter-spacing: -0.02em; }
      .role-tag { font-size: 10px; padding: 3px 8px; border-radius: 999px; background: rgba(168, 85, 247, 0.1); color: #a855f7; border: 1.5px solid rgba(168, 85, 247, 0.2); font-weight: 800; letter-spacing: 0.06em; }
      .logout { font-size: 13px; color: #94a3b8; background: none; border: none; cursor: pointer; transition: color 0.15s ease; font-weight: 700; }
      .logout:hover { color: #fb7185; }
      
      main { padding: 20px; }
      
      /* Neobrutalist RPG Card Styles */
      .rpg-card {
        background: #0f172a;
        border: 2.5px solid #1e293b;
        border-radius: 16px;
        box-shadow: 4px 4px 0px 0px #020617;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
      }
      .rpg-card:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0px 0px #020617;
        border-color: #334155;
      }

      /* RPG Profile Card */
      .rpg-profile {
        margin-bottom: 24px;
        padding: 20px;
        position: relative;
        overflow: visible;
        background: linear-gradient(135deg, rgba(30, 41, 59, 0.7) 0%, rgba(15, 23, 42, 0.85) 100%);
      }
      /* Class specific border colors */
      .rpg-profile.class-sorcerer { border-color: #a855f7; }
      .rpg-profile.class-knight { border-color: #fbbf24; }
      .rpg-profile.class-druid { border-color: #10b981; }
      .rpg-profile.class-cleric { border-color: #06b6d4; }
      .rpg-profile.class-rogue { border-color: #f43f5e; }

      .profile-layout {
        display: flex;
        gap: 16px;
        align-items: center;
      }
      .avatar-container {
        position: relative;
      }
      .avatar-circle {
        width: 76px;
        height: 76px;
        background: rgba(15, 23, 42, 0.6);
        border: 3px solid #1e293b;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 38px;
        cursor: pointer;
        position: relative;
        transition: all 0.2s ease;
        box-shadow: 2px 2px 0px 0px rgba(0,0,0,0.4);
      }
      .avatar-circle:hover {
        transform: scale(1.06);
        border-color: #fbbf24;
      }
      .avatar-edit-badge {
        position: absolute;
        bottom: -2px;
        right: -2px;
        background: #fbbf24;
        font-size: 10px;
        border-radius: 50%;
        width: 20px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1.5px solid #0f172a;
      }
      .avatar-select-grid {
        position: absolute;
        top: 84px;
        left: 0;
        background: #0f172a;
        border: 2px solid #334155;
        border-radius: 12px;
        padding: 8px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        z-index: 99;
        box-shadow: 0 10px 25px rgba(0,0,0,0.5);
        min-width: 140px;
      }
      .avatar-select-grid button {
        background: transparent;
        border: none;
        color: #f1f5f9;
        font-size: 13px;
        padding: 6px 12px;
        border-radius: 8px;
        cursor: pointer;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: inherit;
        font-weight: 700;
        transition: background 0.15s ease;
        width: 100%;
      }
      .avatar-select-grid button:hover {
        background: rgba(251, 191, 36, 0.1);
        color: #fbbf24;
      }
      .profile-details {
        flex: 1;
      }
      .char-title {
        font-size: 10px;
        font-weight: 800;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .level-badge {
        display: inline-block;
        background: #fbbf24;
        color: #0b1220;
        font-size: 9px;
        font-weight: 900;
        padding: 2px 8px;
        border-radius: 4px;
        margin-top: 4px;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .xp-bar-container {
        height: 8px;
        background: rgba(255, 255, 255, 0.08);
        border: 1.5px solid #1e293b;
        border-radius: 99px;
        overflow: hidden;
        margin-bottom: 4px;
      }
      .xp-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #10b981 0%, #3b82f6 100%);
        border-radius: 99px;
        transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        width: 0%;
      }
      .xp-text {
        font-size: 10px;
        color: #64748b;
        font-weight: 800;
      }

      /* RPG Stats Attributes */
      .rpg-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 28px;
      }
      .rpg-stat-box {
        background: rgba(15, 23, 42, 0.45);
        border: 2px solid #1e293b;
        border-radius: 16px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 3px 3px 0px 0px #020617;
        transition: all 0.2s ease;
      }
      .rpg-stat-box:hover {
        border-color: rgba(251, 191, 36, 0.3);
        transform: translateY(-2px);
        box-shadow: 4px 4px 0px 0px #020617;
      }
      .rpg-stat-icon {
        font-size: 24px;
        background: rgba(30, 41, 59, 0.6);
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1.5px solid #334155;
        flex-shrink: 0;
      }
      .rpg-stat-info {
        display: flex;
        flex-direction: column;
      }
      .rpg-stat-lbl {
        font-size: 9px;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .rpg-stat-val {
        font-size: 18px;
        font-weight: 900;
        color: #ffffff;
        line-height: 1.25;
      }
      .rpg-stat-sub {
        font-size: 9px;
        color: #475569;
        font-weight: 600;
      }

      /* Town Map Section */
      .section-header-rpg {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin: 28px 0 12px;
      }
      .section-header-rpg h2 {
        font-size: 11px;
        margin: 0;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 900;
      }
      .town-viewport {
        width: 100%;
        overflow-x: auto;
        background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
        border: 3px solid #1e293b;
        border-radius: 20px;
        box-shadow: 4px 4px 0px 0px #020617;
        padding: 20px;
        margin-bottom: 28px;
        position: relative;
      }
      .town-map {
        display: grid;
        grid-template-columns: repeat(7, 76px);
        grid-template-rows: repeat(3, 90px);
        gap: 12px;
        justify-content: center;
        align-items: center;
        position: relative;
        width: max-content;
        margin: 0 auto;
      }
      .map-cell {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        width: 100%;
        position: relative;
      }
      .road-cell {
        background: rgba(51, 65, 85, 0.2);
        border: 1px dashed rgba(255, 255, 255, 0.04);
        color: #475569;
        font-size: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
      }
      .grass-cell {
        color: #1b2e1e;
        font-size: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.6;
      }
      .building-sprite {
        font-size: 28px;
        filter: drop-shadow(2px 2px 0px rgba(0,0,0,0.6));
        transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      }
      .cafe-cell:hover .building-sprite {
        transform: scale(1.2) translateY(-2px);
      }
      .building-label {
        font-size: 8px;
        font-weight: 800;
        color: #cbd5e1;
        text-align: center;
        margin-top: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 72px;
        background: rgba(3, 7, 18, 0.85);
        padding: 1px 4px;
        border-radius: 4px;
        border: 1px solid rgba(255,255,255,0.06);
      }
      .active-cafe {
        cursor: pointer;
      }
      .floating-bubble {
        position: absolute;
        top: -10px;
        background: #0f172a;
        border: 2px solid #fbbf24;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: float 2.5s ease-in-out infinite;
        box-shadow: 0 4px 10px rgba(0,0,0,0.4);
        z-index: 10;
        font-size: 12px;
      }
      .floating-bubble.zero { border-color: #ef4444; }
      .floating-bubble.low { border-color: #f59e0b; }
      .floating-bubble.closing { border-color: #38bdf8; }
      .floating-bubble.settlement { border-color: #10b981; animation: float 2.5s ease-in-out infinite, glow 1.5s ease-in-out infinite alternate; }

      @keyframes float {
        0% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
        100% { transform: translateY(0); }
      }
      @keyframes glow {
        0% { box-shadow: 0 0 4px #10b981; }
        100% { box-shadow: 0 0 12px #10b981; }
      }

      /* Controls & Search */
      .sisa-controls {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin: 16px 0 20px;
      }
      .search-container {
        position: relative;
        width: 100%;
      }
      .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 14px;
        color: #64748b;
        pointer-events: none;
      }
      .search-input {
        width: 100%;
        background: rgba(15, 23, 42, 0.45);
        border: 2.5px solid #1e293b;
        border-radius: 14px;
        padding: 12px 12px 12px 40px;
        font-size: 14px;
        color: #f1f5f9;
        font-family: inherit;
        transition: all 0.2s ease;
      }
      .search-input:focus {
        outline: none;
        border-color: #fbbf24;
        background: rgba(15, 23, 42, 0.7);
        box-shadow: 3px 3px 0px 0px #020617;
      }
      .filter-tabs {
        display: flex;
        background: rgba(15, 23, 42, 0.45);
        border: 2px solid #1e293b;
        padding: 4px;
        border-radius: 14px;
        gap: 4px;
      }
      .filter-tab {
        flex: 1;
        background: transparent;
        border: none;
        color: #94a3b8;
        padding: 8px 12px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s ease;
        text-align: center;
      }
      .filter-tab:hover {
        color: #f1f5f9;
        background: rgba(255, 255, 255, 0.03);
      }
      .filter-tab.active {
        background: #fbbf24;
        color: #0b1220;
        box-shadow: 2px 2px 0px 0px #020617;
      }
      
      /* Stok Tersisa Inventory Pouch */
      .sisa-list { display: flex; flex-direction: column; gap: 16px; margin-bottom: 24px; }
      .sisa-card {
        padding: 18px;
      }
      .sisa-card .sisa-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        user-select: none;
        border-bottom: 2px solid #1e293b;
        padding-bottom: 12px;
        margin-bottom: 14px;
        transition: border-color 0.2s ease;
      }
      .sisa-card.collapsed .sisa-header {
        border-bottom-color: transparent;
        margin-bottom: 0;
        padding-bottom: 0;
      }
      .sisa-card.collapsed .pouch-grid {
        display: none;
      }
      .sisa-header-left {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .partner-icon {
        font-size: 16px;
        background: rgba(251, 191, 36, 0.08);
        padding: 6px;
        border-radius: 10px;
        border: 1px solid rgba(251, 191, 36, 0.15);
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .partner-name {
        font-weight: 800;
        font-size: 15px;
        color: #f8fafc;
      }
      .sisa-toggle-icon {
        font-size: 10px;
        color: #64748b;
        transition: transform 0.25s ease;
        display: inline-block;
      }
      .sisa-card:not(.collapsed) .sisa-toggle-icon {
        transform: rotate(90deg);
      }
      
      /* Item Pouch Grid */
      .pouch-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
      }
      .pouch-item {
        background: #020617;
        border: 2px solid #1e293b;
        border-radius: 12px;
        padding: 12px;
        box-shadow: 2px 2px 0px 0px rgba(0,0,0,0.3);
        display: flex;
        flex-direction: column;
        gap: 8px;
        transition: all 0.2s ease;
      }
      .pouch-item:hover {
        transform: scale(1.01);
        border-color: #334155;
      }
      .pouch-item.zero { border-color: #ef4444; background: rgba(239, 68, 68, 0.02); }
      .pouch-item.low { border-color: #f59e0b; background: rgba(245, 158, 11, 0.02); }
      .pouch-item.ok { border-color: #10b981; background: rgba(16, 185, 129, 0.02); }

      .sku-code {
        font-weight: 800;
        color: #fbbf24;
        font-size: 10px;
        background: rgba(251, 191, 36, 0.08);
        border: 1px solid rgba(251, 191, 36, 0.15);
        padding: 2px 6px;
        border-radius: 4px;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        display: inline-block;
      }
      .sku-price {
        font-size: 11px;
        color: #64748b;
        font-weight: 700;
      }
      .sku-name {
        color: #e2e8f0;
        font-size: 13px;
        font-weight: 700;
        line-height: 1.35;
      }
      
      .stock-badge {
        font-size: 11px;
        font-weight: 800;
        padding: 4px 8px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        min-width: 90px;
        justify-content: center;
      }
      .stock-badge.zero {
        background: rgba(239, 68, 68, 0.08);
        color: #f87171;
        border: 1px solid rgba(239, 68, 68, 0.15);
      }
      .stock-badge.low {
        background: rgba(245, 158, 11, 0.08);
        color: #fbbf24;
        border: 1px solid rgba(245, 158, 11, 0.15);
      }
      .stock-badge.ok {
        background: rgba(16, 185, 129, 0.08);
        color: #34d399;
        border: 1px solid rgba(16, 185, 129, 0.15);
      }
      
      /* Progress bar (HP bar) styling */
      .stock-progress-container {
        height: 6px;
        width: 100%;
        background: rgba(255, 255, 255, 0.04);
        border-radius: 99px;
        overflow: hidden;
      }
      .stock-progress-bar {
        height: 100%;
        border-radius: 99px;
        transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .stock-progress-bar.zero { width: 0% !important; }
      .stock-progress-bar.low { background: #f59e0b; }
      .stock-progress-bar.ok { background: #10b981; }

      /* Target Highlight Glow */
      .sisa-card.map-highlight {
        animation: card-flash 0.5s ease-in-out 3 alternate;
      }
      @keyframes card-flash {
        0% { border-color: #1e293b; box-shadow: 4px 4px 0px 0px #020617; }
        100% { border-color: #fbbf24; box-shadow: 0 0 15px rgba(251, 191, 36, 0.4); }
      }

      /* Quest board UI */
      .quest-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
        margin-bottom: 24px;
      }
      .quest-card {
        background: #0f172a;
        border: 2.5px solid #1e293b;
        border-radius: 16px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: #f1f5f9;
        text-decoration: none;
        transition: all 0.2s ease;
        box-shadow: 3px 3px 0px 0px #020617;
      }
      .quest-card:hover {
        border-color: #fbbf24;
        transform: translate(-1px, -1px);
        box-shadow: 4px 4px 0px 0px #020617;
        text-decoration: none;
      }
      .quest-info {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .quest-icon {
        font-size: 20px;
        background: rgba(30, 41, 59, 0.6);
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1.5px solid #334155;
        flex-shrink: 0;
      }
      .quest-details {
        display: flex;
        flex-direction: column;
      }
      .quest-title {
        font-weight: 800;
        font-size: 13px;
        color: #ffffff;
      }
      .quest-desc {
        font-size: 10px;
        color: #64748b;
        margin-top: 1px;
      }
      .quest-xp-badge {
        font-size: 9px;
        font-weight: 900;
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
        border: 1.5px solid rgba(16, 185, 129, 0.15);
        padding: 2px 8px;
        border-radius: 6px;
        text-transform: uppercase;
        flex-shrink: 0;
      }

      /* Collapsible Sections & History Logs */
      .collapsible-section {
        margin-bottom: 12px;
      }
      .collapsible-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        user-select: none;
        border-bottom: 2px solid #1e293b;
        padding-bottom: 8px;
      }
      .collapsible-section.collapsed .collapsible-header {
        border-bottom-color: transparent;
      }
      .collapsible-header h2 {
        margin: 0;
        font-size: 11px;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 900;
      }
      .collapsible-header .toggle-btn {
        font-size: 10px;
        color: #64748b;
        transition: transform 0.25s ease;
        display: inline-block;
      }
      .collapsible-section.collapsed .toggle-btn {
        transform: rotate(0deg);
      }
      .collapsible-section:not(.collapsed) .toggle-btn {
        transform: rotate(90deg);
      }
      .collapsible-section.collapsed .collapsible-content {
        display: none;
      }
      .collapsible-content {
        padding-top: 14px;
      }

      /* Combat Log Box */
      .rpg-log-viewport {
        background: #020617;
        border: 2px solid #1e293b;
        border-radius: 12px;
        padding: 12px;
        max-height: 180px;
        overflow-y: auto;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }
      .rpg-combat-log {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .combat-row {
        font-size: 11px;
        line-height: 1.4;
        color: #94a3b8;
        border-bottom: 1px solid rgba(255, 255, 255, 0.02);
        padding-bottom: 4px;
      }
      .combat-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }
      .log-time { color: #475569; margin-right: 4px; }
      .log-icon { margin-right: 4px; }
      .log-entity { color: #e2e8f0; font-weight: 700; }
      .log-xp { color: #10b981; font-weight: 700; }
      .text-alert { color: #f59e0b; }
      .text-success { color: #10b981; }
      .empty-log {
        font-size: 11px;
        color: #475569;
        text-align: center;
        padding: 20px;
      }

      /* Partners List & SKUs */
      .partnerships { display: flex; flex-direction: column; gap: 10px; }
      .partner {
        background: #020617;
        border: 2px solid #1e293b;
        border-radius: 14px;
        padding: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        transition: border-color 0.2s ease;
      }
      .partner:hover { border-color: #334155; }
      .partner .name { font-weight: 800; font-size: 14px; color: #f1f5f9; }
      .partner .meta { font-size: 12px; color: #64748b; margin-top: 2px; font-weight: 500; }
      
      .badge {
        font-size: 10px; padding: 4px 10px; border-radius: 999px; font-weight: 800;
        letter-spacing: 0.06em;
      }
      .badge.active { background: rgba(52, 211, 153, 0.1); color: #34d399; border: 1.5px solid rgba(52, 211, 153, 0.15); }
      .badge.pending { background: rgba(251, 191, 36, 0.1); color: #fbbf24; border: 1.5px solid rgba(251, 191, 36, 0.15); }
      .badge.suspended { background: rgba(251, 113, 133, 0.1); color: #fb7185; border: 1.5px solid rgba(251, 113, 133, 0.15); }
      
      .empty {
        background: rgba(15, 23, 42, 0.3); border: 2.5px dashed #1e293b; border-radius: 16px;
        padding: 24px; text-align: center; color: #94a3b8; font-size: 13px;
      }

      .skus { display: flex; flex-wrap: wrap; gap: 6px; }
      .sku-pill { 
        background: #020617;
        border: 2px solid #1e293b;
        padding: 6px 12px; 
        border-radius: 8px; 
        font-size: 12px; 
        color: #f1f5f9; 
        font-weight: 600;
        transition: all 0.2s ease;
      }
      .sku-pill:hover {
        border-color: #fbbf24;
        background: rgba(251, 191, 36, 0.03);
      }
      
      .err { background: rgba(251, 113, 133, .12); color: #fb7185; border: 1px solid rgba(251, 113, 133, .3); padding: 12px; border-radius: 10px; font-size: 14px; }
      .loading { color: #94a3b8; text-align: center; padding: 24px; font-size: 14px; font-weight: 600; }
    </style>
  </head>
