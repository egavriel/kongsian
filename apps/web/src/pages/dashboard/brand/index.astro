---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../../../lib/api";
import NotificationBell from "../../../components/NotificationBell.astro";
const title = `Brand Dashboard — ${APP_NAME}`;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: #0b1220; color: #f1f5f9;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }
      a { color: #38bdf8; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .shell { max-width: 480px; margin: 0 auto; padding: 0 0 80px; }
      header.top {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; border-bottom: 1px solid #1e293b;
        position: sticky; top: 0; background: rgba(11, 18, 32, .92);
        backdrop-filter: blur(6px); z-index: 5;
      }
      .brand-name { font-weight: 700; font-size: 15px; }
      .role-tag { font-size: 11px; padding: 2px 8px; border-radius: 999px; background: #fbbf24; color: #0b1220; font-weight: 700; letter-spacing: 0.04em; }
      .logout { font-size: 13px; color: #94a3b8; background: none; border: none; cursor: pointer; }
      main { padding: 20px; }
      .greet { font-size: 14px; color: #94a3b8; margin: 0 0 4px; }
      h1 { font-size: 24px; margin: 0 0 16px; letter-spacing: -0.01em; }
      .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px; }
      .stat {
        background: #0f172a; border: 1px solid #1e293b; border-radius: 12px; padding: 14px;
      }
      .stat .lbl { font-size: 12px; color: #94a3b8; margin-bottom: 4px; }
      .stat .val { font-size: 22px; font-weight: 700; }
      .stat .sub { font-size: 12px; color: #94a3b8; }
      h2 { font-size: 16px; margin: 24px 0 12px; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; }
      .actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
      .action {
        background: #0f172a; border: 1px solid #1e293b; border-radius: 12px;
        padding: 16px; display: flex; flex-direction: column; gap: 4px;
        color: #f1f5f9; text-decoration: none; min-height: 80px;
      }
      .action:hover { border-color: #fbbf24; text-decoration: none; }
      .action .ic { font-size: 20px; }
      .action .tt { font-weight: 600; font-size: 14px; }
      .action .sub { font-size: 12px; color: #94a3b8; }
      .partnerships { display: flex; flex-direction: column; gap: 10px; }
      .partner {
        background: #0f172a; border: 1px solid #1e293b; border-radius: 12px; padding: 14px;
        display: flex; align-items: center; justify-content: space-between; gap: 12px;
      }
      .partner .name { font-weight: 600; }
      .partner .meta { font-size: 12px; color: #94a3b8; }
      .badge {
        font-size: 11px; padding: 4px 10px; border-radius: 999px; font-weight: 700;
        letter-spacing: 0.04em;
      }
      .badge.active { background: rgba(52, 211, 153, .15); color: #34d399; }
      .badge.pending { background: rgba(251, 191, 36, .15); color: #fbbf24; }
      .badge.suspended { background: rgba(251, 113, 133, .15); color: #fb7185; }
      .empty {
        background: #0f172a; border: 1px dashed #1e293b; border-radius: 12px;
        padding: 24px; text-align: center; color: #94a3b8;
      }
      .sisa-list { display:flex; flex-direction:column; gap:10px; margin-bottom:24px; }
      .sisa-card { background:#0f172a; border:1px solid #1e293b; border-radius:12px; padding:14px; }
      .sisa-card .partner { font-weight:600; margin-bottom:8px; }
      .sisa-rows { display:flex; flex-wrap:wrap; gap:6px; }
      .sisa-pill { background:#1e293b; padding:4px 8px; border-radius:6px; font-size:12px; }
      .sisa-pill.zero { color:#94a3b8; }
      .sisa-pill.low { color:#fb7185; font-weight:700; }
      .sisa-pill.ok { color:#34d399; }
      .skus { display: flex; flex-wrap: wrap; gap: 6px; }
      .sku-pill { background: #1e293b; padding: 4px 8px; border-radius: 6px; font-size: 12px; color: #fbbf24; }
      .err { background: rgba(251, 113, 133, .12); color: #fb7185; border: 1px solid rgba(251, 113, 133, .3); padding: 12px; border-radius: 10px; font-size: 14px; }
      .loading { color: #94a3b8; text-align: center; padding: 24px; }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="top">
        <div>
          <div class="brand-name">{APP_NAME}</div>
        </div>
        <div style="display:flex;align-items:center;gap:10px">
          <NotificationBell />
          <span class="role-tag">BRAND</span>
          <button id="logout" class="logout">Keluar</button>
        </div>
      </header>
      <main>
        <p class="greet" id="greet">Halo, …</p>
        <h1 id="brand-name">Brand Dashboard</h1>

        <div class="stats">
          <div class="stat">
            <div class="lbl">Partner aktif</div>
            <div class="val" id="active-count">—</div>
            <div class="sub">partnerships</div>
          </div>
          <div class="stat">
            <div class="lbl">Omzet minggu ini</div>
            <div class="val" id="weekly-revenue">—</div>
            <div class="sub">semua partner</div>
          </div>
        </div>

        <h2>Stok tersisa di partner</h2>
        <div id="sisa-list" class="sisa-list">
          <div class="loading">Memuat…</div>
        </div>

        <h2>Aksi cepat</h2>
        <div class="actions">
          <a class="action" href="/dashboard/brand/ops/new" style="border-color:#fbbf24;background:rgba(251,191,36,.08)">
            <span class="ic">⚡</span>
            <span class="tt">Catat Hari Ini</span>
            <span class="sub">Titip + Tarik + Terjual dalam 1 layar</span>
          </a>
          <a class="action" href="/dashboard/brand/movements/new-titip">
            <span class="ic">📦</span>
            <span class="tt">Catat Titip</span>
            <span class="sub">Stok masuk ke partner</span>
          </a>
          <a class="action" href="/dashboard/brand/movements/new-tarik">
            <span class="ic">↩️</span>
            <span class="tt">Catat Tarik</span>
            <span class="sub">Stok kembali ke brand</span>
          </a>
          <a class="action" href="/dashboard/brand/skus">
            <span class="ic">🏷️</span>
            <span class="tt">Kelola SKU</span>
            <span class="sub">Produk &amp; harga</span>
          </a>
          <a class="action" href="/dashboard/brand/partnerships">
            <span class="ic">🤝</span>
            <span class="tt">Invite Partner</span>
            <span class="sub">Tambah partnership</span>
          </a>
          <a class="action" href="/dashboard/brand/closings">
            <span class="ic">📋</span>
            <span class="tt">Tenant Closings</span>
            <span class="sub">Review closing harian</span>
          </a>
          <a class="action" href="/dashboard/brand/settlements">
            <span class="ic">💰</span>
            <span class="tt">Settlements</span>
            <span class="sub">Approve &amp; mark paid</span>
          </a>
          <a class="action" href="/dashboard/brand/analytics">
            <span class="ic">📊</span>
            <span class="tt">Analytics</span>
            <span class="sub">Top SKU &amp; tren mingguan</span>
          </a>
        </div>

        <h2>Partner</h2>
        <div id="partnerships" class="partnerships">
          <div class="loading">Memuat…</div>
        </div>

        <h2>SKU</h2>
        <div id="skus" class="skus">
          <div class="loading">Memuat…</div>
        </div>
      </main>
    </div>

    <script define:vars={{ API_BASE_URL }}>
      window.__KONGSIAN_API__ = API_BASE_URL;
      const API = API_BASE_URL.replace(/\/$/, "");
      const tok = localStorage.getItem("kongsian_session");
      if (!tok) { window.location.href = "/login"; }
      const authH = { Authorization: `Bearer ${tok}`, "Content-Type": "application/json" };

      async function jget(path) {
        const r = await fetch(API + path, { headers: authH });
        return r.json().catch(() => ({}));
      }
      async function jpost(path, body) {
        const r = await fetch(API + path, { method: "POST", headers: authH, body: JSON.stringify(body) });
        return r.json().catch(() => ({}));
      }

      document.getElementById("logout").addEventListener("click", async () => {
        try { await fetch(API + "/v1/auth/logout", { method: "POST", headers: { Authorization: `Bearer ${tok}` } }); } catch {}
        localStorage.removeItem("kongsian_session");
        window.location.href = "/login";
      });

      (async () => {
        const me = await jget("/v1/brands/me");
        if (!me.ok) {
          // P0 #3: API returns 403 VERIFICATION_PENDING for unverified users.
          if (me.error?.code === "VERIFICATION_PENDING") {
            window.location.href = "/login?registered=1";
            return;
          }
          window.location.href = "/login"; return;
        }
        const { role, brandId, user } = me.data;
        if (!brandId) {
          document.querySelector("main").innerHTML =
            '<div class="empty">Akun kamu belum punya brand. <a href="/dashboard/brand/new">Daftar brand dulu</a>.</div>';
          return;
        }
        document.getElementById("greet").textContent = `Halo, ${user.name || user.phoneE164}`;

        const b = await jget(`/v1/brands/${brandId}`);
        if (!b.ok) {
          document.getElementById("partnerships").innerHTML = `<div class="err">Gagal memuat brand: ${b.error?.code || "?"}</div>`;
          return;
        }
        const brand = b.data;
        document.getElementById("brand-name").textContent = brand.brand.name;
        const active = (brand.partnerships || []).filter(p => p.status === "ACTIVE");
        document.getElementById("active-count").textContent = active.length;

        // SKUs
        const skusEl = document.getElementById("skus");
        if (brand.skus.length === 0) {
          skusEl.innerHTML = '<div class="empty">Belum ada SKU. <a href="/dashboard/brand/skus">Tambah SKU</a>.</div>';
        } else {
          skusEl.innerHTML = brand.skus.map(s => `<span class="sku-pill">${s.code} · ${s.name}</span>`).join("");
        }

        // Partnerships
        const ps = brand.partnerships || [];
        const pEl = document.getElementById("partnerships");
        if (ps.length === 0) {
          pEl.innerHTML = '<div class="empty">Belum ada partner. <a href="/dashboard/brand/partnerships">Invite partner pertama</a>.</div>';
        } else {
          pEl.innerHTML = ps.map(p => `
            <div class="partner">
              <div>
                <div class="name">${p.tenant?.name || "(tenant?)"}</div>
                <div class="meta">${p.tenant?.address || p.tenant?.picPhoneE164 || ""}</div>
              </div>
              <div>
                <span class="badge ${p.status.toLowerCase()}">${p.status}</span>
              </div>
            </div>
          `).join("");
        }

        // Stok tersisa per partner
        const sisaEl = document.getElementById("sisa-list");
        if (active.length === 0) {
          sisaEl.innerHTML = `<div class="empty">Belum ada partner aktif.</div>`;
        } else {
          const today = new Date().toISOString().slice(0, 10);
          const cards = [];
          for (const p of active) {
            const r = await jget(`/v1/movements/sisa-sistem?partnershipId=${p.id}&upTo=${today}`);
            const rows = r.ok ? (r.data?.bySku || []) : [];
            if (rows.length === 0) {
              cards.push(`<div class="sisa-card"><div class="partner">${p.tenant?.name || "(tenant?)"}</div><div class="loading" style="padding:8px 0">Belum ada stok.</div></div>`);
              continue;
            }
            const pills = rows.map(row => {
              const sku = brand.skus.find(s => s.id === row.skuId);
              if (!sku) return "";
              const qty = row.sisa ?? 0;
              const cls = qty <= 0 ? "zero" : qty < 5 ? "low" : "ok";
              return `<span class="sisa-pill ${cls}">${sku.code}: ${qty}</span>`;
            }).join("");
            cards.push(`<div class="sisa-card"><div class="partner">${p.tenant?.name || "(tenant?)"}</div><div class="sisa-rows">${pills}</div></div>`);
          }
          sisaEl.innerHTML = cards.join("");
        }

        // Weekly revenue: pull movements from active partnerships, sum TERJUAL_OPENING qty for this week
        const weekStart = (() => {
          const d = new Date(); d.setDate(d.getDate() - ((d.getDay() + 6) % 7));
          return d.toISOString().slice(0, 10);
        })();
        let totalRp = 0;
        let totalUnits = 0;
        for (const p of active) {
          const r = await jget(`/v1/movements?partnershipId=${p.id}&from=${weekStart}`);
          if (!r.ok) continue;
          for (const mv of r.data || []) {
            if (mv.kind === "TERJUAL_OPENING" || mv.kind === "TERJUAL_CORRECTION") {
              const sku = brand.skus.find(s => s.id === mv.skuId);
              if (sku) {
                totalUnits += Math.abs(mv.qty);
                totalRp += Math.abs(mv.qty) * sku.priceIdr;
              }
            }
          }
        }
        document.getElementById("weekly-revenue").textContent = totalRp === 0
          ? "Rp 0"
          : new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", maximumFractionDigits: 0 }).format(totalRp);
      })();
    </script>
  </body>
</html>
