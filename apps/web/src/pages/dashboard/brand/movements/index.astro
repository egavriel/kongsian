---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../../../../lib/api";
import "../../../../styles/global.css";
const title = `Movements — ${APP_NAME}`;
---
<!doctype html>
<html lang="id">
  <head>
    <script src="/i18n-helper.js" is:inline></script>
    <script src="/theme-helper.js" is:inline></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: #090d16;
        color: #f1f5f9;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }
      a { color: #38bdf8; text-decoration: none; }
      .shell { max-width: 520px; margin: 0 auto; padding: 0 0 80px; }
      
      header.top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 2px solid #1e293b;
        position: sticky;
        top: 0;
        background: rgba(9, 13, 22, 0.95);
        backdrop-filter: blur(8px);
        z-index: 5;
      }
      .back {
        color: #94a3b8;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: color 0.15s ease;
      }
      .back:hover { color: #fbbf24; }
      h1 { font-size: 18px; font-weight: 900; margin: 0; text-transform: uppercase; letter-spacing: 0.03em; }
      main { padding: 20px; }
 
      /* Action Buttons */
      .new-btns {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 24px;
      }
      .new-btn {
        background: #0f172a;
        border: 2px solid #1e293b;
        color: #f1f5f9;
        border-radius: 14px;
        padding: 14px;
        text-align: center;
        font-size: 14px;
        font-weight: 800;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        box-shadow: 3px 3px 0px 0px #020617;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        cursor: pointer;
      }
      .new-btn:hover {
        transform: translate(-2px, -2px);
        box-shadow: 5px 5px 0px 0px #020617;
        text-decoration: none;
      }
      .new-btn.btn-titip:hover {
        border-color: #34d399;
        color: #34d399;
      }
      .new-btn.btn-tarik:hover {
        border-color: #fb7185;
        color: #fb7185;
      }
      .new-btn .btn-icon {
        font-size: 20px;
      }
 
      /* Partner Selection Row */
      .partner-label {
        font-size: 11px;
        color: #94a3b8;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 8px;
        display: block;
      }
      .partner-pick {
        display: flex;
        gap: 8px;
        margin-bottom: 20px;
        overflow-x: auto;
        padding-bottom: 6px;
        scrollbar-width: none;
      }
      .partner-pick::-webkit-scrollbar { display: none; }
      .partner-pick button {
        background: #0f172a;
        border: 2px solid #1e293b;
        color: #f1f5f9;
        padding: 8px 14px;
        border-radius: 10px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 700;
        white-space: nowrap;
        box-shadow: 2px 2px 0px 0px #020617;
        transition: all 0.15s ease;
      }
      .partner-pick button:hover {
        border-color: #fbbf24;
      }
      .partner-pick button.active {
        background: #fbbf24;
        color: #0b1220;
        border-color: #0b1220;
        box-shadow: 3px 3px 0px 0px #020617;
        transform: translate(-1px, -1px);
      }
 
      /* Filter Toggle pills */
      .filter {
        display: flex;
        gap: 8px;
        margin-bottom: 20px;
        overflow-x: auto;
        padding-bottom: 6px;
        scrollbar-width: none;
      }
      .filter::-webkit-scrollbar { display: none; }
      .filter button {
        background: #0f172a;
        border: 2px solid #1e293b;
        color: #f1f5f9;
        padding: 6px 14px;
        border-radius: 999px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 700;
        box-shadow: 2px 2px 0px 0px #020617;
        transition: all 0.15s ease;
      }
      .filter button:hover {
        border-color: #fbbf24;
      }
      .filter button.active {
        background: #fbbf24;
        color: #0b1220;
        border-color: #0b1220;
        box-shadow: 0 0 0 0 transparent;
        transform: translate(1px, 1px);
      }
 
      /* Movements List and Row Card */
      .list {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .mv {
        background: #0f172a;
        border: 2px solid #1e293b;
        border-radius: 16px;
        padding: 14px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 3px 3px 0px 0px #020617;
        transition: all 0.2s ease;
      }
      .mv:hover {
        border-color: #fbbf24;
        transform: translate(-1px, -1px);
        box-shadow: 4px 4px 0px 0px #020617;
      }
      .kind {
        font-size: 10px;
        padding: 4px 8px;
        border-radius: 8px;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        min-width: 80px;
        text-align: center;
        border: 1px solid transparent;
      }
      .kind.TITIP { background: rgba(52, 211, 153, 0.08); color: #34d399; border-color: rgba(52, 211, 153, 0.2); }
      .kind.TARIK { background: rgba(251, 113, 133, 0.08); color: #fb7185; border-color: rgba(251, 113, 133, 0.2); }
      .kind.TERJUAL_OPENING, .kind.TERJUAL_CORRECTION { background: rgba(251, 191, 36, 0.08); color: #fbbf24; border-color: rgba(251, 191, 36, 0.2); }
      .kind.ADJUSTMENT { background: rgba(56, 189, 248, 0.08); color: #38bdf8; border-color: rgba(56, 189, 248, 0.2); }
      
      .info { flex: 1; min-width: 0; }
      .info .sku { font-weight: 700; font-size: 14px; color: #ffffff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .info .meta { font-size: 12px; color: #94a3b8; margin-top: 2px; }
      
      .qty {
        font-weight: 800;
        font-size: 18px;
        min-width: 56px;
        text-align: right;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }
      .qty.pos { color: #34d399; }
      .qty.neg { color: #fb7185; }
 
      .thumb {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        background: #1e293b;
        border: 2px solid #1e293b;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-size: 18px;
        box-shadow: 2px 2px 0px 0px #020617;
        flex-shrink: 0;
      }
      .thumb img { width: 100%; height: 100%; object-fit: cover; }
      
      .empty {
        background: #0f172a;
        border: 2px dashed #1e293b;
        border-radius: 16px;
        padding: 32px 24px;
        text-align: center;
        color: #94a3b8;
        font-weight: 600;
      }
      .empty a {
        color: #fbbf24;
        text-decoration: underline;
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="top">
        <a class="back" href="/dashboard/brand">← Brand</a>
        <h1>Movements</h1>
        <div style="display:flex;align-items:center;gap:10px">
          <button id="theme-toggle" class="theme-toggle-btn">☕</button>
        </div>
      </header>
      <main>
        <div class="new-btns">
          <a href="/dashboard/brand/movements/new-titip" class="new-btn btn-titip">
            <span class="btn-icon">📦</span>
            <span class="btn-text">Kirim Titipan Stok</span>
          </a>
          <a href="/dashboard/brand/movements/new-tarik" class="new-btn btn-tarik">
            <span class="btn-icon">↩️</span>
            <span class="btn-text">Tarik Sisa Stok</span>
          </a>
        </div>
 
        <span class="partner-label">Pilih Partner Cafe</span>
        <div id="partner-pick" class="partner-pick"></div>
        
        <div class="filter">
          <button data-filter="ALL" class="active">Semua</button>
          <button data-filter="TITIP">Titip</button>
          <button data-filter="TARIK">Tarik</button>
          <button data-filter="TERJUAL">Terjual</button>
        </div>
        
        <div class="list" id="list">
          <div class="empty">Memuat…</div>
        </div>
      </main>
      <footer class="tagline-footer">
        Built with <a href="https://oatlet.com" target="_blank">Oatlet App</a> — Trusted and proudly used by <a href="https://www.instagram.com/littlehanniel" target="_blank">@littlehanniel</a>
      </footer>
    </div>
 
    <script define:vars={{ API_BASE_URL }}>
      const API = API_BASE_URL.replace(/\/$/, "");
      const tok = localStorage.getItem("kongsian_session");
      if (!tok) { window.location.href = "/login"; }
      const authH = { Authorization: `Bearer ${tok}`, "Content-Type": "application/json" };

      // Theme Toggle logic
      const toggleBtn = document.getElementById("theme-toggle");
      if (toggleBtn) {
        const updateThemeBtnText = (theme) => {
          toggleBtn.innerHTML = theme === "playful" ? "🌾" : "☕";
        };
        updateThemeBtnText(window.OatletTheme.getTheme());
        window.addEventListener("oatlet:themechange", (e) => {
          updateThemeBtnText(e.detail.theme);
        });
        toggleBtn.addEventListener("click", () => {
          window.OatletTheme.toggleTheme();
        });
      }

      async function jget(p) { return (await fetch(API+p, { headers: authH })).json().catch(()=>({})); }
 
      const state = { partnerships: [], skus: [], activePartner: null, filter: "ALL" };
      const pickEl = document.getElementById("partner-pick");
      const listEl = document.getElementById("list");
 
      function getLocale() {
        return localStorage.getItem("kongsian_lang") === "id" ? "id-ID" : "en-US";
      }
 
      function fmtDate(s) {
        const d = new Date(s);
        return new Intl.DateTimeFormat(getLocale(), { weekday:"short", day:"2-digit", month:"short" }).format(d);
      }
      function fmtDateTime(unix) {
        return new Date(unix * 1000).toLocaleString(getLocale(), { day:"2-digit", month:"short", hour:"2-digit", minute:"2-digit" });
      }
 
      function applyFilter() {
        document.querySelectorAll(".filter button").forEach(b => {
          b.classList.toggle("active", b.dataset.filter === state.filter);
        });
        render();
      }
 
      document.querySelectorAll(".filter button").forEach(b => {
        b.addEventListener("click", () => {
          state.filter = b.dataset.filter;
          applyFilter();
        });
      });
 
      function render() {
        if (!state.activePartner) {
          listEl.innerHTML = `<div class="empty">Pilih partnership di atas untuk lihat history.</div>`;
          return;
        }
        const all = state._movements || [];
        const skuMap = new Map(state.skus.map(s => [s.id, s]));
        const filtered = all.filter(m => {
          if (state.filter === "ALL") return true;
          if (state.filter === "TERJUAL") return m.kind.startsWith("TERJUAL");
          return m.kind === state.filter;
        });
        if (filtered.length === 0) {
          listEl.innerHTML = `<div class="empty">Belum ada movement untuk filter ini.</div>`;
          return;
        }
        listEl.innerHTML = filtered.map(m => {
          const sku = skuMap.get(m.skuId);
          const pos = m.qty > 0;
          const sign = pos ? "+" : "";
          const foto = m.fotoR2Key
            ? `<div class="thumb" title="ada foto"><img src="https://${(m.fotoR2Key.startsWith('http')?m.fotoR2Key: '')}" alt="foto" onerror="this.parentElement.textContent='📷'"/></div>`
            : `<div class="thumb">📦</div>`;
          const kindKey = m.kind.replace("TERJUAL_","").toLowerCase();
          return `
            <div class="mv">
              <span class="kind ${m.kind}"><span>${kindKey}</span></span>
              <div class="info">
                <div class="sku">${sku ? sku.code + " · " + sku.name : "(?)"}</div>
                <div class="meta">${fmtDate(m.movementDate)} · ${fmtDateTime(m.submittedAt)}</div>
              </div>
              ${foto}
              <div class="qty ${pos?"pos":"neg"}">${sign}${m.qty}</div>
            </div>
          `;
        }).join("");
      }
 
      async function loadMovements(pid) {
        state.activePartner = pid;
        const r = await jget(`/v1/movements?partnershipId=${pid}`);
        state._movements = r.ok ? (r.data || []) : [];
        render();
      }
 
      async function init() {
        const me = await jget("/v1/brands/me");
        if (!me.ok || !me.data.brandId) { window.location.href = "/dashboard/brand"; return; }
        const b = await jget(`/v1/brands/${me.data.brandId}`);
        if (!b.ok) { listEl.innerHTML = `<div class="empty">Gagal memuat brand.</div>`; return; }
        state.partnerships = b.data.partnerships || [];
        state.skus = b.data.skus || [];
        if (state.partnerships.length === 0) {
          listEl.innerHTML = `<div class="empty"><span>belum ada partnership.</span> <a href="/dashboard/brand/partnerships"><span>undang partner dulu</span></a>.</div>`;
          return;
        }
        pickEl.innerHTML = state.partnerships.map(p => `
          <button data-pid="${p.id}" class="${p.id === state.activePartner ? "active" : ""}">${p.tenant?.name || "?"}</button>
        `).join("");
        pickEl.querySelectorAll("button").forEach(btn => {
          btn.addEventListener("click", () => {
            pickEl.querySelectorAll("button").forEach(b => b.classList.remove("active"));
            btn.classList.add("active");
            loadMovements(btn.dataset.pid);
          });
        });
        await loadMovements(state.partnerships[0].id);
      }
      init();
    </script>
  </body>
</html>
