---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../../../../lib/api";
const title = `Catat Titip — ${APP_NAME}`;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body { margin:0; background:#0b1220; color:#f1f5f9; font-family:ui-sans-serif,system-ui,-apple-system,sans-serif; line-height:1.5; -webkit-font-smoothing:antialiased; }
      a { color:#38bdf8; text-decoration:none; }
      .shell { max-width:480px; margin:0 auto; padding:0 0 80px; }
      header.top { display:flex; align-items:center; justify-content:space-between; padding:16px 20px; border-bottom:1px solid #1e293b; position:sticky; top:0; background:rgba(11,18,32,.92); backdrop-filter:blur(6px); z-index:5; }
      .back { color:#94a3b8; font-size:14px; }
      h1 { font-size:20px; margin:0; }
      main { padding:20px; }
      label { display:flex; flex-direction:column; gap:6px; margin-bottom:14px; font-size:13px; }
      .lbl { font-weight:600; }
      select, input {
        background:#0b1220; border:1px solid #1e293b; color:#f1f5f9;
        padding:12px; border-radius:10px; font-size:16px; font-family:inherit; width:100%;
        min-height:48px;
      }
      select:focus, input:focus { outline:none; border-color:#fbbf24; }
      .btn { display:inline-flex; align-items:center; justify-content:center; gap:8px; padding:14px 20px; border-radius:10px; font-weight:600; border:1px solid transparent; cursor:pointer; font-size:16px; min-height:48px; }
      .btn-primary { background:#fbbf24; color:#0b1220; width:100%; }
      .btn-primary:hover { background:#f59e0b; }
      .btn-primary:disabled { opacity:.5; cursor:not-allowed; }
      .btn-ghost { background:transparent; color:#f1f5f9; border-color:#1e293b; }
      .row2 { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
      .sku-table { background:#0f172a; border:1px solid #1e293b; border-radius:12px; padding:12px; margin-bottom:16px; }
      .sku-table h2 { margin:0 0 10px; font-size:15px; color:#fbbf24; }
      :global(.sk-row) { display:grid; grid-template-columns:1fr 150px; gap:10px; align-items:center; padding:8px 0; border-bottom:1px solid #1e293b; }
      :global(.sk-row:last-child) { border-bottom:none; }
      :global(.sk-label) { font-size:14px; }
      :global(.sk-label .code) { color:#fbbf24; font-weight:700; margin-right:6px; }
      :global(.sk-label .name) { color:#f1f5f9; }
      :global(.sk-label .meta) { color:#94a3b8; font-size:12px; }
      :global(.sk-row input) { padding:10px; text-align:center; font-size:16px; min-height:48px; }
      :global(.stepper) { display:grid; grid-template-columns:44px 1fr 44px; gap:6px; align-items:stretch; }
      :global(.stepper .step-btn) { background:#0b1220; border:1px solid #1e293b; color:#f1f5f9; border-radius:10px; font-size:20px; font-weight:700; min-height:48px; cursor:pointer; padding:0; line-height:1; }
      :global(.stepper .step-btn:active) { background:#1e293b; }
      :global(.stepper .step-btn:disabled) { opacity:.4; cursor:not-allowed; }
      :global(.stepper input) { width:100%; }
      .empty { background:#0f172a; border:1px dashed #1e293b; border-radius:12px; padding:24px; text-align:center; color:#94a3b8; }
      .err { background:rgba(251,113,133,.12); color:#fb7185; border:1px solid rgba(251,113,133,.3); padding:10px 12px; border-radius:10px; font-size:13px; margin-bottom:12px; }
      .ok { background:rgba(52,211,153,.12); color:#34d399; border:1px solid rgba(52,211,153,.3); padding:10px 12px; border-radius:10px; font-size:13px; margin-bottom:12px; }
      .foto { background:#0f172a; border:1px solid #1e293b; border-radius:12px; padding:12px; margin-bottom:16px; }
      .foto h2 { margin:0 0 8px; font-size:15px; color:#fbbf24; }
      .foto input[type=file] { padding:8px; background:transparent; border:none; color:#94a3b8; font-size:13px; }
      .foto .preview { margin-top:8px; }
      .foto .preview img { max-width:120px; border-radius:8px; border:1px solid #1e293b; }
      .section-title { font-size:13px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.06em; font-weight:700; margin:20px 0 8px; }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="top">
        <a class="back" href="/dashboard/brand/movements">← Movements</a>
        <h1>Catat Titip</h1>
        <span></span>
      </header>
      <main>
        <div id="err" class="err" style="display:none"></div>
        <div id="ok" class="ok" style="display:none"></div>

        <label>
          <span class="lbl">Pilih partnership (partner)</span>
          <select id="partnership"></select>
        </label>

        <label>
          <span class="lbl">Tanggal titip</span>
          <input id="date" type="date" required />
        </label>

        <div class="section-title">SKU yang akan dititipkan</div>
        <div id="sku-section" class="sku-table">
          <div class="empty">Pilih partnership dulu.</div>
        </div>

        <div class="foto">
          <h2>Foto titipan (opsional)</h2>
          <input id="foto" type="file" accept="image/*" capture="environment" />
          <div id="preview" class="preview"></div>
        </div>

        <button id="submit-btn" class="btn btn-primary" type="button" disabled>Simpan Titip</button>
      </main>
    </div>

    <script define:vars={{ API_BASE_URL }}>
      const API = API_BASE_URL.replace(/\/$/, "");
      const tok = localStorage.getItem("kongsian_session");
      if (!tok) { window.location.href = "/login"; }
      const authH = { Authorization: `Bearer ${tok}`, "Content-Type": "application/json" };
      async function jget(p) { return (await fetch(API+p, { headers: authH })).json().catch(()=>({})); }
      function attachQtyStrip() {
        document.querySelectorAll("#sku-section .stepper").forEach(stepper => {
          const inp = stepper.querySelector("input[data-sku]");
          const minus = stepper.querySelector(".step-btn.minus");
          const plus = stepper.querySelector(".step-btn.plus");
          if (!inp) return;
          const clamp = () => {
            const max = inp.hasAttribute("max") ? parseInt(inp.getAttribute("max"), 10) : null;
            let v = parseInt((inp.value || "0").replace(/\D/g, ""), 10) || 0;
            if (v < 0) v = 0;
            if (max != null && v > max) v = max;
            if (String(v) !== inp.value) inp.value = String(v);
            if (minus) minus.disabled = v <= 0;
            if (plus) plus.disabled = (max != null && v >= max);
          };
          inp.addEventListener("input", clamp);
          if (minus) minus.addEventListener("click", () => { if (inp.disabled) return; inp.value = String(Math.max(0, (parseInt((inp.value||"0").replace(/\D/g,""),10)||0) - 1)); clamp(); });
          if (plus)  plus.addEventListener("click", () => { if (inp.disabled) return; inp.value = String(((parseInt((inp.value||"0").replace(/\D/g,""),10)||0) + 1)); clamp(); });
          clamp();
        });
      }

      const errEl = document.getElementById("err");
      const okEl = document.getElementById("ok");
      const showErr = m => { errEl.textContent = m; errEl.style.display="block"; okEl.style.display="none"; };
      const showOk = m => { okEl.textContent = m; okEl.style.display="block"; errEl.style.display="none"; };

      const state = { brandId: null, partnerships: [], skus: [], partnershipId: null };

      // Default date = today (local)
      document.getElementById("date").value = new Date().toISOString().slice(0, 10);

      function fmtRp(n) { return new Intl.NumberFormat("id-ID", { style:"currency", currency:"IDR", maximumFractionDigits:0 }).format(n); }

      async function loadPartnerships() {
        const r = await jget("/v1/ops/init");
        if (!r.ok) {
          if (r.error?.code === "VERIFICATION_PENDING") {
            window.location.href = "/login?registered=1";
            return;
          }
          window.location.href = "/dashboard/brand";
          return;
        }

        const { brandId, skus, partnerships } = r.data;
        state.brandId = brandId;
        state.skus = skus || [];
        state.partnerships = partnerships || [];

        if (state.partnerships.length === 0) {
          document.getElementById("partnership").innerHTML = `<option value="">— Belum ada partner aktif —</option>`;
          return;
        }
        document.getElementById("partnership").innerHTML = `<option value="">— Pilih partner —</option>` +
          state.partnerships.map(p => `<option value="${p.id}">${p.tenant?.name || "(tenant?)"}</option>`).join("");
      }

      function renderSkus() {
        const sec = document.getElementById("sku-section");
        if (!state.partnershipId) {
          sec.innerHTML = `<div class="empty">Pilih partnership dulu.</div>`;
          document.getElementById("submit-btn").disabled = true;
          return;
        }
        if (state.skus.length === 0) {
          sec.innerHTML = `<div class="empty">Belum ada SKU di brand ini. <a href="/dashboard/brand/skus">Tambah SKU</a> dulu.</div>`;
          document.getElementById("submit-btn").disabled = true;
          return;
        }
        sec.innerHTML = state.skus.map(s => `
          <div class="sk-row">
            <div class="sk-label">
              <div><span class="code">${s.code}</span><span class="name">${s.name}</span></div>
              <div class="meta">${fmtRp(s.priceIdr)}</div>
            </div>
            <div class="stepper">
              <button type="button" class="step-btn minus" aria-label="Kurangi">−</button>
              <input type="number" min="0" max="999" step="1" data-sku="${s.id}" placeholder="0" inputmode="numeric" />
              <button type="button" class="step-btn plus" aria-label="Tambah">+</button>
            </div>
          </div>
        `).join("");
        document.getElementById("submit-btn").disabled = false;
        attachQtyStrip();
      }

      document.getElementById("partnership").addEventListener("change", (e) => {
        const pid = e.target.value;
        state.partnershipId = pid || null;
        renderSkus();
      });

      // Photo upload preview + R2
      let uploadedFotoUrl = null;
      document.getElementById("foto").addEventListener("change", async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        const prev = document.getElementById("preview");
        prev.innerHTML = `<span style="color:#94a3b8;font-size:12px">Uploading…</span>`;
        const fd = new FormData();
        fd.append("file", file);
        fd.append("kind", "titip");
        const res = await fetch(API + "/v1/uploads", {
          method: "POST",
          headers: { Authorization: `Bearer ${tok}` },
          body: fd,
        });
        const json = await res.json().catch(() => ({}));
        if (!res.ok || !json.ok) {
          prev.innerHTML = `<span style="color:#fb7185;font-size:12px">Gagal upload foto.</span>`;
          uploadedFotoUrl = null;
          return;
        }
        uploadedFotoUrl = json.data?.url || null;
        prev.innerHTML = uploadedFotoUrl
          ? `<img src="${uploadedFotoUrl}" alt="foto" />`
          : `<span style="color:#94a3b8;font-size:12px">Foto tersimpan.</span>`;
      });

      document.getElementById("submit-btn").addEventListener("click", async () => {
        errEl.style.display = "none"; okEl.style.display = "none";
        if (!state.partnershipId) { showErr("Pilih partnership dulu."); return; }
        const date = document.getElementById("date").value;
        if (!date) { showErr("Tanggal wajib."); return; }
        const rows = document.querySelectorAll("#sku-section input[data-sku]");
        const items = [];
        for (const inp of rows) {
          const v = parseInt((inp.value || "0").replace(/\D/g, ""), 10) || 0;
          if (v > 0) items.push({ skuId: inp.dataset.sku, kind: "TITIP", qty: v });
        }
        if (items.length === 0) { showErr("Isi minimal 1 SKU dengan qty > 0."); return; }

        const btn = document.getElementById("submit-btn");
        btn.disabled = true; btn.textContent = "Menyimpan…";
        try {
          // v2: deterministic idempotency in BODY (server suffixes -<skuId> per row).
          const batchIdempotencyKey = `titip-${state.partnershipId}-${date}`;
          const r = await fetch(API + "/v1/movements/batch", {
            method: "POST",
            headers: { ...authH },
            body: JSON.stringify({
              partnershipId: state.partnershipId,
              movementDate: date,
              items,
              batchIdempotencyKey,
              fotoR2Key: uploadedFotoUrl || undefined,
            }),
          });
          const json = await r.json().catch(() => ({}));
          if (r.ok && json.ok) {
            showOk(`Berhasil: ${items.length} SKU dititipkan.`);
            setTimeout(() => { window.location.href = "/dashboard/brand/movements"; }, 800);
            return;
          }
          showErr("Gagal: " + (json?.error?.code || `HTTP ${r.status}`));
        } catch (e) {
          showErr("Tidak bisa konek ke server.");
        } finally {
          btn.disabled = false; btn.textContent = "Simpan Titip";
        }
      });

      loadPartnerships();
    </script>
  </body>
</html>
