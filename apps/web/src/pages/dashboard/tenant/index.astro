---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../../../lib/api";
import NotificationBell from "../../../components/NotificationBell.astro";
import "../../../styles/global.css";
const title = `Dashboard — ${APP_NAME}`;
---
<!doctype html>
<html lang="id">
  <head>
    <script src="/i18n-helper.js" is:inline></script>
    <script src="/theme-helper.js" is:inline></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body { margin:0; background:#0b1220; color:#f1f5f9; font-family:ui-sans-serif,system-ui,-apple-system,sans-serif; line-height:1.5; -webkit-font-smoothing:antialiased; }
      a { color:#38bdf8; text-decoration:none; }
      a:hover { text-decoration:underline; }
      .shell { max-width:480px; margin:0 auto; padding:0 0 80px; }
      header.top {
        display:flex; align-items:center; justify-content:space-between;
        padding:16px 20px; border-bottom:1px solid #1e293b;
        position:sticky; top:0; background:rgba(11,18,32,.92);
        backdrop-filter:blur(6px); z-index:5;
      }
      .role-tag { font-size:11px; padding:2px 8px; border-radius:999px; background:#38bdf8; color:#0b1220; font-weight:700; letter-spacing:0.04em; }
      .logout { font-size:13px; color:#94a3b8; background:none; border:none; cursor:pointer; }
      .logout:hover { color:#f1f5f9; }
      main { padding:20px; }
      .greet { font-size:14px; color:#94a3b8; margin:0 0 4px; }
      h1 { font-size:24px; margin:0 0 4px; letter-spacing:-0.01em; }
      .sub { color:#94a3b8; font-size:13px; margin:0 0 20px; }

      .task-card {
        background: linear-gradient(135deg, rgba(251,191,36,.15), rgba(251,191,36,.05));
        border: 1px solid #fbbf24;
        border-radius: 14px;
        padding: 20px;
        margin-bottom: 24px;
      }
      .task-card .ic { font-size:24px; margin-bottom:8px; display:block; }
      .task-card .tt { font-weight:700; font-size:17px; margin-bottom:4px; }
      .task-card .desc { font-size:13px; color:#cbd5e1; margin-bottom:14px; }
      .task-card .row { display:flex; align-items:center; justify-content:space-between; gap:10px; }
      .task-card .deadline { font-size:12px; color:#fbbf24; }
      .task-card.done { background: linear-gradient(135deg, rgba(52,211,153,.12), rgba(52,211,153,.04)); border-color:#34d399; }
      .task-card.done .tt { color:#34d399; }

      .btn {
        display:inline-flex; align-items:center; justify-content:center; gap:8px;
        padding:14px 20px; border-radius:10px; font-weight:600;
        border:1px solid transparent; cursor:pointer; font-size:15px;
        text-decoration:none; min-height:48px;
      }
      .btn-primary { background:#fbbf24; color:#0b1220; }
      .btn-primary:hover { background:#f59e0b; text-decoration:none; }
      .btn-ghost { background:transparent; color:#f1f5f9; border-color:#1e293b; }
      .btn-ghost:hover { border-color:#94a3b8; text-decoration:none; }

      h2 { font-size:13px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.06em; font-weight:700; margin:24px 0 12px; }

      .partner {
        background:#0f172a; border:1px solid #1e293b; border-radius:12px; padding:14px;
        margin-bottom:10px; display:flex; align-items:center; justify-content:space-between; gap:10px;
      }
      .partner .name { font-weight:600; }
      .partner .meta { font-size:12px; color:#94a3b8; }

      .sku-list { display:flex; flex-direction:column; gap:8px; }
      .sku-row {
        background:#0f172a; border:1px solid #1e293b; border-radius:10px; padding:12px;
        display:grid; grid-template-columns:1fr auto; gap:10px; align-items:center;
      }
      .sku-row .code { color:#fbbf24; font-weight:700; margin-right:6px; }
      .sku-row .name { font-weight:600; }
      .sku-row .price { font-size:12px; color:#94a3b8; }

      .empty {
        background:#0f172a; border:1px dashed #1e293b; border-radius:12px;
        padding:24px; text-align:center; color:#94a3b8;
      }
      .loading { color:#94a3b8; text-align:center; padding:24px; }
      .err { background:rgba(251,113,133,.12); color:#fb7185; border:1px solid rgba(251,113,133,.3); padding:12px; border-radius:10px; font-size:14px; }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="top">
        <div style="font-weight:700;font-size:15px">{APP_NAME}</div>
        <div style="display:flex;align-items:center;gap:10px">
          <button id="theme-toggle" class="theme-toggle-btn">☕</button>
          <NotificationBell />
          <span class="role-tag">TENANT</span>
          <button id="logout" class="logout">Keluar</button>
        </div>
      </header>
      <main>
        <p class="greet" id="greet">Halo, …</p>
        <h1 id="tenant-name">Dashboard</h1>
        <p class="sub" id="date-line"></p>

        <div id="task-card" class="task-card">
          <span class="ic">⏰</span>
          <div class="tt" id="task-title">Tugas hari ini</div>
          <div class="desc" id="task-desc">Input Terjual + Sisa Fisik untuk semua SKU titipan hari ini.</div>
          <div class="row">
            <span class="deadline" id="task-deadline">Deadline: 23:59 WIB</span>
            <a id="task-cta" class="btn btn-primary" href="/dashboard/tenant/closing">Buka Form</a>
          </div>
        </div>

        <h2>Brand partner</h2>
        <div id="partners">
          <div class="loading">Memuat…</div>
        </div>

        <h2>Link cepat</h2>
        <div style="display:flex;flex-direction:column;gap:8px">
          <a class="btn btn-ghost" href="/dashboard/tenant/disputes" style="text-align:left">Lihat Disputes →</a>
        </div>

        <h2>SKU tersedia</h2>
        <div id="skus" class="sku-list">
          <div class="loading">Memuat…</div>
        </div>
      </main>
      <footer class="tagline-footer">
        Built with <a href="https://oatlet.com" target="_blank">Oatlet App</a> — Trusted and proudly used by <a href="https://www.instagram.com/littlehanniel" target="_blank">@littlehanniel</a>
      </footer>
    </div>

    <script define:vars={{ API_BASE_URL }}>
      window.__KONGSIAN_API__ = API_BASE_URL;
      const API = API_BASE_URL.replace(/\/$/, "");
      const tok = localStorage.getItem("kongsian_session");
      if (!tok) { window.location.href = "/login"; }
      const authH = { Authorization: `Bearer ${tok}`, "Content-Type": "application/json" };
      async function jget(p) { return (await fetch(API+p, { headers: authH })).json().catch(()=>({})); }

      // Theme Toggle logic
      const toggleBtn = document.getElementById("theme-toggle");
      if (toggleBtn) {
        const updateThemeBtnText = (theme) => {
          toggleBtn.innerHTML = theme === "playful" ? "🌾" : "☕";
        };
        updateThemeBtnText(window.OatletTheme.getTheme());
        window.addEventListener("oatlet:themechange", (e) => {
          updateThemeBtnText(e.detail.theme);
        });
        toggleBtn.addEventListener("click", () => {
          window.OatletTheme.toggleTheme();
        });
      }

      function fmtRp(n) { return new Intl.NumberFormat("id-ID", { style:"currency", currency:"IDR", maximumFractionDigits:0 }).format(n); }
      function fmtDateLong() {
        return new Intl.DateTimeFormat("id-ID", { weekday:"long", day:"2-digit", month:"long", year:"numeric" }).format(new Date());
      }

      document.getElementById("date-line").textContent = fmtDateLong();

      document.getElementById("logout").addEventListener("click", async () => {
        try { await fetch(API + "/v1/auth/logout", { method: "POST", headers: { Authorization: `Bearer ${tok}` } }); } catch {}
        localStorage.removeItem("kongsian_session");
        window.location.href = "/login";
      });

      (async () => {
        // P0 #3: verify the session belongs to a verified user before showing
        // the dashboard. /v1/me returns verificationStatus; if PENDING, bounce.
        const me = await jget("/v1/me");
        if (!me.ok) { window.location.href = "/login"; return; }
        if (me.data?.verificationStatus === "PENDING_VERIFICATION" || me.data?.verificationStatus === "REJECTED") {
          window.location.href = "/login?registered=1";
          return;
        }
        const tenant = await jget("/v1/tenants/me");
        if (!me.ok) {
          document.querySelector("main").innerHTML =
            `<div class="err">Akun tenant tidak ditemukan. <a href="/login">Login ulang</a>.</div>`;
          return;
        }
        const { tenant: tenantData, partnerships, skus } = me.data;
        document.getElementById("greet").textContent = `${window.t('Halo')}, ${tenantData.name || "Tenant"}`;
        document.getElementById("tenant-name").textContent = tenantData.name || "Dashboard";

        // Partners
        const pEl = document.getElementById("partners");
        const active = (partnerships || []).filter(p => p.status === "ACTIVE");
        if (active.length === 0) {
          pEl.innerHTML = `<div class="empty">${window.t('Belum ada brand partner aktif. Tunggu brand invite kamu.')}</div>`;
        } else {
          pEl.innerHTML = active.map(p => `
            <div class="partner">
              <div>
                <div class="name">${p.brand?.name || "(brand?)"}</div>
                <div class="meta">${p.tenantSplitBps ? "Split " + (p.tenantSplitBps/100) + "%" : ""}</div>
              </div>
              <span style="color:#34d399;font-size:12px;font-weight:700">AKTIF</span>
            </div>
          `).join("");
        }

        // SKUs
        const sEl = document.getElementById("skus");
        const flat = (skus || []).filter(s => s.active !== false);
        if (flat.length === 0) {
          sEl.innerHTML = `<div class="empty">${window.t('Belum ada SKU yang bisa kamu jual.')}</div>`;
        } else {
          sEl.innerHTML = flat.map(s => `
            <div class="sku-row">
              <div>
                <span class="code">${s.code}</span><span class="name">${s.name}</span>
                <div class="price">${fmtRp(s.priceIdr || 0)} · ${s.brandName || ""}</div>
              </div>
            </div>
          `).join("");
        }

        // Check closing status for today
        if (active.length > 0) {
          const today = new Date().toISOString().slice(0, 10);
          const pid = active[0].id;
          const closing = await jget(`/v1/tenants/${tenantData.id}/partnerships/${pid}/closings/${today}`);
          if (closing.ok && closing.data?.submitted) {
            const card = document.getElementById("task-card");
            card.classList.add("done");
            document.getElementById("task-title").textContent = window.t("Closing hari ini sudah masuk ✓");
            document.getElementById("task-desc").textContent = window.t("Terima kasih. Brand akan review dan kirim settlement.");
            const cta = document.getElementById("task-cta");
            cta.textContent = window.t("Lihat Riwayat");
            cta.href = "/dashboard/tenant/closing";
          }
        }
      })();
    </script>
  </body>
</html>
