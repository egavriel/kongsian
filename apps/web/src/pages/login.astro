---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../lib/api";
import "../styles/global.css";
const title = `Masuk — ${APP_NAME}`;
// ?registered=1 banner shown when user just registered
const showRegisteredBanner = Astro.url.searchParams.get("registered") === "1";
// ?phone=628xxx deep-link pre-fill (from WA invites / shared links).
// We accept digits-only, with or without leading +. Stored on the input
// via data-attribute so the inline script can pick it up.
const phoneParam = (Astro.url.searchParams.get("phone") ?? "").trim();
---
<!doctype html>
<html lang="id">
  <head>
    <script src="/i18n-helper.js" is:inline></script>
    <script src="/theme-helper.js" is:inline></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: #0b1220;
        color: #f1f5f9;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        line-height: 1.55;
      }
      a { color: #38bdf8; text-decoration: none; }
      .wrap { max-width: 460px; margin: 0 auto; padding: 32px 20px 80px; }
      .back { font-size: 14px; color: #94a3b8; }
      .card {
        background: #0f172a;
        border: 1px solid #1e293b;
        border-radius: 14px;
        padding: 28px;
        margin-top: 24px;
      }
      .eyebrow { color: #fbbf24; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; }
      h1 { margin: 8px 0 12px; font-size: 28px; line-height: 1.15; }
      p { color: #94a3b8; margin: 0 0 24px; }
      label { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
      .lbl { font-size: 13px; font-weight: 600; }
      input {
        background: #0b1220;
        border: 1px solid #1e293b;
        color: #f1f5f9;
        padding: 14px 14px;
        border-radius: 10px;
        font-size: 16px;
        font-family: inherit;
        width: 100%;
      }
      input:focus { outline: none; border-color: #fbbf24; box-shadow: 0 0 0 3px rgba(251, 191, 36, .15); }
      .phone-container {
        display: flex;
        gap: 8px;
        align-items: stretch;
      }
      .country-select {
        flex-shrink: 0;
        width: 110px;
        background: #0b1220;
        border: 1px solid #1e293b;
        color: #f1f5f9;
        padding: 14px 10px;
        border-radius: 10px;
        font-size: 15px;
        font-family: inherit;
        font-weight: 700;
        cursor: pointer;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
      }
      .country-select:focus {
        outline: none;
        border-color: #fbbf24;
        box-shadow: 0 0 0 3px rgba(251, 191, 36, .15);
      }
      .phone-input-wrap {
        flex: 1;
        position: relative;
      }
      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        padding: 14px 20px; border-radius: 10px; font-weight: 600;
        border: 1px solid transparent; cursor: pointer; font-size: 16px;
        width: 100%;
      }
      .btn-primary { background: #fbbf24; color: #0b1220; }
      .btn-primary:hover { background: #f59e0b; }
      .btn-ghost { background: transparent; color: #f1f5f9; border-color: #1e293b; }
      .btn:disabled { opacity: .5; cursor: not-allowed; }
      .err {
        background: rgba(251, 113, 133, .12);
        color: #fb7185;
        border: 1px solid rgba(251, 113, 133, .3);
        padding: 10px 12px; border-radius: 10px;
        font-size: 14px; margin-bottom: 16px;
      }
      .info {
        background: rgba(56, 189, 248, .1);
        color: #38bdf8;
        border: 1px solid rgba(56, 189, 248, .3);
        padding: 10px 12px; border-radius: 10px;
        font-size: 14px; margin-bottom: 16px;
      }
      .dev-code {
        font-family: ui-monospace, monospace;
        font-size: 22px; letter-spacing: 4px;
        background: #0b1220; border: 1px dashed #fbbf24;
        padding: 12px 16px; border-radius: 10px;
        text-align: center; color: #fbbf24; margin: 8px 0 16px;
      }
      .step2 { margin-top: 28px; padding-top: 24px; border-top: 1px solid #1e293b; display: none; }
      .step2.show { display: block; }
      .small { font-size: 13px; color: #94a3b8; }
      .muted { color: #94a3b8; }
      /* P0 #3: blocking verification modal */
      .block-modal {
        position: fixed; inset: 0; background: rgba(11, 18, 32, .85);
        display: none; align-items: center; justify-content: center;
        z-index: 50; padding: 20px;
      }
      .block-modal.show { display: flex; }
      .block-card {
        background: #0f172a; border: 1px solid #fbbf24; border-radius: 14px;
        padding: 28px; max-width: 420px; width: 100%; text-align: center;
      }
      .block-card .ic { font-size: 40px; display: block; margin-bottom: 12px; }
      .block-card .tt { font-weight: 700; font-size: 20px; margin-bottom: 8px; }
      .block-card .msg { color: #94a3b8; font-size: 14px; margin-bottom: 20px; }
    </style>
  </head>
  <body>
    <main class="wrap">
      <a class="back" href="/">← Kembali</a>
      <div class="card">
        {showRegisteredBanner && (
          <div class="info" style="margin-bottom:16px">
            <strong>Akun kamu sedang diverifikasi admin. Strong> Kami akan kabari via WA max 1x24 jam. Untuk sekarang kamu bisa login, tapi dashboard akan terbuka setelah admin approve.
          </div>
        )}
        <span class="eyebrow">Masuk</span>
        <h1>Selamat datang kembali</h1>
        <p>Masukin nomor WhatsApp kamu. Kami kirim OTP 6 digit.</p>

        <div id="err" class="err" style="display:none"></div>
        <div id="info" class="info" style="display:none"></div>

        <form id="otp-form">
          <label>
            <span class="lbl">Nomor HP / WhatsApp</span>
            <div class="phone-container">
              <select id="country-code" class="country-select">
                <option value="+62">🇮🇩 +62</option>
                <option value="+65">🇸🇬 +65</option>
                <option value="+60">🇲🇾 +60</option>
              </select>
              <div class="phone-input-wrap">
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  inputmode="tel"
                  autocomplete="tel"
                  placeholder="812 1234 5678"
                  required
                  data-prefill={phoneParam}
                />
              </div>
            </div>
            <span class="small muted" id="phone-hint">Pilih kode negara & masukkan nomor tanpa angka 0 di depan.</span>
          </label>
          <button class="btn btn-primary" type="submit" id="send-btn">Kirim OTP via WhatsApp</button>
          <p class="small" style="margin-top:16px">
            Belum punya akun? Prosesnya &lt; 10 menu — kami auto-create akun pas verifikasi pertama.
          </p>
        </form>

        <div id="step2" class="step2">
          <span class="eyebrow">Step 2 of 2</span>
          <h2>Masukin kode OTP</h2>
          <p class="small">Dikirim ke <span id="otp-phone" class="muted"></span>. Berlaku 5 menit.</p>
          <div id="dev-code" class="dev-code" style="display:none"></div>
          <form id="verify-form">
            <label>
              <span class="lbl">6-digit kode</span>
              <input id="code" name="code" type="text" inputmode="numeric" autocomplete="one-time-code"
                     maxlength="6" placeholder="123456" required />
            </label>
            <button class="btn btn-primary" type="submit" id="verify-btn">Verifikasi</button>
            <button class="btn btn-ghost" type="button" id="resend" style="margin-top:8px">Kirim ulang</button>
          </form>
        </div>
      </div>
    </main>

    <!-- P0 #3: verification blocking modal -->
    <div id="verify-block" class="block-modal" role="dialog" aria-modal="true">
      <div class="block-card">
        <span class="ic">⏳</span>
        <div class="tt">Akun kamu belum diverifikasi admin</div>
        <div class="msg" id="verify-block-msg">Tunggu max 1x24 jam. Kami kabari via WhatsApp setelah approve.</div>
        <button class="btn btn-ghost" id="verify-block-logout">Keluar</button>
      </div>
    </div>

    <script define:vars={{ API_BASE_URL }}>
      const API = API_BASE_URL.replace(/\/$/, "");
      const $ = (s) => document.querySelector(s);
      const err = $("#err"), info = $("#info");
      const showErr = (m) => { err.textContent = m; err.style.display = "block"; info.style.display = "none"; };
      const showInfo = (m) => { info.textContent = m; info.style.display = "block"; err.style.display = "none"; };
      const hideMsg = () => { err.style.display = "none"; info.style.display = "none"; };
      const showVerificationBlock = (msg) => {
        document.getElementById("verify-block-msg").textContent = msg;
        document.getElementById("verify-block").classList.add("show");
        // Hide the OTP card so it cannot be interacted with.
        document.querySelector(".card").style.display = "none";
      };
      document.getElementById("verify-block-logout").addEventListener("click", () => {
        localStorage.removeItem("kongsian_session");
        window.location.href = "/login?registered=1";
      });

      let lastPhone = "";
      let isSending = false;

      // ---- Phone normalization & Country Code setup ----
      const countrySelect = $("#country-code");
      const phoneInput = $("#phone");
      
      const PLACEHOLDERS = {
        "+62": "812 1234 5678",
        "+65": "8123 4567",
        "+60": "12 345 6789"
      };

      countrySelect.addEventListener("change", () => {
        const code = countrySelect.value;
        phoneInput.placeholder = PLACEHOLDERS[code] || "";
      });

      function parsePrefill(raw) {
        let digits = String(raw).replace(/[^\d]/g, "");
        if (!digits) return { code: "+62", rest: "" };

        if (digits.startsWith("62")) {
          return { code: "+62", rest: digits.slice(2) };
        } else if (digits.startsWith("65")) {
          return { code: "+65", rest: digits.slice(2) };
        } else if (digits.startsWith("60")) {
          return { code: "+60", rest: digits.slice(2) };
        }

        if (digits.startsWith("0")) {
          return { code: "+62", rest: digits.slice(1) };
        }

        return { code: "+62", rest: digits };
      }

      const prefill = (phoneInput.dataset.prefill || "").trim();
      if (prefill) {
        const parsed = parsePrefill(prefill);
        countrySelect.value = parsed.code;
        phoneInput.value = parsed.rest;
        phoneInput.placeholder = PLACEHOLDERS[parsed.code] || "";
      }

      phoneInput.addEventListener("blur", () => {
        let core = phoneInput.value.replace(/[^\d]/g, "");
        if (core.startsWith("0")) core = core.slice(1);
        phoneInput.value = core;
      });

      async function sendOtp(phone, btn) {
        if (isSending) return false;
        isSending = true;
        if (btn) { btn.disabled = true; btn.textContent = window.t("Mengirim…"); }
        try {
          const res = await fetch(`${API}/v1/auth/otp/request`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ phone, purpose: "LOGIN" }),
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok || !json.ok) {
            const code = json?.error?.code;
            if (code === "OTP_RATE_LIMITED") {
              showErr(window.t("Kebanyakan percobaan. Coba lagi ~1 jam."));
            } else {
              showErr(window.t("Gagal kirim OTP. Coba lagi."));
            }
            return false;
          }
          lastPhone = phone;
          $("#otp-phone").textContent = phone;
          $("#step2").classList.add("show");
          $("#otp-form").style.display = "none";
          if (json.data?.devCode) {
            $("#dev-code").textContent = json.data.devCode;
            $("#dev-code").style.display = "block";
            $("#code").value = json.data.devCode;
            showInfo(window.t("Dev mode: kode OTP sudah diisi otomatis di bawah."));
          } else {
            showInfo(window.t("OTP dikirim. Cek WhatsApp kamu."));
          }
          return true;
        } catch (e) {
          // Surface the real error to console so a phone-browser user (no
          // DevTools) can copy/paste it from a remote-debug session or the
          // Auth-bus logs. Old message swallowed the cause entirely.
          // eslint-disable-next-line no-console
          console.error("[login] sendOtp fetch failed:", e, { url: `${API}/v1/auth/otp/request` });
          const cause = (e && (e.message || e.name)) || "unknown";
          showErr(`${window.t('Tidak bisa konek ke server')} (${cause}). Hard-refresh (Ctrl+Shift+R).`);
          return false;
        } finally {
          isSending = false;
          if (btn) { btn.disabled = false; btn.textContent = window.t("Kirim OTP via WhatsApp"); }
        }
      }

      $("#otp-form").addEventListener("submit", async (e) => {
        e.preventDefault();
        hideMsg();
        
        let core = phoneInput.value.replace(/[^\d]/g, "");
        if (core.startsWith("0")) core = core.slice(1);
        phoneInput.value = core;
        
        const phone = countrySelect.value + core;
        if (!/^\+[1-9]\d{7,14}$/.test(phone)) {
          showErr(window.t("Nomor HP tidak valid. Silakan masukkan nomor yang benar."));
          return;
        }
        await sendOtp(phone, $("#send-btn"));
      });

      // Strip non-digits from the OTP field on every input — the WhatsApp
      // message wraps the code in `*asterisks*` for emphasis and tap-to-copy
      // sometimes grabs the asterisks too. The input no longer has an HTML
      // `pattern` attribute (it fires before JS and blocks submit on pasted
      // asterisks); we rely on this oninput strip + the submit-time check.
      const codeEl = $("#code");
      if (codeEl) {
        codeEl.addEventListener("input", () => {
          const cleaned = codeEl.value.replace(/\D/g, "").slice(0, 6);
          if (codeEl.value !== cleaned) codeEl.value = cleaned;
        });
      }
      function normalizeOtp() {
        if (!codeEl) return;
        const cleaned = codeEl.value.replace(/\D/g, "").slice(0, 6);
        if (codeEl.value !== cleaned) codeEl.value = cleaned;
      }

      $("#verify-form").addEventListener("submit", async (e) => {
        e.preventDefault();
        hideMsg();
        normalizeOtp();
        const code = $("#code").value.trim();
        if (!/^\d{6}$/.test(code)) { showErr(window.t("Kode harus 6 digit angka.")); return; }
        const btn = $("#verify-btn"); btn.disabled = true; btn.textContent = window.t("Memverifikasi…");
        try {
          const res = await fetch(`${API}/v1/auth/otp/verify`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ phone: lastPhone, code, purpose: "LOGIN" }),
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok || !json.ok) {
            const c = json?.error?.code;
            if (c === "OTP_INVALID") showErr(window.t("Kode salah. Coba lagi."));
            else if (c === "OTP_EXPIRED") showErr(window.t("Kode sudah kadaluarsa. Kirim ulang."));
            else if (c === "OTP_TOO_MANY_ATTEMPTS") showErr(window.t("Terlalu banyak percobaan. Kirim OTP baru."));
            else showErr(window.t("Verifikasi gagal. Coba lagi."));
            return;
          }
          const token = json.data?.sessionToken;
          if (token) {
            localStorage.setItem("kongsian_session", token);
            showInfo(window.t("Berhasil! Mengecek status verifikasi…"));
            setTimeout(async () => {
              // P0 #3: gate on verification status. The API now returns 403 for
              // PENDING_VERIFICATION/REJECTED — we treat that as "blocked".
              try {
                const r = await fetch(`${API}/v1/brands/me`, { headers: { Authorization: `Bearer ${token}` }});
                const j = await r.json().catch(() => ({}));
                if (r.status === 403 && j?.error?.code === "VERIFICATION_PENDING") {
                  // Show a blocking in-page modal — do NOT redirect.
                  showVerificationBlock(j.error.message || "Akun kamu belum diverifikasi admin. Tunggu max 1x24 jam.");
                  return;
                }
                const role = j?.data?.role;
                if (role === "BRAND" || role === "BOTH") window.location.href = "/dashboard/brand";
                else if (role === "TENANT") window.location.href = "/dashboard/tenant";
                else window.location.href = "/dashboard/brand";
              } catch {
                window.location.href = "/dashboard/brand";
              }
            }, 400);
          } else {
            showErr(window.t("Tidak ada session token. Coba lagi."));
          }
        } catch (e) {
          showErr(window.t("Tidak bisa konek ke server. Coba lagi."));
        } finally {
          btn.disabled = false; btn.textContent = window.t("Verifikasi");
        }
      });

      // Resend: actually re-call the OTP endpoint, then drop the user back
      // into step 2 with the same phone.
      $("#resend").addEventListener("click", async () => {
        hideMsg();
        const phone = lastPhone || (countrySelect.value + phoneInput.value.replace(/[^\d]/g, "").replace(/^0/, ""));
        if (!/^\+[1-9]\d{7,14}$/.test(phone)) {
          showErr(window.t("Nomor tidak valid. Balik ke step 1 dan masukin lagi."));
          return;
        }
        const ok = await sendOtp(phone, null);
        if (ok) showInfo(window.t("OTP baru dikirim. Cek WhatsApp kamu."));
      });
    </script>
  </body>
</html>
