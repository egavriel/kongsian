---
import { APP_NAME } from "@kongsian/shared/constants";
import { API_BASE_URL } from "../lib/api";
const title = `Masuk — ${APP_NAME}`;
// ?registered=1 banner shown when user just registered
const showRegisteredBanner = Astro.url.searchParams.get("registered") === "1";
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: #0b1220;
        color: #f1f5f9;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        line-height: 1.55;
      }
      a { color: #38bdf8; text-decoration: none; }
      .wrap { max-width: 460px; margin: 0 auto; padding: 32px 20px 80px; }
      .back { font-size: 14px; color: #94a3b8; }
      .card {
        background: #0f172a;
        border: 1px solid #1e293b;
        border-radius: 14px;
        padding: 28px;
        margin-top: 24px;
      }
      .eyebrow { color: #fbbf24; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; }
      h1 { margin: 8px 0 12px; font-size: 28px; line-height: 1.15; }
      p { color: #94a3b8; margin: 0 0 24px; }
      label { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
      .lbl { font-size: 13px; font-weight: 600; }
      input {
        background: #0b1220;
        border: 1px solid #1e293b;
        color: #f1f5f9;
        padding: 14px 14px;
        border-radius: 10px;
        font-size: 16px;
        font-family: inherit;
        width: 100%;
      }
      input:focus { outline: none; border-color: #fbbf24; box-shadow: 0 0 0 3px rgba(251, 191, 36, .15); }
      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        padding: 14px 20px; border-radius: 10px; font-weight: 600;
        border: 1px solid transparent; cursor: pointer; font-size: 16px;
        width: 100%;
      }
      .btn-primary { background: #fbbf24; color: #0b1220; }
      .btn-primary:hover { background: #f59e0b; }
      .btn-ghost { background: transparent; color: #f1f5f9; border-color: #1e293b; }
      .btn:disabled { opacity: .5; cursor: not-allowed; }
      .err {
        background: rgba(251, 113, 133, .12);
        color: #fb7185;
        border: 1px solid rgba(251, 113, 133, .3);
        padding: 10px 12px; border-radius: 10px;
        font-size: 14px; margin-bottom: 16px;
      }
      .info {
        background: rgba(56, 189, 248, .1);
        color: #38bdf8;
        border: 1px solid rgba(56, 189, 248, .3);
        padding: 10px 12px; border-radius: 10px;
        font-size: 14px; margin-bottom: 16px;
      }
      .dev-code {
        font-family: ui-monospace, monospace;
        font-size: 22px; letter-spacing: 4px;
        background: #0b1220; border: 1px dashed #fbbf24;
        padding: 12px 16px; border-radius: 10px;
        text-align: center; color: #fbbf24; margin: 8px 0 16px;
      }
      .step2 { margin-top: 28px; padding-top: 24px; border-top: 1px solid #1e293b; display: none; }
      .step2.show { display: block; }
      .small { font-size: 13px; color: #94a3b8; }
      .muted { color: #94a3b8; }
      /* P0 #3: blocking verification modal */
      .block-modal {
        position: fixed; inset: 0; background: rgba(11, 18, 32, .85);
        display: none; align-items: center; justify-content: center;
        z-index: 50; padding: 20px;
      }
      .block-modal.show { display: flex; }
      .block-card {
        background: #0f172a; border: 1px solid #fbbf24; border-radius: 14px;
        padding: 28px; max-width: 420px; width: 100%; text-align: center;
      }
      .block-card .ic { font-size: 40px; display: block; margin-bottom: 12px; }
      .block-card .tt { font-weight: 700; font-size: 20px; margin-bottom: 8px; }
      .block-card .msg { color: #94a3b8; font-size: 14px; margin-bottom: 20px; }
    </style>
  </head>
  <body>
    <main class="wrap">
      <a class="back" href="/">← Kembali</a>
      <div class="card">
        {showRegisteredBanner && (
          <div class="info" style="margin-bottom:16px">
            <strong>Akun kamu sedang diverifikasi admin.</strong> Kami akan kabari via WA max 1x24 jam. Untuk sekarang kamu bisa login, tapi dashboard akan terbuka setelah admin approve.
          </div>
        )}
        <span class="eyebrow">Masuk</span>
        <h1>Selamat datang kembali</h1>
        <p>Masukin nomor WhatsApp kamu. Kami kirim OTP 6 digit.</p>

        <div id="err" class="err" style="display:none"></div>
        <div id="info" class="info" style="display:none"></div>

        <form id="otp-form">
          <label>
            <span class="lbl">Nomor HP (format +62)</span>
            <input
              id="phone"
              name="phone"
              type="tel"
              inputmode="tel"
              autocomplete="tel"
              placeholder="+628****7890"
              required
              pattern="^\+[1-9]\d{7,14}$"
            />
          </label>
          <button class="btn btn-primary" type="submit" id="send-btn">Kirim OTP via WhatsApp</button>
          <p class="small" style="margin-top:16px">
            Belum punya akun? Prosesnya &lt; 10 menit — kami auto-create akun pas verifikasi pertama.
          </p>
        </form>

        <div id="step2" class="step2">
          <span class="eyebrow">Step 2 of 2</span>
          <h2>Masukin kode OTP</h2>
          <p class="small">Dikirim ke <span id="otp-phone" class="muted"></span>. Berlaku 5 menit.</p>
          <div id="dev-code" class="dev-code" style="display:none"></div>
          <form id="verify-form">
            <label>
              <span class="lbl">6-digit kode</span>
              <input id="code" name="code" type="text" inputmode="numeric" autocomplete="one-time-code"
                     pattern="\d{6}" maxlength="6" placeholder="123456" required />
            </label>
            <button class="btn btn-primary" type="submit" id="verify-btn">Verifikasi</button>
            <button class="btn btn-ghost" type="button" id="resend" style="margin-top:8px">Kirim ulang</button>
          </form>
        </div>
      </div>
    </main>

    <!-- P0 #3: verification blocking modal -->
    <div id="verify-block" class="block-modal" role="dialog" aria-modal="true">
      <div class="block-card">
        <span class="ic">⏳</span>
        <div class="tt">Akun kamu belum diverifikasi admin</div>
        <div class="msg" id="verify-block-msg">Tunggu max 1x24 jam. Kami kabari via WhatsApp setelah approve.</div>
        <button class="btn btn-ghost" id="verify-block-logout">Keluar</button>
      </div>
    </div>

    <script define:vars={{ API_BASE_URL }}>
      const API = API_BASE_URL.replace(/\/$/, "");
      const $ = (s) => document.querySelector(s);
      const err = $("#err"), info = $("#info");
      const showErr = (m) => { err.textContent = m; err.style.display = "block"; info.style.display = "none"; };
      const showInfo = (m) => { info.textContent = m; info.style.display = "block"; err.style.display = "none"; };
      const hideMsg = () => { err.style.display = "none"; info.style.display = "none"; };
      const showVerificationBlock = (msg) => {
        document.getElementById("verify-block-msg").textContent = msg;
        document.getElementById("verify-block").classList.add("show");
        // Hide the OTP card so it cannot be interacted with.
        document.querySelector(".card").style.display = "none";
      };
      document.getElementById("verify-block-logout").addEventListener("click", () => {
        localStorage.removeItem("kongsian_session");
        window.location.href = "/login?registered=1";
      });

      let lastPhone = "";

      $("#otp-form").addEventListener("submit", async (e) => {
        e.preventDefault();
        hideMsg();
        const phone = $("#phone").value.trim();
        if (!/^\+[1-9]\d{7,14}$/.test(phone)) { showErr("Nomor harus format +62xxx (E.164)."); return; }
        const btn = $("#send-btn"); btn.disabled = true; btn.textContent = "Mengirim…";
        try {
          const res = await fetch(`${API}/v1/auth/otp/request`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ phone, purpose: "LOGIN" }),
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok || !json.ok) {
            const code = json?.error?.code;
            if (code === "OTP_RATE_LIMITED") {
              showErr("Kebanyakan percobaan. Coba lagi ~1 jam.");
            } else {
              showErr("Gagal kirim OTP. Coba lagi.");
            }
            return;
          }
          lastPhone = phone;
          $("#otp-phone").textContent = phone;
          $("#step2").classList.add("show");
          $("#otp-form").style.display = "none";
          if (json.data?.devCode) {
            $("#dev-code").textContent = json.data.devCode;
            $("#dev-code").style.display = "block";
            $("#code").value = json.data.devCode;
            showInfo("Dev mode: kode OTP sudah diisi otomatis di bawah.");
          } else {
            showInfo("OTP dikirim. Cek WhatsApp kamu.");
          }
        } catch (e) {
          showErr("Tidak bisa konek ke server. Coba lagi.");
        } finally {
          btn.disabled = false; btn.textContent = "Kirim OTP via WhatsApp";
        }
      });

      $("#verify-form").addEventListener("submit", async (e) => {
        e.preventDefault();
        hideMsg();
        const code = $("#code").value.trim();
        if (!/^\d{6}$/.test(code)) { showErr("Kode harus 6 digit angka."); return; }
        const btn = $("#verify-btn"); btn.disabled = true; btn.textContent = "Memverifikasi…";
        try {
          const res = await fetch(`${API}/v1/auth/otp/verify`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ phone: lastPhone, code, purpose: "LOGIN" }),
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok || !json.ok) {
            const c = json?.error?.code;
            if (c === "OTP_INVALID") showErr("Kode salah. Coba lagi.");
            else if (c === "OTP_EXPIRED") showErr("Kode sudah kadaluarsa. Kirim ulang.");
            else if (c === "OTP_TOO_MANY_ATTEMPTS") showErr("Terlalu banyak percobaan. Kirim OTP baru.");
            else showErr("Verifikasi gagal. Coba lagi.");
            return;
          }
          const token = json.data?.sessionToken;
          if (token) {
            localStorage.setItem("kongsian_session", token);
            showInfo("Berhasil! Mengecek status verifikasi…");
            setTimeout(async () => {
              // P0 #3: gate on verification status. The API now returns 403 for
              // PENDING_VERIFICATION/REJECTED — we treat that as "blocked".
              try {
                const r = await fetch(`${API}/v1/brands/me`, { headers: { Authorization: `Bearer ${token}` }});
                const j = await r.json().catch(() => ({}));
                if (r.status === 403 && j?.error?.code === "VERIFICATION_PENDING") {
                  // Show a blocking in-page modal — do NOT redirect.
                  showVerificationBlock(j.error.message || "Akun kamu belum diverifikasi admin. Tunggu max 1x24 jam.");
                  return;
                }
                const role = j?.data?.role;
                if (role === "BRAND" || role === "BOTH") window.location.href = "/dashboard/brand";
                else if (role === "TENANT") window.location.href = "/dashboard/tenant";
                else window.location.href = "/dashboard/brand";
              } catch {
                window.location.href = "/dashboard/brand";
              }
            }, 400);
          } else {
            showErr("Tidak ada session token. Coba lagi.");
          }
        } catch (e) {
          showErr("Tidak bisa konek ke server. Coba lagi.");
        } finally {
          btn.disabled = false; btn.textContent = "Verifikasi";
        }
      });

      $("#resend").addEventListener("click", () => {
        $("#otp-form").style.display = "block";
        $("#step2").classList.remove("show");
        $("#verify-form").reset();
      });
    </script>
  </body>
</html>
