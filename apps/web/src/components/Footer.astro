---
import { APP_NAME } from "@kongsian/shared/constants";
const year = new Date().getFullYear();
---
<footer class="container">
  <div class="row">
    <div>© {year} {APP_NAME}. Built in Jakarta.</div>
    <div class="links">
      <a href="#how">Cara kerja</a>
      <a href="#signup">Daftar</a>
      <a href="https://github.com/egavriel/kongsian">GitHub</a>
    </div>
  </div>
</footer>

<style>
  footer { padding: 40px 24px; border-top: 1px solid var(--line); color: var(--fg-muted); font-size: 14px; }
  .row { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
  .links { display: flex; gap: 18px; }
  .links a { color: var(--fg-muted); }
  .links a:hover { color: var(--fg); text-decoration: none; }
</style>
