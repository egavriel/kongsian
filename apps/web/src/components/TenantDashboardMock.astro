---
const today = "Kamis, 21 Nov";
---
<div class="title">Cafe B — PIC Hadi</div>
<div class="small">{today}</div>
<div style="margin-top:10px">
  <div class="big-cta">Catat Terjual Hari Ini</div>
  <div class="small" style="margin-top:8px">A: <span class="neu">12</span> · B: <span class="neu">8</span> · C: <span class="neu">5</span></div>
  <div class="small" style="margin-top:10px">⏱ Tersinkron 12 detik lalu</div>
</div>
<style>
  .big-cta {
    background: var(--brand);
    color: var(--brand-fg);
    text-align: center;
    padding: 14px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 14px;
  }
</style>
