# Application
NODE_ENV=development
LOG_LEVEL=debug
APP_URL=http://localhost:4321

# Cloudflare D1 (local) - remote IDs are in wrangler.toml
D1_DATABASE_ID=94a52c2f-af08-4642-b477-4edc2251f52b

# Auth secrets (set via `wrangler secret put` in real envs)
JWT_SECRET=dev-only-change-me
OTP_HMAC_KEY=dev-only-change-me
SESSION_COOKIE_NAME=kongsian_session

# WhatsApp Cloud API (test mode)
WA_PHONE_ID=placeholder_phone_id
WA_TOKEN=placeholder_token
WA_VERIFY_TOKEN=placeholder_verify_token

# Lucia / OTP TTLs
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
SESSION_TTL_SECONDS=2592000
